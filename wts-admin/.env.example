# WTS Admin Environment Configuration
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Session
SESSION_SECRET=your-super-secret-session-key-change-this

# Access control
# Public self-signup is disabled unless explicitly set to 'true'.
# Bootstrap the first admin with: node scripts/promote-admin.js <email>
ALLOW_SIGNUP=false
# Comma-separated emails allowed to auto-create accounts via Google/Facebook OAuth.
# Leave empty to block all new OAuth account creation (existing users still log in).
OAUTH_ALLOWED_EMAILS=

# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/wts_admin

# Database TLS
# Connections over Railway's private network (DATABASE_URL host ending in
# .railway.internal) use a plaintext connection automatically, since Postgres
# there presents no certificate. This is the recommended Railway setup and
# needs no TLS variables below.
#
# For connections over a PUBLIC host / TCP proxy, production requires a
# verified TLS connection: set PGSSLROOTCERT to the server CA certificate —
# either a file path or the PEM content itself.
# (Railway: copy the CA from the Postgres service's variables/TLS info.)
PGSSLROOTCERT=
# Hostname verification mode (with PGSSLROOTCERT set):
#   verify-full (default) — CA chain + hostname must match
#   verify-ca             — CA chain only; use when the server cert's SANs
#                           don't include the host you dial (e.g. Railway's
#                           *.proxy.rlwy.net TCP proxy in front of a
#                           self-signed Postgres certificate)
# PGSSL_VERIFY=verify-full
# Development-only escape hatch for managed DBs without the CA at hand
# (accepts any certificate — never allowed in production):
# PGSSL_INSECURE=true

# Connection pool size (default 10)
# PG_POOL_MAX=10

# Or use individual PG variables
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=wts_admin

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=/auth/google/callback

# Facebook OAuth (optional)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=/auth/facebook/callback

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=WTS Admin <noreply@wordsthatsells.website>

# Stripe (for digital product payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://wordsthatsells.website

# Anthropic API (for AI image analysis - auto-generates SEO metadata)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Image storage
# Local working copy of the image library. Defaults to the in-repo
# sibling directory (../images). Point at a mounted Railway volume
# (e.g. /data/images) for a copy that survives redeploys — the durable
# canonical store remains the GitHub repo + jsDelivr CDN either way.
# IMAGES_DIR=/data/images
# Multer temp directory for in-flight uploads (default: ./uploads/temp)
# UPLOAD_TEMP_DIR=/data/uploads-temp

# GitHub API token used to push uploaded images to the repo (CDN origin)
GITHUB_TOKEN=

# Telemetry webhook ingest (POST /api/webhooks/telemetry)
# Senders must sign the raw JSON body: X-Telemetry-Signature: hex(HMAC_SHA256(secret, body))
# If unset, the endpoint rejects all requests with 503.
TELEMETRY_WEBHOOK_SECRET=

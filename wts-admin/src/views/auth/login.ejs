<%- include('../partials/head', { title, bodyClass: 'auth-page' }) %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <img src="/images/SEO_AI_Digital_Marketing_Agency_Laos_Thailand_Asia_logo_with-words_white_colour_SVG.svg" alt="Words That Sells" class="auth-logo-svg">
      <p>Admin Dashboard</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= error %></span>
    </div>
    <% } %>

    <form class="auth-form" action="/auth/login" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label class="form-label" for="email">Email Address</label>
        <div class="form-input-icon">
          <i class="fas fa-envelope"></i>
          <input type="email" id="email" name="email" class="form-input" placeholder="Enter your email" value="<%= typeof email !== 'undefined' ? email : '' %>" required>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <div class="form-input-icon">
          <i class="fas fa-lock"></i>
          <input type="password" id="password" name="password" class="form-input" placeholder="Enter your password" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-checkbox">
          <input type="checkbox" id="remember" name="remember">
          <label for="remember">Remember me</label>
        </div>
        <a href="/auth/forgot-password" class="form-link">Forgot password?</a>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fas fa-sign-in-alt"></i>
        Sign In
      </button>
    </form>

    <% var showGoogle = typeof googleEnabled === 'undefined' || googleEnabled; %>
    <% var showFacebook = typeof facebookEnabled === 'undefined' || facebookEnabled; %>
    <% if (showGoogle || showFacebook) { %>
    <div class="auth-divider">
      <span>or continue with</span>
    </div>

    <div class="social-login">
      <% if (showGoogle) { %>
      <a href="/auth/google" class="social-btn google">
        <i class="fab fa-google"></i>
        Google
      </a>
      <% } %>
      <% if (showFacebook) { %>
      <a href="/auth/facebook" class="social-btn facebook">
        <i class="fab fa-facebook-f"></i>
        Facebook
      </a>
      <% } %>
    </div>
    <% } %>

    <% if (typeof signupEnabled !== 'undefined' && signupEnabled) { %>
    <div class="auth-footer">
      Don't have an account? <a href="/auth/signup">Sign up</a>
    </div>
    <% } %>

    <p class="auth-legal-note">
      By signing in you agree to the
      <a href="https://wordsthatsells.website/en/company/legal/terms-and-conditions.html" target="_blank" rel="noopener noreferrer">Terms</a>
      and
      <a href="https://wordsthatsells.website/en/company/legal/privacy-policy.html" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
      of Laboise eworker Laos enterprise (operator of WordsThatSells.Website).
    </p>
  </div>
</div>

<%- include('../partials/footer') %>

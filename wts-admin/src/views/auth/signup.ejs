<%- include('../partials/head', { title, bodyClass: 'auth-page' }) %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <img src="/images/SEO_AI_Digital_Marketing_Agency_Laos_Thailand_Asia_logo_with-words_white_colour_SVG.svg" alt="Words That Sells" class="auth-logo-svg">
      <h1>Create Account</h1>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= error %></span>
    </div>
    <% } %>

    <form class="auth-form" action="/auth/signup" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="firstName">First Name</label>
          <input type="text" id="firstName" name="firstName" class="form-input" placeholder="John" value="<%= typeof formData !== 'undefined' && formData ? formData.firstName : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="lastName">Last Name</label>
          <input type="text" id="lastName" name="lastName" class="form-input" placeholder="Doe" value="<%= typeof formData !== 'undefined' && formData ? formData.lastName : '' %>" required>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="email">Email Address</label>
        <div class="form-input-icon">
          <i class="fas fa-envelope"></i>
          <input type="email" id="email" name="email" class="form-input" placeholder="john@example.com" value="<%= typeof formData !== 'undefined' && formData ? formData.email : '' %>" required>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <div class="form-input-icon">
          <i class="fas fa-lock"></i>
          <input type="password" id="password" name="password" class="form-input" placeholder="Min. 8 characters" minlength="8" required>
        </div>
        <p class="form-help">Must be at least 8 characters long</p>
      </div>

      <div class="form-group">
        <div class="form-checkbox">
          <input type="checkbox" id="terms" name="terms" required>
          <label for="terms">I agree to the <a href="https://wordsthatsells.website/en/company/legal/terms-and-conditions.html" target="_blank" rel="noopener noreferrer">Terms of Service</a> and <a href="https://wordsthatsells.website/en/company/legal/privacy-policy.html" target="_blank" rel="noopener noreferrer">Privacy Policy</a></label>
        </div>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fas fa-user-plus"></i>
        Create Account
      </button>
    </form>

    <% var showGoogle = typeof googleEnabled === 'undefined' || googleEnabled; %>
    <% var showFacebook = typeof facebookEnabled === 'undefined' || facebookEnabled; %>
    <% if (showGoogle || showFacebook) { %>
    <div class="auth-divider">
      <span>or continue with</span>
    </div>

    <div class="social-login">
      <% if (showGoogle) { %>
      <a href="/auth/google" class="social-btn google">
        <i class="fab fa-google"></i>
        Google
      </a>
      <% } %>
      <% if (showFacebook) { %>
      <a href="/auth/facebook" class="social-btn facebook">
        <i class="fab fa-facebook-f"></i>
        Facebook
      </a>
      <% } %>
    </div>
    <% } %>

    <div class="auth-footer">
      Already have an account? <a href="/auth/login">Sign in</a>
    </div>

    <p class="auth-legal-note">
      By creating an account you agree to the
      <a href="https://wordsthatsells.website/en/company/legal/terms-and-conditions.html" target="_blank" rel="noopener noreferrer">Terms</a>
      and
      <a href="https://wordsthatsells.website/en/company/legal/privacy-policy.html" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
      of Laboise eworker Laos enterprise (operator of WordsThatSells.Website).
    </p>
  </div>
</div>

<%- include('../partials/footer') %>

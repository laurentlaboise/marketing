<%- include('../portal/partials/head') %>
  <style>
    .wrap { flex: 1; max-width: 760px; width: 100%; margin: 0 auto; padding: 1.5rem 1rem 2.5rem; }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin: 0.5rem 0 0.15rem; }
    p.sub { color: #64748b; font-size: 0.9rem; margin-bottom: 1rem; }
    .board { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem 1.15rem; margin-bottom: 0.9rem; display: flex; justify-content: space-between; gap: 0.85rem; align-items: center; flex-wrap: wrap; }
    .board strong { color: #1a1a2e; font-size: 0.98rem; }
    .board .bmeta { color: #94a3b8; font-size: 0.78rem; margin-top: 0.3rem; }
    .role-badge { display: inline-block; border-radius: 999px; padding: 0.15rem 0.65rem; font-size: 0.74rem; font-weight: 600; background: #e2e8f0; color: #475569; line-height: 1.45; }
    .role-badge.editor { background: #dcfce7; color: #166534; }
    .role-badge.commenter { background: #fef3c7; color: #92400e; }
    .role-badge.viewer { background: #e0f2fe; color: #075985; }
    .board a.open { background: #d62b83; color: #fff; text-decoration: none; border-radius: 8px; padding: 0.5rem 1.1rem; font-size: 0.86rem; font-weight: 600; white-space: nowrap; line-height: 1.45; }
    .empty { background: #fff; border: 1px dashed #cbd5e1; border-radius: 14px; padding: 2.5rem 1rem; text-align: center; color: #64748b; }
  </style>
</head>
<body>
  <%- include('../portal/partials/topbar') %>
  <div class="wrap">
    <h1><%= t('boards.heading') %></h1>
    <p class="sub"><%= t('boards.subtitle') %></p>

    <%- include('../portal/partials/nav', { active: 'boards' }) %>

    <% if (boards.length === 0) { %>
      <div class="empty">
        <p style="margin-bottom:0.5rem;"><%= t('boards.empty') %></p>
      </div>
    <% } %>

    <% boards.forEach(function (b) { %>
    <div class="board">
      <div style="flex:1;min-width:200px;">
        <strong><%= b.title %></strong>
        <span class="role-badge <%= b.role %>"><%= t('boards.role.' + b.role) %></span>
        <% if (b.approval_status) {
             var apKnown = { awaiting_review: true, needs_changes: true, approved: true }[b.approval_status];
             var apLabel = apKnown ? t('boards.approval.' + b.approval_status) : b.approval_status;
             var apStyle = { awaiting_review: 'background:#fef3c7;color:#92400e;', needs_changes: 'background:#fee2e2;color:#b91c1c;', approved: 'background:#dcfce7;color:#166534;' }[b.approval_status] || 'background:#e2e8f0;color:#475569;';
        %>
        <span style="display:inline-block;border-radius:999px;padding:0.15rem 0.65rem;font-size:0.74rem;font-weight:600;white-space:nowrap;line-height:1.45;<%= apStyle %>"><%= apLabel %></span>
        <% } %>
        <% if (b.unresolved_comments > 0) { %>
        <span title="<%= t('boards.openCommentsTooltip') %>" style="display:inline-block;border-radius:999px;padding:0.15rem 0.65rem;font-size:0.74rem;font-weight:600;white-space:nowrap;line-height:1.45;background:#e0f2fe;color:#075985;"><%= t(b.unresolved_comments === 1 ? 'boards.openCommentsOne' : 'boards.openCommentsMany', { count: b.unresolved_comments }) %></span>
        <% } %>
        <div class="bmeta"><%= t('boards.updated', { date: fmtDate(b.updated_at) }) %></div>
      </div>
      <a class="open" href="/portal/boards/<%= b.id %>"><%= t('boards.openBoard') %></a>
    </div>
    <% }); %>
  </div>
  <%- include('../portal/partials/footer') %>

        .catch(function (e) { toast(e.message); });
    }
    function markFinal(img) {
      var raw = prompt('Price in USD for the final file (0 = free download):', img.price != null ? img.price : '');
      if (raw === null) return;
      var price = parseFloat(raw);
      if (!isFinite(price) || price < 0) { toast('Enter a price of 0 or more.'); return; }
      var title = prompt('Name for the downloaded file (optional):', img.title || cfg.boardTitle) || '';
      api('POST', '/assets/' + img.id + '/final', { price: price, title: title })
        .then(loadAll)
        .then(function () { toast(price > 0 ? 'Marked as final — locked until paid.' : 'Marked as final — free to download.'); })
        .catch(function (e) { toast(e.message); });
    }
    function unmarkFinal(img) {
      if (!confirm('Remove the final-deliverable mark from this image?')) return;
      api('POST', '/assets/' + img.id + '/final', { remove: true })
        .then(loadAll).then(function () { toast('No longer marked as final.'); })
        .catch(function (e) { toast(e.message); });
    }
    function unlockFinal(img) {
      if (!confirm('Mark this deliverable as paid and unlock the client download?')) return;
      api('POST', '/assets/' + img.id + '/unlock')
        .then(loadAll).then(function () { toast('Unlocked — the client can download it now.'); })
        .catch(function (e) { toast(e.message); });
    }

    // ── Chrome (everything outside the canvas) ───────────────────
    function renderChrome() {
      renderApproval(); renderFilm(); renderDeliverable(); renderPanel(); renderCount(); repaintPinStates();
      updateSelection(); renderNodeTools();
      // Banner/approval visibility changes move and resize the viewport —
      // drop the cached rect so gesture math reads the fresh box.
      vpRect = null;
    }

    function updateSelection() {
      Object.keys(nodesById).forEach(function (id) {
        var node = nodesById[id];
        var selected = state.canArrange && id === state.current;
        node.classList.toggle('selected', selected);
        var handle = node.querySelector('.rs-handle');
        if (selected && !handle) {
          handle = document.createElement('div');
          handle.className = 'rs-handle';
          handle.title = 'Drag to resize';
          node.appendChild(handle);
        } else if (!selected && handle) {
          handle.remove();
        }
      });
    }

    function renderNodeTools() {
      var el = document.getElementById('node-tools');
      var tidyBtn = document.getElementById('tidy');
      tidyBtn.hidden = !(state.canArrange && state.images.length > 1);
      var img = currentImage();
      if (!img) { el.hidden = true; el.innerHTML = ''; return; }
      el.hidden = false;
      var canDelete = state.canArrange && (!img.is_final || cfg.isAdmin);
      el.innerHTML =
        '<button type="button" data-t="export">&#10515; Export</button>' +
        (state.canArrange
          ? '<button type="button" data-t="front">&#8613; Front</button>' +
            '<button type="button" data-t="back">&#8615; Back</button>' +
            (canDelete ? '<button type="button" class="danger" data-t="remove">Remove</button>' : '')
          : '');
      el.querySelectorAll('button[data-t]').forEach(function (b) {
        b.addEventListener('click', function () {
          var act = b.getAttribute('data-t');
          if (act === 'export') {
            openExportPopover(img);
          } else if (act === 'front') {
            var maxZ = state.images.reduce(function (m, i) { return Math.max(m, i.z || 0); }, 0);
            persistPlacement(img, { z: Math.min(100000, maxZ + 1) });
            applyPlacement(nodesById[img.id], img);
          } else if (act === 'back') {
            persistPlacement(img, { z: 0 });
            applyPlacement(nodesById[img.id], img);
          } else if (act === 'remove') {
            if (!confirm('Remove this image from the board? Its comments stay in the panel as history.')) return;
            api('POST', '/assets/' + img.id + '/delete')
              .then(function () { state.current = null; return loadAll(); })
              .then(function () { toast('Image removed.'); })
              .catch(function (er) { toast(er.message); });
          }
        });
      });
    }

    // ── Export pipeline (blueprint §6): renders from the DATA MODEL into an
    // offscreen canvas in natural-pixel space — the viewport transform and
    // UI chrome are never inputs, so they cannot leak into the artifact.
    function slugify(s) {
      return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 40) || 'design';
    }

    function decodeBlob(blob) {
      if (window.createImageBitmap) return createImageBitmap(blob);
      return new Promise(function (res, rej) {
        var u = URL.createObjectURL(blob);
        var im = new Image();
        im.onload = function () { URL.revokeObjectURL(u); res(im); };
        im.onerror = function () { URL.revokeObjectURL(u); rej(new Error('Could not read the image.')); };
        im.src = u;
      });
    }

    function drawWatermark(ctx, W, H) {
      var diag = Math.hypot(W, H);
      var fontPx = Math.max(18, diag * 0.028);
      ctx.save();
      ctx.globalAlpha = 0.14;
      ctx.fillStyle = '#122a3f';
      ctx.font = '700 ' + Math.round(fontPx) + 'px -apple-system, "Segoe UI", Roboto, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.translate(W / 2, H / 2);
      ctx.rotate(-30 * Math.PI / 180);
      var text = 'PROOF — Words That Sells';
      var stepX = Math.max(1, ctx.measureText(text).width * 1.6);
      var stepY = fontPx * 6;
      for (var y = -diag; y <= diag; y += stepY) {
        var off = (Math.abs(Math.round(y / stepY)) % 2) * (stepX / 2);
        for (var x = -diag; x <= diag; x += stepX) ctx.fillText(text, x + off, y);
      }
      ctx.restore();
    }

    function exportNode(img, opts) {
      var locked = img.is_final && img.payment_status === 'locked' && !cfg.isAdmin;
      var wantAnnots = locked ? true : !!opts.annotations;
      var wantLegend = wantAnnots && !!opts.legend;
      toast('Preparing export…');
      fetch(img.src, { credentials: 'same-origin' })
        .then(function (r) {
          if (!r.ok) throw new Error('Could not fetch the image (' + r.status + ').');
          return r.blob();
        })
        .then(decodeBlob)
        .then(function (bmp) {
          var nw = bmp.width, nh = bmp.height;
          if (!nw || !nh) throw new Error('Could not read the image.');
          // Memory clamps: Safari misbehaves past ~16M px / 8192 a side.
          var s = 1;
          if (locked) s = Math.min(s, 1600 / Math.max(nw, nh));
          s = Math.min(s, 8192 / Math.max(nw, nh), Math.sqrt(14000000 / (nw * nh)));
          s = Math.max(0.02, Math.min(1, s));
          var W = Math.max(1, Math.round(nw * s));
          var H = Math.max(1, Math.round(nh * s));
          var diag = Math.hypot(W, H);

          var pins = pinsFor(img.id); // numbering source: FULL list, matches on-screen badges
          var visible = wantAnnots ? pins.filter(function (c) { return opts.includeResolved || !c.resolved_at; }) : [];

          // Legend measure pass (throwaway ctx so the real canvas is sized once)
          var fontPx = Math.round(Math.min(26, Math.max(13, diag * 0.012)));
          var lineH = Math.round(fontPx * 1.45);
          var pad = Math.round(fontPx * 1.2);
          var entries = [];
          var legendH = 0;
          if (wantLegend && visible.length) {
            var mctx = document.createElement('canvas').getContext('2d');
            mctx.font = '400 ' + fontPx + 'px -apple-system, "Segoe UI", Roboto, sans-serif';
            visible.forEach(function (c) {
              var text = (c.author_name || 'Comment') + ': ' + String(c.body || '').slice(0, 200) + (c.body && c.body.length > 200 ? '…' : '');
              var words = text.split(/\s+/);
              var lines = [];
              var line = '';
              var maxW = W - pad * 2 - fontPx * 1.6;
              words.forEach(function (w) {
                var probe = line ? line + ' ' + w : w;
                if (mctx.measureText(probe).width > maxW && line) { lines.push(line); line = w; }
                else line = probe;
              });
              if (line) lines.push(line);
              entries.push({ n: pins.indexOf(c) + 1, resolved: !!c.resolved_at, lines: lines });
              legendH += lines.length * lineH + Math.round(fontPx * 0.5);
            });
            legendH += pad * 2;
          }

          var canvas = document.createElement('canvas');
          canvas.width = W;
          canvas.height = H + legendH;
          var ctx = canvas.getContext('2d');
          ctx.imageSmoothingQuality = 'high';
          ctx.drawImage(bmp, 0, 0, W, H);
          if (bmp.close) bmp.close();

          if (locked) drawWatermark(ctx, W, H);

          // Badges in natural-pixel space, sized off the image diagonal so a
          // pin looks identical whether the user was zoomed to 10% or 400%.
          var r = Math.min(40, Math.max(12, diag * 0.011));
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          visible.forEach(function (c) {
            var px = (c.anchor.xPct / 100) * W;
            var py = (c.anchor.yPct / 100) * H;
            ctx.beginPath();
            ctx.arc(px, py, r, 0, Math.PI * 2);
            ctx.fillStyle = c.resolved_at ? 'rgba(148,163,184,0.95)' : 'rgba(214,43,131,0.95)';
            ctx.fill();
            ctx.lineWidth = Math.max(2, r * 0.14);
            ctx.strokeStyle = '#ffffff';
            ctx.stroke();
            ctx.fillStyle = '#ffffff';
            ctx.font = '700 ' + Math.round(r * 1.05) + 'px -apple-system, "Segoe UI", Roboto, sans-serif';
            ctx.fillText(String(pins.indexOf(c) + 1), px, py);
          });

          if (entries.length) {
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(0, H, W, legendH);
            ctx.fillStyle = '#e2e8f0';
            ctx.fillRect(0, H, W, 1);
            var y = H + pad + lineH / 2;
            entries.forEach(function (en) {
              var br = fontPx * 0.55;
              ctx.beginPath();
              ctx.arc(pad + br, y, br, 0, Math.PI * 2);
              ctx.fillStyle = en.resolved ? '#94a3b8' : '#d62b83';
              ctx.fill();
              ctx.fillStyle = '#ffffff';
              ctx.font = '700 ' + Math.round(fontPx * 0.8) + 'px -apple-system, "Segoe UI", Roboto, sans-serif';
              ctx.fillText(String(en.n), pad + br, y);
              ctx.fillStyle = '#334155';
              ctx.font = '400 ' + fontPx + 'px -apple-system, "Segoe UI", Roboto, sans-serif';
              ctx.textAlign = 'left';
              en.lines.forEach(function (ln, li) {
                ctx.fillText(ln, pad + fontPx * 1.6, y + li * lineH);
              });
              ctx.textAlign = 'center';
              y += en.lines.length * lineH + Math.round(fontPx * 0.5);
            });
          }

          return new Promise(function (res, rej) {
            canvas.toBlob(function (b) {
              if (b) res({ blob: b, locked: locked, annotated: wantAnnots });
              else rej(new Error('This image is too large to export here — try on a desktop browser.'));
            }, 'image/png');
          });
        })
        .then(function (out) {
          var d = new Date();
          var p2 = function (n) { return (n < 10 ? '0' : '') + n; };
          var stamp = d.getFullYear() + p2(d.getMonth() + 1) + p2(d.getDate()) + '-' + p2(d.getHours()) + p2(d.getMinutes());
          var kind = out.locked ? 'proof' : (out.annotated ? 'annotated' : 'clean');
          var url = URL.createObjectURL(out.blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = slugify(cfg.boardTitle) + '_' + slugify(img.title || 'design') + '_' + kind + '_' + stamp + '.png';
          document.body.appendChild(a);
          a.click();
          a.remove();
          setTimeout(function () { URL.revokeObjectURL(url); }, 10000);
          toast(out.locked ? 'Watermarked proof exported.' : 'Export downloaded.');
        })
        .catch(function (e) { toast(e.message); });
    }

    function openExportPopover(img) {
      closeComposer();
      var old = viewport.querySelector('.export-pop');
      if (old) { old.remove(); return; }
      var locked = img.is_final && img.payment_status === 'locked' && !cfg.isAdmin;
      var pop = document.createElement('div');
      pop.className = 'export-pop';
      pop.innerHTML =
        '<label><input type="checkbox" id="x-annot" checked' + (locked ? ' disabled' : '') + '> Comment pins</label>' +
        '<label><input type="checkbox" id="x-res"> Include resolved</label>' +
        '<label><input type="checkbox" id="x-legend"> Comment legend</label>' +
        (locked ? '<div class="note">&#128274; Locked final &mdash; exports as a watermarked proof. The clean file unlocks with payment.</div>' : '') +
        '<div class="row"><button type="button" class="cancel">Cancel</button><button type="button" class="go">Export PNG</button></div>';
      viewport.appendChild(pop);
      pop.querySelector('.cancel').addEventListener('click', function () { pop.remove(); });
      pop.querySelector('.go').addEventListener('click', function () {
        var opts = {
          annotations: pop.querySelector('#x-annot').checked,
          includeResolved: pop.querySelector('#x-res').checked,
          legend: pop.querySelector('#x-legend').checked
        };
        pop.remove();
        exportNode(img, opts);
      });
    }

    document.getElementById('tidy').addEventListener('click', function () {
      var GAP = 120;
      var imgs = state.images;
      if (imgs.length < 2) return;
      var cols = Math.ceil(Math.sqrt(imgs.length));
      var maxW = 0, maxH = 0;
      imgs.forEach(function (i) { var r = nodeRect(i); maxW = Math.max(maxW, r.w); maxH = Math.max(maxH, r.h); });
      var placements = imgs.map(function (i, n) {
        return { id: i.id, x: (n % cols) * (maxW + GAP), y: Math.floor(n / cols) * (maxH + GAP), z: n };
      });
      api('POST', '/assets/arrange', { placements: placements })
        .then(loadAll)
        .then(function () { fitAll(); toast('Board tidied.'); })
        .catch(function (e) { toast(e.message); });
    });

    function repaintPinStates() {
      state.images.forEach(function (img) {
        var node = nodesById[img.id];
        if (node) renderPins(node, img);
      });
    }

    function renderCount() {
      var open = roots().filter(function (c) { return !c.resolved_at; }).length;
      document.getElementById('c-count').textContent = open + ' open comment' + (open === 1 ? '' : 's');
    }

    function renderApproval() {
      var el = document.getElementById('approval');
      var a = state.approval;
      var LABELS = { awaiting_review: 'Awaiting review', needs_changes: 'Changes requested', approved: 'Approved' };
      var h = '';
      if (a) {
        h += '<span class="chip ' + esc(a.status) + '">' + LABELS[a.status] + '</span>';
        var note = a.status === 'awaiting_review' ? a.request_note : a.reviewer_note;
        if (note) h += '<span class="note">&ldquo;' + esc(note) + '&rdquo;</span>';
      } else {
        h += '<span class="note">' + (cfg.isAdmin ? 'No approval requested yet.' : 'Nothing awaiting your approval.') + '</span>';
      }
      h += '<span class="spacer"></span>';
      if (cfg.canApprove && (!a || a.status !== 'awaiting_review')) h += '<button class="abtn primary" id="btn-request">Request approval</button>';
      if (cfg.canDecide && a && a.status === 'awaiting_review') {
        h += '<button class="abtn approve" id="btn-approve">Approve</button>' +
             '<button class="abtn changes" id="btn-changes">Request changes</button>';
      }
      el.innerHTML = h;
      var rq = document.getElementById('btn-request');
      if (rq) rq.addEventListener('click', function () {
        var note = prompt('Add a note for the client (optional):') || '';
        api('POST', '/approvals', { note: note }).then(loadAll).then(function () { toast('Review requested — the client has been emailed.'); })
          .catch(function (e) { toast(e.message); });
      });
      var ap = document.getElementById('btn-approve');
      if (ap) ap.addEventListener('click', function () {
        api('POST', '/approvals/' + state.approval.id + '/decide', { decision: 'approved' }).then(loadAll).then(function () { toast('Approved — thank you!'); })
          .catch(function (e) { toast(e.message); });
      });
      var ch = document.getElementById('btn-changes');
      if (ch) ch.addEventListener('click', function () {
        var note = prompt('What should we change?') || '';
        api('POST', '/approvals/' + state.approval.id + '/decide', { decision: 'needs_changes', note: note }).then(loadAll).then(function () { toast('Change request sent.'); })
          .catch(function (e) { toast(e.message); });
      });
    }

    function renderFilm() {
      var el = document.getElementById('film');
      el.innerHTML = '';
      state.images.forEach(function (img) {
        var wrap = document.createElement('div');
        wrap.className = 'thumb';
        var t = document.createElement('img');
        t.src = img.src;
        t.alt = 'design';
        if (img.id === state.current) t.className = 'active';
        t.addEventListener('click', function () {
          state.current = img.id;
          state.activeThread = null;
          renderChrome();
          zoomToNode(img);
        });
        wrap.appendChild(t);
        if (img.is_final) {
          var s = document.createElement('span');
          s.className = 'star';
          s.innerHTML = '&#9733;';
          s.title = 'Final deliverable';
          wrap.appendChild(s);
        }
        el.appendChild(wrap);
      });
      if (cfg.canUpload) {
        var add = document.createElement('button');
        add.className = 'add';
        add.type = 'button';
        add.textContent = '+ Add image';
        add.addEventListener('click', function () { document.getElementById('file-input').click(); });
        el.appendChild(add);
      }
      el.hidden = !state.images.length && !cfg.canUpload;
    }

    document.getElementById('file-input').addEventListener('change', function () {
      var f = this.files && this.files[0];
      this.value = '';
      if (!f) return;
      var fd = new FormData();
      fd.append('file', f);
      fetch(cfg.apiBase + '/assets', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'X-CSRF-Token': cfg.csrfToken }, body: fd
      }).then(function (r) { return r.json().then(function (d) { if (!r.ok) throw new Error(d.error || 'Upload failed'); }); })
        .then(loadAll)
        .then(function () {
          toast('Image added.');
          var latest = state.images[state.images.length - 1];
          if (latest) { state.current = latest.id; renderChrome(); zoomToNode(latest); }
        })
        .catch(function (e) { toast(e.message); });
    });

    function renderDeliverable() {
      var el = document.getElementById('deliverable');
      var img = currentImage();
      if (!img || (!img.is_final && !cfg.isAdmin)) { el.hidden = true; el.innerHTML = ''; return; }
      el.hidden = false;
      var h = '';
      if (img.is_final) {
        var locked = img.payment_status === 'locked';
        el.className = 'deliverable ' + (locked ? 'locked' : 'unlocked');
        h += '<span>&#9733; <strong>Final deliverable</strong>' +
             (img.title ? ' &mdash; ' + esc(img.title) : '') +
             (locked && img.price != null ? ' &middot; ' + fmtPrice(img.price) : '') + '</span>';
        h += '<span class="spacer"></span>';
        if (cfg.isAdmin) {
          h += '<button type="button" class="abtn ghost" data-d="download">&#8595; Download</button>';
          if (locked) h += '<button type="button" class="abtn approve" data-d="unlock">Mark paid &mdash; unlock</button>';
          h += '<button type="button" class="abtn ghost" data-d="unmark">Unmark final</button>';
        } else if (locked) {
          h += '<button type="button" class="abtn gold" data-d="pay">&#128274; Pay to download' + (img.price != null ? ' &mdash; ' + fmtPrice(img.price) : '') + '</button>';
          h += '<button type="button" class="abtn ghost" data-d="bcel">Pay by bank transfer</button>';
        } else {
          h += '<button type="button" class="abtn approve" data-d="download">&#8595; Download final</button>';
        }
      } else {
        el.className = 'deliverable plain';
        h += '<span>Working file &mdash; not marked as the final deliverable.</span><span class="spacer"></span>' +
             '<button type="button" class="abtn ghost" data-d="mark">Mark as final&hellip;</button>';
      }
      el.innerHTML = h;
      el.querySelectorAll('button[data-d]').forEach(function (b) {
        b.addEventListener('click', function () {
          var act = b.getAttribute('data-d');
          if (act === 'pay') payFor(img);
          else if (act === 'bcel') bcelFor(img);
          else if (act === 'download') downloadFinal(img);
          else if (act === 'mark') markFinal(img);
          else if (act === 'unmark') unmarkFinal(img);
          else if (act === 'unlock') unlockFinal(img);
        });
      });
    }

    function threadHtml(c, n) {
      var reps = repliesOf(c.id);
      var h = '<div class="thread' + (c.resolved_at ? ' resolved-t' : '') + (state.activeThread === c.id ? ' active' : '') + '" data-thread="' + c.id + '">' +
        '<div class="meta">' + (n != null ? '<span class="pin-n">' + n + '</span>' : '') +
        '<span class="who">' + esc(c.author_name) + '</span><span>' + ago(c.created_at) + '</span>' +
        (c.resolved_at ? '<span>· resolved</span>' : '') + '</div>' +
        '<div class="body">' + esc(c.body) + '</div>';
      reps.forEach(function (r) {
        h += '<div class="reply"><div class="meta"><span class="who">' + esc(r.author_name) + '</span><span>' + ago(r.created_at) + '</span></div>' +
             '<div class="body">' + esc(r.body) + '</div></div>';
      });
      if (cfg.canComment) {
        h += '<div class="actions">' +
          '<button type="button" data-act="reply" data-id="' + c.id + '">Reply</button>' +
          (c.resolved_at
            ? '<button type="button" class="unres" data-act="unresolve" data-id="' + c.id + '">Reopen</button>'
            : '<button type="button" class="res" data-act="resolve" data-id="' + c.id + '">&#10003; Resolve</button>') +
          '</div>';
      }
      return h + '</div>';
    }

    function renderPanel() {
      var el = document.getElementById('threads');
      var img = currentImage();
      var pins = img ? pinsFor(img.id) : [];
      var open = pins.filter(function (c) { return !c.resolved_at; });
      var done = pins.filter(function (c) { return c.resolved_at; });
      var gen = generals();
      var h = '';
      if (cfg.canComment) {
        h += '<div class="muted" style="text-align:left;">' + (img ? 'Tap an image to pin a comment. Drag to pan, pinch or ctrl+scroll to zoom.' + (state.canArrange ? ' Drag an image to move it.' : '') : '') + '</div>';
      }
      if (!pins.length && !gen.length) h += '<div class="muted">No comments yet.</div>';
      open.forEach(function (c) { h += threadHtml(c, pins.indexOf(c) + 1); });
      if (gen.length) {
        h += '<div class="resolved-h">General</div>';
        gen.forEach(function (c) {
          var removed = c.anchor && c.anchor.imageId;
          h += threadHtml(c, null).replace('</div>' /* first meta close */, (removed ? '<span>&middot; image removed</span>' : '') + '</div>');
        });
      }
      if (done.length) {
        h += '<div class="resolved-h">Resolved</div>';
        done.forEach(function (c) { h += threadHtml(c, pins.indexOf(c) + 1); });
      }
      el.innerHTML = h;

      el.querySelectorAll('.thread').forEach(function (t) {
        t.addEventListener('click', function () {
          state.activeThread = t.getAttribute('data-thread');
          flyToThread(state.activeThread);
          renderChrome();
        });
      });
      el.querySelectorAll('button[data-act]').forEach(function (b) {
        b.addEventListener('click', function (e) {
          e.stopPropagation();
          var id = b.getAttribute('data-id');
          var act = b.getAttribute('data-act');
          if (act === 'resolve' || act === 'unresolve') {
            api('POST', '/comments/' + id + '/' + act).then(loadAll).catch(function (er) { toast(er.message); });
            return;
          }
          var thread = b.closest('.thread');
          if (thread.querySelector('textarea')) return;
          var ta = document.createElement('textarea');
          ta.maxLength = 2000;
          ta.placeholder = 'Reply…';
          thread.appendChild(ta);
          ta.focus();
          ta.addEventListener('click', function (ev) { ev.stopPropagation(); });
          ta.addEventListener('keydown', function (ev) {
            if (ev.key === 'Enter' && !ev.shiftKey) {
              ev.preventDefault();
              var body = ta.value.trim();
              if (!body) return;
              api('POST', '/comments', { body: body, parentId: id }).then(loadAll).catch(function (er) { toast(er.message); });
            }
            if (ev.key === 'Escape') ta.remove();
          });
        });
      });
    }

    // Back from a successful checkout: fast-poll (2s for 30s) until the
    // webhook has flipped the asset to 'unlocked' — the Download button
    // should appear near-instantly, not on the lazy 12s cycle.
    if (/[?&]paid=1(&|$)/.test(window.location.search)) {
      toast('Payment received — checking with the bank…');
      try { history.replaceState(null, '', window.location.pathname); } catch (e) { /* ignore */ }
      var paidTries = 0;
      var paidTimer = setInterval(function () {
        paidTries++;
        loadAll().then(function () {
          var unlocked = state.images.some(function (i) { return i.is_final && i.payment_status === 'unlocked'; });
          if (unlocked) {
            clearInterval(paidTimer);
            toast('Payment confirmed — your download is unlocked!');
          } else if (paidTries >= 15) {
            clearInterval(paidTimer);
            toast('Payment is still being confirmed — this page will keep checking.');
          }
        });
      }, 2000);
    }

    loadAll();
  })();
  </script>
</body>
</html>

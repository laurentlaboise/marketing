<%- include('../../partials/head', { title, bodyClass: 'dashboard-layout' }) %>

<%- include('../../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Articles</h1>
        <p class="page-subtitle">Manage your blog articles</p>
      </div>
      <div class="page-actions">
        <button type="button" class="btn btn-secondary" id="interlinkAllBtn" title="Cross-link the WHOLE content library: articles, glossary definitions, SEO terms, guides and products all link to each other (first mentions, capped, idempotent, never re-opens paid translations)">
          <i class="fas fa-link"></i> Link the Whole Library
        </button>
        <a href="/content/articles/new" class="btn btn-primary">
          <i class="fas fa-plus"></i> New Article
        </a>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <form action="/content/articles" method="GET" class="filter-form">
          <input type="text" name="search" class="form-input filter-input" placeholder="Search articles..." value="<%= pagination.search || '' %>">
          <select name="status" class="form-input filter-select">
            <option value="">All Status</option>
            <option value="draft" <%= pagination.status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="published" <%= pagination.status === 'published' ? 'selected' : '' %>>Published</option>
          </select>
          <select name="category" class="form-input filter-select">
            <option value="">All Categories</option>
            <option value="Digital Marketing" <%= pagination.category === 'Digital Marketing' ? 'selected' : '' %>>Digital Marketing</option>
            <option value="SEO" <%= pagination.category === 'SEO' ? 'selected' : '' %>>SEO</option>
            <option value="AI & Automation" <%= pagination.category === 'AI & Automation' ? 'selected' : '' %>>AI & Automation</option>
            <option value="Content Strategy" <%= pagination.category === 'Content Strategy' ? 'selected' : '' %>>Content Strategy</option>
            <option value="Business Growth" <%= pagination.category === 'Business Growth' ? 'selected' : '' %>>Business Growth</option>
            <option value="Social Media Marketing" <%= pagination.category === 'Social Media Marketing' ? 'selected' : '' %>>Social Media Marketing</option>
          </select>
          <button type="submit" class="btn btn-secondary btn-sm">
            <i class="fas fa-search"></i> Search
          </button>
        </form>
      </div>
      <div class="card-body" style="padding: 0;">
        <% if (articles.length > 0) { %>
        <div class="table-container">
          <table class="table table-responsive-cards">
            <thead>
              <tr>
                <th>Article</th>
                <th>Category</th>
                <th>Words</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% articles.forEach(article => { %>
              <tr>
                <td data-label="Article">
                  <div style="display: flex; align-items: flex-start; gap: 10px;">
                    <% if (article.featured_image) { %>
                    <img src="<%= article.featured_image %>" alt="" style="width: 48px; height: 48px; border-radius: 6px; object-fit: cover; flex-shrink: 0;" onerror="this.style.display='none'">
                    <% } %>
                    <div style="min-width: 0;">
                      <strong style="display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 320px;"><%= article.title %></strong>
                      <% if (article.excerpt) { %>
                      <small style="color: var(--gray-500); display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; font-size: 12px;"><%= article.excerpt.substring(0, 100) %></small>
                      <% } %>
                      <div style="display: flex; align-items: center; gap: 6px; margin-top: 2px;">
                        <small style="color: var(--gray-400); font-size: 11px;">/<%= article.slug %></small>
                        <% if (article.featured) { %>
                        <span style="background: #fef3c7; color: #92400e; font-size: 10px; padding: 1px 6px; border-radius: 4px; font-weight: 600;"><i class="fas fa-star" style="font-size: 8px;"></i> Featured</span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                </td>
                <td data-label="Category">
                  <% if (article.category) { %>
                  <span style="background: var(--gray-100); color: var(--gray-700); font-size: 12px; padding: 2px 8px; border-radius: 4px; white-space: nowrap;"><%= article.category %></span>
                  <% } else { %>
                  <span style="color: var(--gray-400);">—</span>
                  <% } %>
                </td>
                <td data-label="Words">
                  <% if (article.word_count) { %>
                  <span style="font-size: 13px; color: <%= article.word_count >= 1000 ? '#059669' : article.word_count >= 500 ? '#d97706' : '#dc2626' %>;"><%= article.word_count.toLocaleString() %></span>
                  <% } else { %>
                  <span style="color: var(--gray-400);">—</span>
                  <% } %>
                </td>
                <td data-label="Status">
                  <span class="status-badge <%= article.status %>"><%= article.status %></span>
                </td>
                <td data-label="Created"><%= new Date(article.created_at).toLocaleDateString() %></td>
                <td data-label="Actions">
                  <div class="table-actions">
                    <a href="/content/articles/<%= article.id %>/edit" class="btn btn-sm btn-secondary" title="Edit">
                      <i class="fas fa-edit"></i>
                    </a>
                    <button type="button" class="btn btn-sm btn-secondary interlink-btn" data-id="<%= article.id %>" title="Link glossary/SEO terms, other articles and site pages in this article">
                      <i class="fas fa-link"></i>
                    </button>
                    <form action="/content/articles/<%= article.id %>/delete" method="POST" style="display: inline;">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-sm btn-danger" title="Delete" data-confirm-delete="Are you sure you want to delete this article?">
                        <i class="fas fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <% if (pagination.totalPages > 1) { %>
        <div class="card-footer">
          <div class="pagination">
            <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %>&search=<%= pagination.search || '' %>&status=<%= pagination.status || '' %>&category=<%= pagination.category || '' %>" class="pagination-btn">
              <i class="fas fa-chevron-left"></i>
            </a>
            <% } %>

            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <a href="?page=<%= i %>&search=<%= pagination.search || '' %>&status=<%= pagination.status || '' %>&category=<%= pagination.category || '' %>" class="pagination-btn <%= i === pagination.page ? 'active' : '' %>">
              <%= i %>
            </a>
            <% } %>

            <% if (pagination.page < pagination.totalPages) { %>
            <a href="?page=<%= pagination.page + 1 %>&search=<%= pagination.search || '' %>&status=<%= pagination.status || '' %>&category=<%= pagination.category || '' %>" class="pagination-btn">
              <i class="fas fa-chevron-right"></i>
            </a>
            <% } %>
          </div>
        </div>
        <% } %>
        <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="fas fa-newspaper"></i>
          </div>
          <h3>No Articles Found</h3>
          <p>Get started by creating your first article.</p>
          <a href="/content/articles/new" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create Article
          </a>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<script nonce="<%= cspNonce %>">
(function () {
  var csrf = document.querySelector('meta[name="csrf-token"]').content;
  function post(url) {
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
      body: '{}'
    }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); });
  }

  document.querySelectorAll('.interlink-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      btn.disabled = true;
      post('/content/articles/' + btn.dataset.id + '/interlink').then(function (res) {
        btn.disabled = false;
        if (!res.ok) return alert(res.data.error || 'Linking failed');
        alert(res.data.count > 0
          ? 'Linked ' + res.data.count + ' term(s): ' + res.data.linked.map(function (l) { return l.term; }).join(', ')
          : 'No new linkable mentions found (already linked mentions are left alone).');
      }).catch(function (e) {
        btn.disabled = false;
        alert('Linking failed: ' + (e && e.message ? e.message : 'network error'));
      });
    });
  });

  var allBtn = document.getElementById('interlinkAllBtn');
  if (allBtn) allBtn.addEventListener('click', function () {
    if (!confirm('Cross-link the WHOLE library? Articles, glossary definitions, SEO terms, guides and products all get first-mention links to each other. Capped per record, safe to re-run, never re-opens paid translations.')) return;
    allBtn.disabled = true;
    allBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Linking\u2026';
    post('/content/interlink-library').then(function (res) {
      allBtn.disabled = false;
      allBtn.innerHTML = '<i class="fas fa-link"></i> Link the Whole Library';
      if (!res.ok) return alert(res.data.error || 'Library linking failed');
      var lines = Object.keys(res.data.byType).map(function (t) {
        var s2 = res.data.byType[t];
        return '  ' + t + ': ' + s2.links + ' link(s) in ' + s2.updated + ' of ' + s2.records;
      });
      alert('Library cross-linked: ' + res.data.totals.links + ' link(s) across ' + res.data.totals.updated + ' record(s).\n\n' + lines.join('\n'));
    }).catch(function (e) {
      allBtn.disabled = false;
      allBtn.innerHTML = '<i class="fas fa-link"></i> Link the Whole Library';
      alert('Library linking failed: ' + (e && e.message ? e.message : 'network error'));
    });
  });
})();
</script>

<%- include('../../partials/footer') %>

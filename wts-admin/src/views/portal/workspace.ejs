<%- include('partials/head') %>
  <style>
    .scope-list { margin: 0; padding-left: 1.15rem; color: var(--wts-text-2); font-size: 0.9rem; line-height: 1.6; }
    .scope-list li { margin-bottom: 0.3rem; }
    .scope-note { margin: 0.85rem 0 0; font-size: 0.85rem; color: var(--wts-muted); line-height: 1.5; }
    .row { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.9rem; }
    .row:last-child { border-bottom: none; }
    .row .meta { color: var(--wts-muted); font-size: 0.8rem; margin-top: 0.25rem; }
    .row a.get { color: var(--wts-magenta); font-weight: 700; text-decoration: none; white-space: nowrap; }
    .btn-done { background: #fff; border: 1.5px solid var(--wts-magenta); color: var(--wts-magenta); border-radius: 999px; padding: 0.4rem 0.9rem; font-size: 0.8rem; font-weight: 700; cursor: pointer; font-family: inherit; white-space: nowrap; }
    .btn-done:hover { background: var(--wts-magenta); color: #fff; }
    .card p.lead { color: var(--wts-text-3); font-size: 0.92rem; line-height: 1.55; margin: 0 0 0.75rem; }
  </style>
</head>
<body class="portal-app">
  <%- include('partials/topbar') %>
  <div class="app-shell">
    <%- include('partials/nav', { active: 'workspace' }) %>
    <main class="main">
      <div class="main-inner">
        <div class="page-head">
          <p class="page-kicker"><%= t('workspace.kicker') %></p>
          <h1><%= t('workspace.heading') %></h1>
          <p class="sub"><%= t('workspace.intro') %></p>
        </div>

        <% if (typeof markedDone !== 'undefined' && markedDone) { %>
        <div class="sent-note"><%= t('workspace.markedDone') %></div>
        <% } %>

        <div class="card">
          <h2><span class="sec-ico" aria-hidden="true">◎</span><%= t('workspace.scopeTitle') %></h2>
          <p class="lead"><%= t('workspace.scopeLead') %></p>
          <% if (scopeHints && scopeHints.length) { %>
          <ul class="scope-list">
            <% scopeHints.forEach(function (h) { %><li><%= h %></li><% }); %>
          </ul>
          <% } else { %>
          <ul class="scope-list">
            <li><%= t('workspace.scopeDefault1') %></li>
            <li><%= t('workspace.scopeDefault2') %></li>
            <li><%= t('workspace.scopeDefault3') %></li>
          </ul>
          <% } %>
          <p class="scope-note"><%= t('workspace.scopeNote') %></p>
        </div>

        <div class="grid-2">
          <div class="card">
            <h2><span class="sec-ico" aria-hidden="true">📄</span><%= t('workspace.reportsTitle') %></h2>
            <p class="lead"><%= t('workspace.reportsLead') %></p>
            <% if (reports && reports.length) { %>
              <% reports.forEach(function (f) { %>
              <div class="row">
                <div>
                  <strong><%= f.title %></strong>
                  <span class="badge report"><%= t('workspace.badgeReport') %></span>
                  <% if (f.description) { %><div class="meta"><%= f.description %></div><% } %>
                  <div class="meta"><%= new Date(f.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                </div>
                <% if (f.external_url) { %>
                  <a class="get" href="<%= f.external_url %>" rel="noopener" target="_blank"><%= t('common.open') %></a>
                <% } else { %>
                  <a class="get" href="/portal/files/<%= f.id %>/download"><%= t('common.download') %></a>
                <% } %>
              </div>
              <% }); %>
            <% } else { %>
              <div class="empty-state" style="box-shadow:none;border-style:dashed;">
                <div class="empty-ico" aria-hidden="true">📊</div>
                <p class="lead-empty"><%= t('workspace.reportsEmptyTitle') %></p>
                <p><%= t('workspace.reportsEmptyBody') %></p>
                <a class="cta" href="/portal/chat"><%= t('workspace.reportsEmptyCta') %></a>
              </div>
            <% } %>
          </div>

          <div class="card">
            <h2><span class="sec-ico" aria-hidden="true">✓</span><%= t('workspace.actionsTitle') %></h2>
            <p class="lead"><%= t('workspace.actionsLead') %></p>
            <% if (actions && actions.length) { %>
              <% actions.forEach(function (a) { %>
              <div class="row">
                <div>
                  <strong><%= a.title %></strong>
                  <span class="badge <%= a.status === 'done' ? 'done' : 'open' %>"><%= a.status === 'done' ? t('workspace.statusDone') : t('workspace.statusOpen') %></span>
                  <% if (a.notes) { %><div class="meta"><%= a.notes %></div><% } %>
                  <div class="meta">
                    <% if (a.due_date) { %><%= t('workspace.due') %>: <%= new Date(a.due_date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %> · <% } %>
                    <%= new Date(a.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  </div>
                </div>
                <% if (a.status !== 'done') { %>
                <form method="POST" action="/portal/workspace/actions/<%= a.id %>/done">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn-done"><%= t('workspace.markDone') %></button>
                </form>
                <% } %>
              </div>
              <% }); %>
            <% } else { %>
              <div class="empty-state" style="box-shadow:none;border-style:dashed;">
                <div class="empty-ico" aria-hidden="true">✅</div>
                <p class="lead-empty"><%= t('workspace.actionsEmptyTitle') %></p>
                <p><%= t('workspace.actionsEmptyBody') %></p>
                <% if (typeof featureWhiteboard !== 'undefined' && featureWhiteboard) { %>
                <a class="cta" href="/portal/boards"><%= t('workspace.actionsEmptyCta') %></a>
                <% } %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>
  <%- include('partials/footer') %>

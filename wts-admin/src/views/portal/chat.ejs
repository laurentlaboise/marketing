<%- include('partials/head') %>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <style>
    .chat-hero {
      background: linear-gradient(135deg, #122a3f 0%, #1a1030 55%, #9d174d 120%);
      border-radius: var(--wts-radius);
      padding: 1.15rem 1.25rem;
      color: #fff;
      margin-bottom: 1rem;
      box-shadow: var(--wts-shadow);
    }
    .chat-hero h1 { color: #fff; margin: 0 0 0.3rem; font-size: clamp(1.3rem, 2.2vw, 1.6rem); }
    .chat-hero .page-kicker { color: #fbcfe8; }
    .chat-hero p.sub { color: #e2e8f0; margin: 0; max-width: 40rem; }
    .chat-wrap { flex: 1; display: flex; flex-direction: column; min-height: 0; }
    .chat-box {
      background: #fff;
      border: 1px solid var(--wts-border);
      border-radius: var(--wts-radius);
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: min(62vh, 640px);
      box-shadow: var(--wts-shadow);
      overflow: hidden;
    }
    .msgs { flex: 1; overflow-y: auto; padding: 1.15rem; display: flex; flex-direction: column; gap: 0.85rem; background: linear-gradient(180deg, #fafbfc, #fff); }
    .msg-row { display: flex; gap: 0.55rem; align-items: flex-end; max-width: 92%; }
    .msg-row.user { align-self: flex-end; flex-direction: row-reverse; }
    .msg-row.bot { align-self: flex-start; }
    .avatar {
      width: 2rem; height: 2rem; border-radius: 999px;
      background: linear-gradient(135deg, #d62b83, #9d174d);
      color: #fff; font-size: 0.75rem; font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .msg {
      border-radius: 16px;
      padding: 0.7rem 0.95rem;
      font-size: 0.92rem;
      line-height: 1.55;
      white-space: pre-wrap;
      word-wrap: break-word;
    }
    .msg.user { background: var(--wts-magenta); color: #fff; border-bottom-right-radius: 5px; }
    .msg.bot { background: #f1f5f9; color: var(--wts-text); border-bottom-left-radius: 5px; border: 1px solid #e8edf3; }
    .msg.bot.thinking { color: var(--wts-muted); font-style: italic; }
    .hello {
      color: var(--wts-text-3);
      font-size: 0.95rem;
      text-align: center;
      padding: 1.75rem 1rem 0.5rem;
      line-height: 1.6;
      max-width: 28rem;
      margin: 0 auto;
    }
    .suggest-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      justify-content: center;
      padding: 0.75rem 1rem 1.25rem;
    }
    .suggest-chips button {
      background: #fff;
      border: 1px solid #f9a8d4;
      color: var(--wts-magenta-dark);
      border-radius: 999px;
      padding: 0.45rem 0.9rem;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      line-height: 1.4;
      text-align: left;
      max-width: 100%;
      box-shadow: 0 2px 8px rgba(214,43,131,0.08);
    }
    .suggest-chips button:hover { background: var(--wts-magenta-soft); }
    .composer {
      border-top: 1px solid var(--wts-border);
      padding: 0.85rem;
      display: flex;
      gap: 0.6rem;
      background: #fff;
    }
    .composer textarea {
      flex: 1;
      border: 1px solid #cbd5e1;
      border-radius: 12px;
      padding: 0.7rem 0.9rem;
      font-family: inherit;
      font-size: 0.92rem;
      resize: none;
      min-height: 52px;
      line-height: 1.45;
    }
    .composer textarea:focus { outline: 2px solid var(--wts-magenta); border-color: transparent; }
    .composer button {
      background: var(--wts-magenta);
      border: none;
      color: #fff;
      border-radius: 12px;
      padding: 0 1.25rem;
      font-size: 0.92rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
    }
    .composer button:disabled { opacity: 0.5; cursor: default; }
    .offline {
      background: #fffbeb;
      border: 1px solid #fde68a;
      color: #92400e;
      border-radius: var(--wts-radius);
      padding: 1rem 1.15rem;
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .offline a { color: var(--wts-magenta); font-weight: 700; }
    .chat-note { text-align: center; color: var(--wts-muted); font-size: 0.8rem; padding: 0.85rem 0 0; line-height: 1.5; font-weight: 500; }
    .typing-dots span {
      display: inline-block;
      width: 6px; height: 6px;
      margin: 0 2px;
      border-radius: 50%;
      background: #94a3b8;
      animation: blink 1.2s infinite ease-in-out;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
    @keyframes blink { 0%, 80%, 100% { opacity: 0.3; } 40% { opacity: 1; } }
  </style>
</head>
<body class="portal-app">
  <%- include('partials/topbar') %>
  <div class="app-shell">
    <%- include('partials/nav', { active: 'chat' }) %>
    <main class="main">
      <div class="main-inner chat-wrap">
        <div class="chat-hero">
          <p class="page-kicker"><%= t('chat.kicker') %></p>
          <h1><%= t('chat.heading') %></h1>
          <p class="sub"><%= t('chat.subtitle') %></p>
        </div>

        <% if (!enabled) { %>
        <div class="offline">
          <%- t('chat.offlineNotice', { link: '<a href="/portal/">' + esc(t('chat.offlineNoticeLink')) + '</a>' }) %>
        </div>
        <% } else { %>
        <div class="chat-box">
          <div class="msgs" id="msgs">
            <% if (!history.length) { %>
            <div id="hello-block">
              <div class="hello" id="hello"><%= t('chat.greeting') %><br><%= t('chat.greetingTry') %></div>
              <div class="suggest-chips" id="suggest-chips">
                <button type="button" data-suggest="<%= t('chat.suggest1') %>"><%= t('chat.suggest1') %></button>
                <button type="button" data-suggest="<%= t('chat.suggest2') %>"><%= t('chat.suggest2') %></button>
                <button type="button" data-suggest="<%= t('chat.suggest3') %>"><%= t('chat.suggest3') %></button>
              </div>
            </div>
            <% } %>
            <% history.forEach(function (m) { %>
            <div class="msg-row <%= m.role === 'user' ? 'user' : 'bot' %>">
              <% if (m.role !== 'user') { %><div class="avatar" title="<%= t('chat.avatarLabel') %>" aria-hidden="true">AI</div><% } %>
              <div class="msg <%= m.role === 'user' ? 'user' : 'bot' %>"><%= m.content %></div>
            </div>
            <% }); %>
          </div>
          <form class="composer" id="composer">
            <textarea id="chat-input" maxlength="2000" placeholder="<%= t('chat.placeholder') %>" required></textarea>
            <button type="submit" id="chat-send"><%= t('chat.send') %></button>
          </form>
        </div>
        <script nonce="<%= cspNonce %>">
          (function () {
            var I18N = {
              thinking: <%- JSON.stringify(t('chat.thinking')) %>,
              errorGeneric: <%- JSON.stringify(t('chat.errorGeneric')) %>,
              errorConnection: <%- JSON.stringify(t('chat.errorConnection')) %>,
              avatar: <%- JSON.stringify(t('chat.avatarLabel')) %>
            };
            var msgs = document.getElementById('msgs');
            var form = document.getElementById('composer');
            var input = document.getElementById('chat-input');
            var send = document.getElementById('chat-send');
            var csrf = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

            function clearHello() {
              var hello = document.getElementById('hello-block');
              if (hello) hello.remove();
            }

            function add(role, text, thinking) {
              clearHello();
              var row = document.createElement('div');
              row.className = 'msg-row ' + role;
              if (role === 'bot') {
                var av = document.createElement('div');
                av.className = 'avatar';
                av.setAttribute('aria-hidden', 'true');
                av.title = I18N.avatar;
                av.textContent = 'AI';
                row.appendChild(av);
              }
              var d = document.createElement('div');
              d.className = 'msg ' + role + (thinking ? ' thinking' : '');
              if (thinking) {
                d.innerHTML = '<span class="typing-dots"><span></span><span></span><span></span></span> ' + I18N.thinking;
              } else {
                d.textContent = text;
              }
              row.appendChild(d);
              msgs.appendChild(row);
              msgs.scrollTop = msgs.scrollHeight;
              return d;
            }

            function sendMessage(text) {
              if (!text || send.disabled) return;
              add('user', text);
              input.value = '';
              send.disabled = true;
              var pending = add('bot', '', true);
              fetch('/portal/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
                credentials: 'same-origin',
                body: JSON.stringify({ message: text })
              })
                .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
                .then(function (res) {
                  pending.className = 'msg bot';
                  pending.textContent = res.ok && res.d.reply ? res.d.reply : (res.d.error || I18N.errorGeneric);
                })
                .catch(function () {
                  pending.className = 'msg bot';
                  pending.textContent = I18N.errorConnection;
                })
                .then(function () {
                  send.disabled = false;
                  msgs.scrollTop = msgs.scrollHeight;
                  input.focus();
                });
            }

            form.addEventListener('submit', function (e) {
              e.preventDefault();
              sendMessage(input.value.trim());
            });

            var chips = document.getElementById('suggest-chips');
            if (chips) {
              chips.querySelectorAll('button').forEach(function (b) {
                b.addEventListener('click', function () {
                  var s = b.getAttribute('data-suggest') || b.textContent;
                  sendMessage(s.trim());
                });
              });
            }

            input.addEventListener('keydown', function (e) {
              if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                form.dispatchEvent(new Event('submit', { cancelable: true }));
              }
            });
            msgs.scrollTop = msgs.scrollHeight;
          })();
        </script>
        <% } %>
        <div class="chat-note"><%= t('chat.footerNote') %></div>
      </div>
    </main>
  </div>
  <%- include('partials/footer') %>

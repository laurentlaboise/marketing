<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; }
    .topbar { background: #122a3f; padding: 0.9rem 1.25rem; display: flex; justify-content: space-between; align-items: center; }
    .topbar a.brand { color: #fff; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
    .topbar form button { background: none; border: 1px solid rgba(255,255,255,0.35); color: #e2e8f0; border-radius: 8px; padding: 0.35rem 0.9rem; font-size: 0.85rem; cursor: pointer; font-family: inherit; }
    .wrap { flex: 1; max-width: 760px; width: 100%; margin: 0 auto; padding: 1.5rem 1rem 2.5rem; display: flex; flex-direction: column; }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin: 0.5rem 0 0.15rem; }
    p.sub { color: #64748b; font-size: 0.9rem; margin-bottom: 1rem; }
    .nav-links { display: flex; gap: 1rem; margin: 0 0 1rem; font-size: 0.88rem; flex-wrap: wrap; }
    .nav-links a { color: #475569; text-decoration: none; font-weight: 600; }
    .nav-links a.active { color: #d62b83; }
    .chat-box { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; flex: 1; display: flex; flex-direction: column; min-height: 420px; }
    .msgs { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.7rem; }
    .msg { max-width: 85%; border-radius: 14px; padding: 0.6rem 0.9rem; font-size: 0.9rem; line-height: 1.55; white-space: pre-wrap; word-wrap: break-word; }
    .msg.user { align-self: flex-end; background: #d62b83; color: #fff; border-bottom-right-radius: 4px; }
    .msg.bot { align-self: flex-start; background: #f1f5f9; color: #1a1a2e; border-bottom-left-radius: 4px; }
    .msg.bot.thinking { color: #94a3b8; font-style: italic; }
    .hello { color: #64748b; font-size: 0.88rem; text-align: center; padding: 1.5rem 1rem; line-height: 1.6; }
    .composer { border-top: 1px solid #e2e8f0; padding: 0.75rem; display: flex; gap: 0.6rem; }
    .composer textarea { flex: 1; border: 1px solid #cbd5e1; border-radius: 10px; padding: 0.6rem 0.8rem; font-family: inherit; font-size: 0.9rem; resize: none; height: 48px; }
    .composer button { background: #d62b83; border: none; color: #fff; border-radius: 10px; padding: 0 1.2rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: inherit; }
    .composer button:disabled { opacity: 0.5; cursor: default; }
    .offline { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; border-radius: 14px; padding: 1rem 1.15rem; font-size: 0.9rem; line-height: 1.6; }
    .offline a { color: #d62b83; font-weight: 600; }
    .foot { text-align: center; color: #94a3b8; font-size: 0.78rem; padding: 1rem; }
  </style>
</head>
<body>
  <div class="topbar">
    <a class="brand" href="https://wordsthatsells.website">Words That Sells</a>
    <div style="display:flex;gap:0.5rem;align-items:center;">
      <a href="/portal/profile" style="background:none;border:1px solid rgba(255,255,255,0.35);color:#e2e8f0;border-radius:8px;padding:0.35rem 0.9rem;font-size:0.85rem;text-decoration:none;">My Profile</a>
      <form method="POST" action="/portal/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit">Sign out</button>
      </form>
    </div>
  </div>
  <div class="wrap">
    <h1>AI Marketing Strategist</h1>
    <p class="sub">Ask about your services, orders, or anything marketing — SEO, content, social, web.</p>

    <div class="nav-links">
      <a href="/portal/">Dashboard</a>
      <a href="/portal/files">Files</a>
      <a href="/portal/billing">Billing</a>
      <a href="/portal/chat" class="active">AI Strategist</a>
      <a href="/portal/profile">Profile</a>
    </div>

    <% if (!enabled) { %>
    <div class="offline">
      The AI Strategist isn't switched on yet — it's coming soon. In the meantime, use
      <a href="/portal/">the quick actions on your dashboard</a> and our team will get back to you by email within one business day.
    </div>
    <% } else { %>
    <div class="chat-box">
      <div class="msgs" id="msgs">
        <% if (!history.length) { %>
        <div class="hello" id="hello">Hi! I'm your marketing strategist. I can see your services, orders and files, and I know the Lao and Southeast Asian market.<br>Try: &ldquo;What should my next marketing step be?&rdquo; or &ldquo;Explain my last order.&rdquo;</div>
        <% } %>
        <% history.forEach(function (m) { %>
        <div class="msg <%= m.role === 'user' ? 'user' : 'bot' %>"><%= m.content %></div>
        <% }); %>
      </div>
      <form class="composer" id="composer">
        <textarea id="chat-input" maxlength="2000" placeholder="Type your question&hellip;" required></textarea>
        <button type="submit" id="chat-send">Send</button>
      </form>
    </div>
    <script nonce="<%= cspNonce %>">
      (function () {
        var msgs = document.getElementById('msgs');
        var form = document.getElementById('composer');
        var input = document.getElementById('chat-input');
        var send = document.getElementById('chat-send');
        var csrf = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

        function add(role, text) {
          var hello = document.getElementById('hello');
          if (hello) hello.remove();
          var d = document.createElement('div');
          d.className = 'msg ' + role;
          d.textContent = text;
          msgs.appendChild(d);
          msgs.scrollTop = msgs.scrollHeight;
          return d;
        }

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var text = input.value.trim();
          if (!text || send.disabled) return;
          add('user', text);
          input.value = '';
          send.disabled = true;
          var pending = add('bot', 'Thinking…');
          pending.className += ' thinking';
          fetch('/portal/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
            credentials: 'same-origin',
            body: JSON.stringify({ message: text })
          })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
            .then(function (res) {
              pending.className = 'msg bot';
              pending.textContent = res.ok && res.d.reply ? res.d.reply : (res.d.error || 'Something went wrong — please try again.');
            })
            .catch(function () {
              pending.className = 'msg bot';
              pending.textContent = 'Connection problem — please try again.';
            })
            .then(function () {
              send.disabled = false;
              msgs.scrollTop = msgs.scrollHeight;
              input.focus();
            });
        });

        input.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            form.dispatchEvent(new Event('submit', { cancelable: true }));
          }
        });
        msgs.scrollTop = msgs.scrollHeight;
      })();
    </script>
    <% } %>
  </div>
  <div class="foot">The strategist can see only your own account. For changes to orders or services, use your dashboard's quick actions.</div>
</body>
</html>

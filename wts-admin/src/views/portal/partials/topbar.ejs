<%# Portal topbar. Pass { minimal: true } on unauthenticated pages
    (login, error) to hide the profile link, sign-out, and menu toggle. %>
<% var isMinimal = typeof minimal !== 'undefined' && minimal; %>
<div class="topbar">
  <div class="topbar-left">
    <% if (!isMinimal) { %>
    <button type="button" class="menu-toggle" id="nav-toggle" aria-label="<%= t('nav.openMenu') %>" aria-controls="portal-sidebar" aria-expanded="false">☰</button>
    <% } %>
    <a class="brand" href="<%= isMinimal ? 'https://wordsthatsells.website' : '/portal/' %>">
      <img
        src="/images/logo-wordsthatsells-website.svg"
        alt="WordsThatSells.website"
        width="40"
        height="40"
        style="height:36px;width:auto;border-radius:8px;background:#fff;padding:2px;"
        onerror="this.onerror=null;this.src='/images/SEO_AI_Digital_Marketing_Agency_Laos_Thailand_Asia_logo_with-words_white_colour_SVG.svg'">
      <span class="brand-text"><%= t('common.brand') %></span>
    </a>
  </div>
  <div class="top-actions">
    <span class="lang-switch" role="group" aria-label="Language">
      <a href="?lang=en" class="<%= locale === 'en' ? 'active' : '' %>" hreflang="en">EN</a>
      <a href="?lang=th" lang="th" class="<%= locale === 'th' ? 'active' : '' %>" hreflang="th">ไทย</a>
    </span>
    <% if (!isMinimal) { %>
      <a class="pill" href="/portal/profile"><%= t('common.myProfile') %></a>
      <form method="POST" action="/portal/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit"><%= t('common.signOut') %></button>
      </form>
    <% } %>
  </div>
</div>
<% if (!isMinimal) { %>
<%# The global helmet CSP only executes inline scripts that carry the
    per-request nonce — without it this block is silently blocked and the
    hamburger does nothing (links/forms in the bar keep working). %>
<script nonce="<%= cspNonce %>">
  (function () {
    var btn = document.getElementById('nav-toggle');
    if (!btn) return;
    var bar = document.querySelector('.topbar');

    // Drawer and sticky-sidebar offsets read --topbar-h; keep it equal to the
    // bar's real height (it exceeds 56px whenever the top actions wrap).
    function syncTopbarHeight() {
      document.documentElement.style.setProperty('--topbar-h', bar.offsetHeight + 'px');
    }
    syncTopbarHeight();
    if (window.ResizeObserver) new ResizeObserver(syncTopbarHeight).observe(bar);
    else window.addEventListener('resize', syncTopbarHeight);

    function setOpen(open) {
      document.body.classList.toggle('nav-open', open);
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    }
    btn.addEventListener('click', function () {
      var open = !document.body.classList.contains('nav-open');
      setOpen(open);
      if (open) {
        var first = document.querySelector('.sidebar a.nav-item');
        if (first) first.focus({ preventScroll: true });
      }
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && document.body.classList.contains('nav-open')) {
        setOpen(false);
        btn.focus();
      }
    });
    document.addEventListener('click', function (e) {
      if (!document.body.classList.contains('nav-open')) return;
      var t = e.target;
      // Close on a tapped nav link (mobile) or on the backdrop — any click
      // that lands outside both the drawer and the topbar.
      if (t.closest && t.closest('.sidebar a.nav-item')) setOpen(false);
      else if (!t.closest || (!t.closest('.sidebar') && !t.closest('.topbar'))) setOpen(false);
    });
    // Crossing up into the sidebar breakpoint discards drawer state
    var mq = window.matchMedia('(min-width: 900px)');
    var onMq = function (e) { if (e.matches) setOpen(false); };
    if (mq.addEventListener) mq.addEventListener('change', onMq);
    else if (mq.addListener) mq.addListener(onMq);
  })();
</script>
<% } %>

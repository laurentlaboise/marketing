<%# Portal page footer; closes the document opened by partials/head.
    Pass { simpleFooter: true } for the brand-only help line (login, error).
    Authenticated app pages hide heavy legal entity/agree via CSS. %>
  <footer class="portal-legal-footer" role="contentinfo">
    <% if (!(typeof simpleFooter !== 'undefined' && simpleFooter)) { %>
    <div class="foot foot-help"><%= t('common.footerHelp') %></div>
    <% } else { %>
    <div class="foot foot-brand"><%= t('common.footerBrand') %></div>
    <% } %>
    <%# compact: links only — entity/tax line is for login; app pages hide it via CSS too %>
    <%- include('../../partials/legal-bar', { compact: true }) %>
    <% if (typeof simpleFooter !== 'undefined' && simpleFooter) { %>
    <p class="foot foot-agree"><%- t('common.footerLegalAgree') %></p>
    <% } %>
  </footer>
</body>
</html>

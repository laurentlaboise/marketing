<%# Shared portal head: opens the document and the shared base styles.
    Usage convention — the including view appends its own style block,
    then closes head and opens body itself:
      include partials/head -> page <style> -> </head><body> ->
      include partials/topbar -> page content -> include partials/footer
    (partials/footer closes body and html). %>
<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Noto+Sans+Thai:wght@400;600;700&display=swap">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', 'Noto Sans Thai', Arial, sans-serif; background: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; }
    .topbar { background: #122a3f; padding: 0.9rem 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; }
    .topbar a.brand { color: #fff; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
    .topbar .top-actions { display: flex; gap: 0.5rem; align-items: center; }
    .topbar .top-actions a.pill { background: none; border: 1px solid rgba(255,255,255,0.35); color: #e2e8f0; border-radius: 8px; padding: 0.35rem 0.9rem; font-size: 0.85rem; text-decoration: none; line-height: 1.45; }
    .topbar form button { background: none; border: 1px solid rgba(255,255,255,0.35); color: #e2e8f0; border-radius: 8px; padding: 0.35rem 0.9rem; font-size: 0.85rem; cursor: pointer; font-family: inherit; line-height: 1.45; }
    .lang-switch { font-size: 0.8rem; color: rgba(255,255,255,0.45); margin-right: 0.35rem; }
    .lang-switch a { color: rgba(255,255,255,0.75); text-decoration: none; padding: 0.15rem 0.3rem; }
    .lang-switch a.active { color: #fff; font-weight: 700; }
    .nav-links { display: flex; gap: 1rem; margin: 0 0 1rem; font-size: 0.88rem; flex-wrap: wrap; }
    .nav-links a { color: #475569; text-decoration: none; font-weight: 600; }
    .nav-links a.active { color: #d62b83; }
    .foot { text-align: center; color: #94a3b8; font-size: 0.78rem; padding: 0.35rem 1rem; line-height: 1.5; }
    .portal-legal-footer { margin-top: auto; padding: 1rem 1rem 1.25rem; border-top: 1px solid #e2e8f0; background: #f8fafc; }
    .wts-legal-bar { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 0.35rem 0.15rem; font-size: 0.8rem; margin: 0.5rem 0 0.35rem; }
    .wts-legal-bar a { color: #475569; text-decoration: none; font-weight: 600; padding: 0.15rem 0.4rem; }
    .wts-legal-bar a:hover { color: #d62b83; text-decoration: underline; }
    .wts-legal-sep { color: #cbd5e1; padding: 0 0.15rem; }
    .wts-legal-entity { text-align: center; color: #94a3b8; font-size: 0.72rem; line-height: 1.45; margin: 0.15rem 0 0; }
    .foot-agree { margin-top: 0.45rem; font-size: 0.75rem; color: #64748b; }
    .foot-agree a { color: #d62b83; font-weight: 600; text-decoration: none; }
    .foot-agree a:hover { text-decoration: underline; }
    .login-legal-note { margin-top: 1rem; font-size: 0.78rem; color: #64748b; line-height: 1.5; text-align: center; }
    .login-legal-note a { color: #d62b83; font-weight: 600; text-decoration: none; }
    .login-legal-note a:hover { text-decoration: underline; }
  </style>

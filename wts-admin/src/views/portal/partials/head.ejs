<%# Shared portal head: opens the document and the shared base styles.
    Usage convention — the including view appends its own style block,
    then closes head and opens body itself:
      include partials/head -> page <style> -> </head><body> ->
      include partials/topbar -> page content -> include partials/footer
    (partials/footer closes body and html). %>
<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="theme-color" content="#122a3f">
  <link rel="icon" href="/favicon/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Noto+Sans+Thai:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --wts-navy: #122a3f;
      --wts-navy-deep: #0b1a28;
      --wts-magenta: #d62b83;
      --wts-magenta-dark: #b91c6f;
      --wts-magenta-soft: #fdf2f8;
      --wts-canvas: #eef2f7;
      --wts-card: #ffffff;
      --wts-border: #e2e8f0;
      --wts-text: #0f172a;
      --wts-text-2: #334155;
      --wts-text-3: #475569;
      --wts-muted: #64748b;
      --wts-radius: 16px;
      --wts-radius-sm: 12px;
      --wts-shadow: 0 4px 18px rgba(15, 23, 42, 0.06);
      --wts-shadow-hover: 0 10px 28px rgba(15, 23, 42, 0.1);
      --wts-sidebar: 248px;
      --wts-font: 'Poppins', 'Noto Sans Thai', system-ui, sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--wts-font);
      background: var(--wts-canvas);
      color: var(--wts-text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--wts-magenta); }

    /* ── Top bar ── */
    .topbar {
      background: linear-gradient(105deg, #0f2740 0%, #122a3f 55%, #1a1030 100%);
      padding: 0.7rem 1.15rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      position: sticky;
      top: 0;
      z-index: 40;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .topbar-left { display: flex; align-items: center; gap: 0.65rem; min-width: 0; }
    .topbar a.brand {
      color: #fff;
      font-weight: 700;
      text-decoration: none;
      font-size: 1rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      white-space: nowrap;
    }
    .topbar a.brand img { height: 36px; width: auto; display: block; border-radius: 8px; background: #fff; padding: 2px; }
    .topbar a.brand .brand-text { font-size: 0.92rem; }
    .topbar .menu-toggle {
      display: none;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.22);
      color: #fff;
      border-radius: 10px;
      width: 2.75rem;
      height: 2.75rem;
      flex-shrink: 0; /* keep the 44px tap target when the bar gets tight */
      cursor: pointer;
      font-size: 1.15rem;
      line-height: 1;
      font-family: inherit;
    }
    .topbar .top-actions { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; justify-content: flex-end; }
    .topbar .top-actions a.pill {
      background: none;
      border: 1px solid rgba(255,255,255,0.28);
      color: #e2e8f0;
      border-radius: 999px;
      padding: 0.35rem 0.85rem;
      font-size: 0.82rem;
      text-decoration: none;
      line-height: 1.45;
      font-weight: 600;
    }
    .topbar .top-actions a.pill:hover { border-color: #f9a8d4; color: #fff; }
    .topbar form button {
      background: none;
      border: 1px solid rgba(255,255,255,0.28);
      color: #e2e8f0;
      border-radius: 999px;
      padding: 0.35rem 0.85rem;
      font-size: 0.82rem;
      cursor: pointer;
      font-family: inherit;
      line-height: 1.45;
      font-weight: 600;
    }
    .topbar form button:hover { border-color: #f9a8d4; color: #fff; }
    .lang-switch {
      display: inline-flex;
      align-items: center;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.18);
      border-radius: 999px;
      padding: 0.15rem;
      gap: 0;
    }
    .lang-switch a {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      padding: 0.28rem 0.65rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .lang-switch a.active {
      background: var(--wts-magenta);
      color: #fff;
      font-weight: 700;
    }

    /* ── App shell + sidebar ── */
    .app-shell {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr;
      min-height: 0;
      width: 100%;
    }
    @media (min-width: 900px) {
      .app-shell { grid-template-columns: var(--wts-sidebar) 1fr; }
    }
    .sidebar {
      background: #fff;
      border-right: 1px solid var(--wts-border);
      padding: 1rem 0.75rem 1.5rem;
      display: none;
      flex-direction: column;
      gap: 0.35rem;
    }
    /* --topbar-h is kept in sync with the real topbar height by the script in
       partials/topbar (the bar is taller than 56px when its actions wrap). */
    @media (min-width: 900px) {
      .sidebar {
        display: flex;
        position: sticky;
        top: var(--topbar-h, 56px);
        height: calc(100vh - var(--topbar-h, 56px));
        overflow-y: auto;
      }
    }
    /* Drawer mode only below the sidebar breakpoint, so a drawer left open
       across a resize can never leak fixed-positioning into the grid layout */
    @media (max-width: 899px) {
      .topbar .menu-toggle { display: inline-flex; align-items: center; justify-content: center; }
      body.nav-open { overflow: hidden; }
      body.nav-open .sidebar {
        display: flex;
        position: fixed;
        inset: var(--topbar-h, 56px) 0 0 0;
        z-index: 35;
        height: auto;
        max-width: min(300px, 88vw);
        box-shadow: 12px 0 40px rgba(15,23,42,0.18);
        overflow-y: auto;
        overscroll-behavior: contain;
        padding-bottom: calc(1.5rem + env(safe-area-inset-bottom));
      }
      body.nav-open::after {
        content: '';
        position: fixed;
        inset: var(--topbar-h, 56px) 0 0 0;
        background: rgba(15,23,42,0.35);
        z-index: 30;
      }
    }
    /* Compact app bar on phones: drop the wordmark and the My Profile pill
       (Profile stays reachable from the drawer) so the bar keeps one line */
    @media (max-width: 640px) {
      .topbar a.brand .brand-text { display: none; }
      .topbar .top-actions a.pill { display: none; }
    }
    .sidebar-group {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--wts-muted);
      padding: 0.85rem 0.75rem 0.35rem;
    }
    .sidebar a.nav-item {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.7rem 0.75rem; /* >=44px touch target with the 1px borders */
      border-radius: 12px;
      color: var(--wts-text-2);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      border: 1px solid transparent;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .sidebar a.nav-item:hover {
      background: var(--wts-magenta-soft);
      color: var(--wts-magenta-dark);
    }
    .sidebar a.nav-item.active {
      background: linear-gradient(135deg, rgba(214,43,131,0.12), rgba(214,43,131,0.06));
      color: var(--wts-magenta-dark);
      border-color: rgba(214,43,131,0.22);
      box-shadow: inset 3px 0 0 var(--wts-magenta);
    }
    .sidebar a.nav-item .ico {
      width: 1.35rem;
      height: 1.35rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: inherit;
    }
    .sidebar a.nav-item .ico svg { width: 1.15rem; height: 1.15rem; display: block; }
    .sidebar-foot {
      margin-top: auto;
      padding: 1rem 0.75rem 0.25rem;
      font-size: 0.75rem;
      color: var(--wts-muted);
      line-height: 1.45;
    }

    /* Legacy horizontal nav (hidden when sidebar present) */
    .nav-links { display: none; }

    /* ── Main content ── */
    .main {
      min-width: 0;
      display: flex;
      flex-direction: column;
    }
    .main-inner, .wrap {
      width: 100%;
      max-width: 1120px;
      margin: 0 auto;
      /* Do not flex-grow: that left a huge empty white void above the legal footer */
      padding: 1.5rem 1.25rem 2rem;
    }
    .page-head { margin-bottom: 1.25rem; }
    .page-kicker {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--wts-magenta);
      margin: 0 0 0.35rem;
    }
    h1, .page-title {
      font-size: clamp(1.4rem, 2.4vw, 1.75rem);
      color: var(--wts-text);
      margin: 0 0 0.35rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }
    p.sub, .page-sub {
      color: var(--wts-muted);
      font-size: 0.95rem;
      line-height: 1.55;
      margin: 0 0 0.25rem;
      max-width: 48rem;
    }

    /* ── Cards & grids ── */
    .card, .order, .file, .board {
      background: var(--wts-card);
      border: 1px solid var(--wts-border);
      border-radius: var(--wts-radius);
      box-shadow: var(--wts-shadow);
    }
    .card {
      padding: 1.2rem 1.3rem;
      margin-bottom: 1rem;
    }
    .card h2, .section-title {
      font-size: 1.05rem;
      color: var(--wts-text);
      margin: 0 0 0.55rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .card h2 .sec-ico, .section-title .sec-ico {
      width: 1.7rem; height: 1.7rem;
      border-radius: 9px;
      display: inline-flex; align-items: center; justify-content: center;
      background: var(--wts-magenta-soft);
      color: var(--wts-magenta);
      font-size: 0.95rem;
      flex-shrink: 0;
    }
    .card-clickable {
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .card-clickable:hover {
      transform: translateY(-2px);
      box-shadow: var(--wts-shadow-hover);
      border-color: #f9a8d4;
    }
    .grid-2 {
      display: grid;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    @media (min-width: 800px) {
      .grid-2 { grid-template-columns: 1fr 1fr; align-items: start; }
    }
    .grid-boards {
      display: grid;
      gap: 0.9rem;
      grid-template-columns: 1fr;
    }
    @media (min-width: 700px) {
      .grid-boards { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 1000px) {
      .grid-boards { grid-template-columns: repeat(3, 1fr); }
    }

    /* ── Stats ── */
    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }
    @media (min-width: 720px) {
      .stats { grid-template-columns: repeat(4, 1fr); }
    }
    .stat {
      background: var(--wts-card);
      border: 1px solid var(--wts-border);
      border-radius: var(--wts-radius);
      padding: 1rem 1.05rem;
      box-shadow: var(--wts-shadow);
      text-decoration: none;
      color: inherit;
      display: block;
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      min-height: 5.5rem;
    }
    a.stat:hover {
      transform: translateY(-2px);
      box-shadow: var(--wts-shadow-hover);
      border-color: #f9a8d4;
    }
    .stat .stat-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.45rem;
    }
    .stat .stat-ico {
      width: 2rem; height: 2rem;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #f1f5f9;
      color: var(--wts-navy);
      font-size: 1rem;
    }
    .stat .num {
      font-size: 1.65rem;
      font-weight: 800;
      color: var(--wts-text);
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .stat .lbl {
      font-size: 0.8rem;
      color: var(--wts-muted);
      margin-top: 0.2rem;
      line-height: 1.4;
      font-weight: 600;
    }
    .stat.warn {
      border-color: #fcd34d;
      background: linear-gradient(180deg, #fffbeb, #fff);
      box-shadow: 0 4px 18px rgba(245, 158, 11, 0.1);
    }
    .stat.warn .num { color: #b45309; }
    .stat.warn .stat-ico { background: #fef3c7; color: #b45309; }

    /* ── Empty states ── */
    .empty, .empty-state {
      background: var(--wts-card);
      border: 1px dashed #cbd5e1;
      border-radius: var(--wts-radius);
      padding: 2rem 1.25rem;
      text-align: center;
      color: var(--wts-muted);
      line-height: 1.5;
    }
    .empty-state {
      border-style: solid;
      border-color: var(--wts-border);
      box-shadow: var(--wts-shadow);
    }
    .empty-state .empty-ico {
      width: 3rem; height: 3rem;
      margin: 0 auto 0.75rem;
      border-radius: 14px;
      background: var(--wts-magenta-soft);
      color: var(--wts-magenta);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.35rem;
    }
    .empty-state p { margin: 0 0 0.4rem; color: var(--wts-text-3); font-size: 0.95rem; }
    .empty-state p.lead-empty { font-weight: 700; color: var(--wts-text); font-size: 1.02rem; }
    .empty-state a.cta {
      display: inline-block;
      margin-top: 0.85rem;
      background: var(--wts-magenta);
      color: #fff;
      text-decoration: none;
      border-radius: 999px;
      padding: 0.5rem 1.15rem;
      font-size: 0.88rem;
      font-weight: 700;
    }
    .empty-state a.cta:hover { background: var(--wts-magenta-dark); }

    /* ── Badges ── */
    .badge {
      display: inline-block;
      border-radius: 999px;
      padding: 0.15rem 0.65rem;
      font-size: 0.74rem;
      font-weight: 600;
      line-height: 1.45;
    }
    .badge.completed, .badge.done, .badge.approved, .badge.active { background: #dcfce7; color: #166534; }
    .badge.awaiting_payment, .badge.open, .badge.pending, .badge.awaiting_review { background: #fef3c7; color: #92400e; }
    .badge.expired, .badge.cancelled, .badge.rejected, .badge.needs_changes { background: #fee2e2; color: #991b1b; }
    .badge.report { background: #ede9fe; color: #5b21b6; }
    .badge.suspended { background: #e2e8f0; color: #475569; }

    /* ── Footer (app) — full-width strip under shell, not mid-page content ── */
    .foot {
      text-align: center;
      color: var(--wts-muted);
      font-size: 0.78rem;
      padding: 0;
      line-height: 1.5;
      margin: 0;
    }
    .portal-legal-footer {
      flex: 0 0 auto;
      width: 100%;
      margin-top: auto;
      padding: 1rem 1.25rem 1.15rem;
      border-top: 1px solid var(--wts-border);
      background: #f1f5f9;
      text-align: center;
    }
    /* Authenticated app: compact legal strip only (no entity wall of text) */
    body.portal-app .portal-legal-footer .wts-legal-entity,
    body.portal-app .portal-legal-footer .foot-agree { display: none !important; }
    body.portal-app .portal-legal-footer .foot-help {
      font-size: 0.8rem;
      color: var(--wts-muted);
      max-width: 40rem;
      margin: 0 auto 0.55rem;
      line-height: 1.45;
    }
    body.portal-app .portal-legal-footer .foot-help a {
      color: var(--wts-magenta);
      font-weight: 600;
      text-decoration: none;
    }
    body.portal-app .portal-legal-footer .foot-help a:hover { text-decoration: underline; }

    .wts-legal-bar {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 0.35rem 0.15rem;
      font-size: 0.8rem;
      margin: 0 auto;
      padding: 0;
      line-height: 1.4;
    }
    .wts-legal-bar a {
      color: var(--wts-text-2);
      text-decoration: none;
      font-weight: 600;
      padding: 0.3rem 0.65rem;
      border-radius: 999px;
      border: 1px solid transparent;
      line-height: 1.35;
      transition: color 0.15s, background 0.15s, border-color 0.15s;
    }
    .wts-legal-bar a:hover {
      color: var(--wts-magenta-dark);
      background: var(--wts-magenta-soft);
      border-color: #fbcfe8;
      text-decoration: none;
    }
    .wts-legal-sep {
      color: #cbd5e1;
      padding: 0 0.05rem;
      user-select: none;
      font-weight: 400;
    }
    .wts-legal-entity {
      text-align: center;
      color: var(--wts-muted);
      font-size: 0.72rem;
      line-height: 1.45;
      margin: 0.45rem 0 0;
    }
    .foot-agree {
      margin-top: 0.45rem;
      font-size: 0.75rem;
      color: var(--wts-muted);
      text-align: center;
    }
    .foot-agree a { color: var(--wts-magenta); font-weight: 600; text-decoration: none; }
    .foot-agree a:hover { text-decoration: underline; }
    .login-legal-note { margin-top: 1rem; font-size: 0.78rem; color: var(--wts-muted); line-height: 1.5; text-align: center; }
    .login-legal-note a { color: var(--wts-magenta); font-weight: 600; text-decoration: none; }

    /* ── Shared form bits ── */
    .sent-note {
      background: #dcfce7;
      border: 1px solid #bbf7d0;
      color: #166534;
      border-radius: var(--wts-radius-sm);
      padding: 0.75rem 1rem;
      margin-bottom: 1rem;
      font-size: 0.88rem;
      line-height: 1.45;
    }
    .btn-primary, button[type=submit].btn-primary {
      background: var(--wts-magenta);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 0.55rem 1.2rem;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      text-decoration: none;
      display: inline-block;
    }
    .btn-primary:hover { background: var(--wts-magenta-dark); }

    @media (prefers-reduced-motion: reduce) {
      .stat, .card-clickable, .sidebar a.nav-item { transition: none; }
    }
  </style>

<%# Portal sidebar nav. Pass { active: 'dashboard'|'workspace'|... }. %>
<%
  function ico(name) {
    // Minimal inline SVGs (currentColor) — no external icon pack needed
    var paths = {
      home: '<path d="M4 10.5L12 4l8 6.5V20a1 1 0 0 1-1 1h-5v-6H10v6H5a1 1 0 0 1-1-1v-9.5z" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>',
      work: '<rect x="3" y="7" width="18" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" fill="none" stroke="currentColor" stroke-width="1.75"/>',
      board: '<rect x="3" y="4" width="5" height="16" rx="1" fill="none" stroke="currentColor" stroke-width="1.75"/><rect x="10" y="4" width="5" height="11" rx="1" fill="none" stroke="currentColor" stroke-width="1.75"/><rect x="17" y="4" width="4" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.75"/>',
      file: '<path d="M7 3h7l5 5v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="M14 3v5h5" fill="none" stroke="currentColor" stroke-width="1.75"/>',
      spark: '<path d="M12 3l1.2 5.2L18 9.5l-4 3.1L15.2 18 12 14.9 8.8 18 10 12.6 6 9.5l4.8-1.3L12 3z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>',
      bill: '<rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="M3 10h18M8 15h4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>',
      partners: '<circle cx="9" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.75"/><circle cx="16" cy="9" r="2.5" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="M3.5 19c.6-3 2.8-4.5 5.5-4.5s4.9 1.5 5.5 4.5M14 14.5c2.2.2 4 1.4 4.8 3.5" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>',
      user: '<circle cx="12" cy="8" r="3.5" fill="none" stroke="currentColor" stroke-width="1.75"/><path d="M5 20c1.2-3.5 3.8-5 7-5s5.8 1.5 7 5" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>'
    };
    return '<svg viewBox="0 0 24 24" aria-hidden="true">' + (paths[name] || '') + '</svg>';
  }
%>
<aside class="sidebar" id="portal-sidebar" aria-label="<%= t('nav.menuLabel') %>">
  <div class="sidebar-group"><%= t('nav.groupWork') %></div>
  <a class="nav-item <%= active === 'dashboard' ? 'active' : '' %>" href="/portal/">
    <span class="ico"><%- ico('home') %></span><%= t('nav.dashboard') %>
  </a>
  <a class="nav-item <%= active === 'workspace' ? 'active' : '' %>" href="/portal/workspace">
    <span class="ico"><%- ico('work') %></span><%= t('nav.workspace') %>
  </a>
  <% if (typeof featureWhiteboard !== 'undefined' && featureWhiteboard) { %>
  <a class="nav-item <%= active === 'boards' ? 'active' : '' %>" href="/portal/boards">
    <span class="ico"><%- ico('board') %></span><%= t('nav.boards') %>
  </a>
  <% } %>
  <a class="nav-item <%= active === 'files' ? 'active' : '' %>" href="/portal/files">
    <span class="ico"><%- ico('file') %></span><%= t('nav.files') %>
  </a>
  <a class="nav-item <%= active === 'chat' ? 'active' : '' %>" href="/portal/chat">
    <span class="ico"><%- ico('spark') %></span><%= t('nav.chat') %>
  </a>

  <div class="sidebar-group"><%= t('nav.groupAccount') %></div>
  <a class="nav-item <%= active === 'billing' ? 'active' : '' %>" href="/portal/billing">
    <span class="ico"><%- ico('bill') %></span><%= t('nav.billing') %>
  </a>
  <a class="nav-item <%= active === 'programs' ? 'active' : '' %>" href="/portal/programs">
    <span class="ico"><%- ico('partners') %></span><%= t('nav.programs') %>
  </a>
  <a class="nav-item <%= active === 'profile' ? 'active' : '' %>" href="/portal/profile">
    <span class="ico"><%- ico('user') %></span><%= t('nav.profile') %>
  </a>

  <p class="sidebar-foot"><%= t('nav.sidebarFoot') %></p>
</aside>

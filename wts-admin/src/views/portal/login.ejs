<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; }
    .topbar { background: #122a3f; padding: 0.9rem 1.25rem; }
    .topbar a { color: #fff; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
    .wrap { flex: 1; display: flex; align-items: center; justify-content: center; padding: 1.5rem; }
    .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 2rem 1.75rem; max-width: 420px; width: 100%; box-shadow: 0 10px 30px rgba(15,23,42,0.06); }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin-bottom: 0.4rem; }
    p.sub { color: #64748b; font-size: 0.92rem; line-height: 1.55; margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.85rem; font-weight: 600; color: #334155; margin-bottom: 0.35rem; }
    input[type=email], input[type=password] { width: 100%; padding: 0.7rem 0.85rem; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 1rem; font-family: inherit; box-sizing: border-box; }
    input[type=email]:focus, input[type=password]:focus { outline: 2px solid #d62b83; border-color: transparent; }
    button { width: 100%; margin-top: 1rem; background: #d62b83; color: #fff; border: none; border-radius: 10px; padding: 0.8rem; font-size: 1rem; font-weight: 700; cursor: pointer; font-family: inherit; }
    button:hover { background: #b91c6f; }
    .notice { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; border-radius: 10px; padding: 0.8rem 1rem; font-size: 0.9rem; line-height: 1.5; }
    .error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; border-radius: 10px; padding: 0.8rem 1rem; font-size: 0.9rem; margin-bottom: 1rem; line-height: 1.5; }
    .hint { color: #94a3b8; font-size: 0.8rem; margin-top: 1rem; line-height: 1.5; }
    .foot { text-align: center; color: #94a3b8; font-size: 0.78rem; padding: 1rem; }
  </style>
</head>
<body>
  <div class="topbar"><a href="https://wordsthatsells.website">Words That Sells</a></div>
  <div class="wrap">
    <div class="card">
      <% if (typeof error !== 'undefined' && error) { %><div class="error"><%= error %></div><% } %>
      <% if (sent) { %>
        <h1>Check your email</h1>
        <p class="sub">If <strong><%= email %></strong> is a valid address, a sign-in link is on its way. It works once and expires in 15 minutes.</p>
        <div class="notice">Nothing arriving? Check your spam folder, or go back and try again.</div>
        <p class="hint"><a href="/portal/login" style="color:#d62b83;">← Use a different email</a></p>
      <% } else { %>
        <h1>Welcome back</h1>
        <p class="sub">Enter your email — and your password if you've set one in your profile.</p>
        <form method="POST" action="/portal/login">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" required maxlength="255" placeholder="you@example.com" autocomplete="email" autofocus <%= email ? 'value="' + email + '"' : '' %>>
          <label for="password" style="margin-top:0.85rem;">Password <span style="font-weight:400;color:#94a3b8;">(optional)</span></label>
          <input type="password" id="password" name="password" maxlength="200" placeholder="Leave empty for an email link" autocomplete="current-password">
          <p class="hint" style="margin-top:0.5rem;">Forgot your password? Leave the password empty and we'll email you a secure sign-in link — you can set a new password from your profile.</p>
          <button type="submit">Sign In</button>
        </form>
        <p class="hint">No account yet? Just enter your email — your account is created automatically. You stay signed in on this device for 30 days.</p>
      <% } %>
    </div>
  </div>
  <div class="foot">Words That Sells · wordsthatsells.website</div>
</body>
</html>

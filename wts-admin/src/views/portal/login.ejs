<%- include('partials/head') %>
  <style>
    .wrap { flex: 1; display: flex; align-items: center; justify-content: center; padding: 1.5rem; }
    .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 2rem 1.75rem; max-width: 420px; width: 100%; box-shadow: 0 10px 30px rgba(15,23,42,0.06); }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin-bottom: 0.4rem; }
    p.sub { color: #64748b; font-size: 0.92rem; line-height: 1.55; margin-bottom: 1.25rem; }
    label { display: block; font-size: 0.85rem; font-weight: 600; color: #334155; margin-bottom: 0.35rem; }
    input[type=email], input[type=password] { width: 100%; padding: 0.7rem 0.85rem; border: 1px solid #cbd5e1; border-radius: 10px; font-size: 1rem; font-family: inherit; box-sizing: border-box; }
    input[type=email]:focus, input[type=password]:focus { outline: 2px solid #d62b83; border-color: transparent; }
    button[type=submit] { width: 100%; margin-top: 1rem; background: #d62b83; color: #fff; border: none; border-radius: 10px; padding: 0.8rem; font-size: 1rem; font-weight: 700; cursor: pointer; font-family: inherit; }
    button[type=submit]:hover { background: #b91c6f; }
    .notice { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; border-radius: 10px; padding: 0.8rem 1rem; font-size: 0.9rem; line-height: 1.5; }
    .error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; border-radius: 10px; padding: 0.8rem 1rem; font-size: 0.9rem; margin-bottom: 1rem; line-height: 1.5; }
    .hint { color: #94a3b8; font-size: 0.8rem; margin-top: 1rem; line-height: 1.5; }
  </style>
</head>
<body>
  <%- include('partials/topbar', { minimal: true }) %>
  <div class="wrap">
    <div class="card">
      <% if (typeof error !== 'undefined' && error) { %><div class="error"><%= error %></div><% } %>
      <% if (sent) { %>
        <h1><%= t('login.checkEmailTitle') %></h1>
        <p class="sub"><%- t('login.checkEmailBody', { email: '<strong>' + esc(email) + '</strong>' }) %></p>
        <div class="notice"><%= t('login.spamNotice') %></div>
        <p class="hint"><a href="/portal/login" style="color:#d62b83;"><%= t('login.useDifferentEmail') %></a></p>
      <% } else { %>
        <h1><%= t('login.welcomeTitle') %></h1>
        <p class="sub"><%= t('login.welcomeSub') %></p>
        <form method="POST" action="/portal/login">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <label for="email"><%= t('login.emailLabel') %></label>
          <input type="email" id="email" name="email" required maxlength="255" placeholder="<%= t('login.emailPlaceholder') %>" autocomplete="email" autofocus <%= email ? 'value="' + email + '"' : '' %>>
          <label for="password" style="margin-top:0.85rem;"><%= t('login.passwordLabel') %> <span style="font-weight:400;color:#94a3b8;"><%= t('login.passwordOptional') %></span></label>
          <input type="password" id="password" name="password" maxlength="200" placeholder="<%= t('login.passwordPlaceholder') %>" autocomplete="current-password">
          <p class="hint" style="margin-top:0.5rem;"><%= t('login.forgotHint') %></p>
          <button type="submit"><%= t('login.signIn') %></button>
        </form>
        <p class="hint"><%= t('login.autoAccountHint') %></p>
        <p class="login-legal-note"><%- t('login.legalAgree') %></p>
      <% } %>
    </div>
  </div>
  <%- include('partials/footer', { simpleFooter: true }) %>

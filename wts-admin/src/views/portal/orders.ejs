<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; }
    .topbar { background: #122a3f; padding: 0.9rem 1.25rem; display: flex; justify-content: space-between; align-items: center; }
    .topbar a.brand { color: #fff; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
    .topbar form button { background: none; border: 1px solid rgba(255,255,255,0.35); color: #e2e8f0; border-radius: 8px; padding: 0.35rem 0.9rem; font-size: 0.85rem; cursor: pointer; font-family: inherit; }
    .wrap { flex: 1; max-width: 760px; width: 100%; margin: 0 auto; padding: 1.5rem 1rem 2.5rem; }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin: 0.5rem 0 0.15rem; }
    p.sub { color: #64748b; font-size: 0.9rem; margin-bottom: 1.25rem; }
    .order { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem 1.15rem; margin-bottom: 0.9rem; }
    .order-head { display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; }
    .order-head strong { color: #1a1a2e; font-size: 1rem; }
    .order-date { color: #94a3b8; font-size: 0.8rem; }
    .row { display: flex; justify-content: space-between; gap: 0.75rem; margin-top: 0.5rem; font-size: 0.9rem; flex-wrap: wrap; }
    .amount { font-weight: 700; color: #1a1a2e; }
    .lak { color: #c8102e; font-weight: 600; font-size: 0.85rem; }
    .badge { display: inline-block; border-radius: 999px; padding: 0.2rem 0.75rem; font-size: 0.78rem; font-weight: 600; }
    .badge.completed { background: #dcfce7; color: #166534; }
    .badge.awaiting_payment { background: #fef3c7; color: #92400e; }
    .badge.pending { background: #e2e8f0; color: #475569; }
    .badge.expired, .badge.cancelled { background: #fee2e2; color: #991b1b; }
    .method { font-size: 0.78rem; color: #64748b; }
    .method .bcel { font-weight: 800; color: #c8102e; border: 1.5px solid #c8102e; border-radius: 4px; padding: 0.05rem 0.3rem; font-size: 0.7rem; }
    .ref-box { background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 0.55rem 0.85rem; margin-top: 0.65rem; font-size: 0.82rem; color: #991b1b; }
    .ref-box code { font-weight: 700; color: #c8102e; font-size: 0.95rem; letter-spacing: 0.04em; }
    .dl { display: inline-block; margin-top: 0.65rem; background: #d62b83; color: #fff; text-decoration: none; border-radius: 8px; padding: 0.45rem 1rem; font-size: 0.85rem; font-weight: 600; }
    .pw-tip { display: flex; align-items: center; gap: 0.75rem; background: #fdf2f8; border: 1px solid #fbcfe8; border-radius: 14px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; font-size: 0.88rem; color: #831843; }
    .pw-tip span { flex: 1; line-height: 1.5; }
    .pw-tip a { color: #d62b83; font-weight: 600; text-decoration: none; white-space: nowrap; }
    .pw-tip button { background: none; border: none; color: #be185d; font-size: 1.1rem; line-height: 1; cursor: pointer; padding: 0.2rem; font-family: inherit; }
    .empty { background: #fff; border: 1px dashed #cbd5e1; border-radius: 14px; padding: 2.5rem 1rem; text-align: center; color: #64748b; }
    .empty a { color: #d62b83; font-weight: 600; }
    .foot { text-align: center; color: #94a3b8; font-size: 0.78rem; padding: 1rem; }
    .nav-links { display: flex; gap: 1rem; margin: 0 0 1rem; font-size: 0.88rem; }
    .nav-links a { color: #475569; text-decoration: none; font-weight: 600; }
    .nav-links a.active { color: #d62b83; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.6rem; margin-bottom: 1.25rem; }
    .stat { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 0.8rem 1rem; }
    .stat .num { font-size: 1.35rem; font-weight: 700; color: #1a1a2e; }
    .stat .lbl { font-size: 0.78rem; color: #64748b; margin-top: 0.1rem; }
    .stat.warn { border-color: #fde68a; background: #fffbeb; }
    .stat.warn .num { color: #92400e; }
    .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem 1.15rem; margin-bottom: 1.25rem; }
    .card h2 { font-size: 1.05rem; color: #1a1a2e; margin: 0 0 0.6rem; }
    .file-row { display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; padding: 0.5rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.88rem; }
    .file-row:last-of-type { border-bottom: none; }
    .file-row .fmeta { color: #94a3b8; font-size: 0.78rem; }
    .file-row a.get { color: #d62b83; font-weight: 600; text-decoration: none; white-space: nowrap; }
    .view-all { display: inline-block; margin-top: 0.5rem; font-size: 0.85rem; color: #d62b83; font-weight: 600; text-decoration: none; }
    .qa-btns { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .qa-btns button { background: #fff; border: 1.5px solid #d62b83; color: #d62b83; border-radius: 999px; padding: 0.5rem 1.1rem; font-size: 0.87rem; font-weight: 600; cursor: pointer; font-family: inherit; }
    .qa-btns button[aria-pressed="true"] { background: #d62b83; color: #fff; }
    #qa-form { margin-top: 0.85rem; }
    #qa-form textarea { width: 100%; border: 1px solid #cbd5e1; border-radius: 10px; padding: 0.65rem 0.8rem; font-family: inherit; font-size: 0.9rem; min-height: 96px; resize: vertical; }
    #qa-form button[type="submit"] { margin-top: 0.6rem; background: #d62b83; border: none; color: #fff; border-radius: 8px; padding: 0.55rem 1.3rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; font-family: inherit; }
    .sent-note { background: #dcfce7; border: 1px solid #bbf7d0; color: #166534; border-radius: 14px; padding: 0.75rem 1rem; margin-bottom: 1.25rem; font-size: 0.88rem; }
  </style>
</head>
<body>
  <div class="topbar">
    <a class="brand" href="https://wordsthatsells.website">Words That Sells</a>
    <div style="display:flex;gap:0.5rem;align-items:center;">
      <a href="/portal/profile" style="background:none;border:1px solid rgba(255,255,255,0.35);color:#e2e8f0;border-radius:8px;padding:0.35rem 0.9rem;font-size:0.85rem;text-decoration:none;">My Profile</a>
      <form method="POST" action="/portal/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit">Sign out</button>
      </form>
    </div>
  </div>
  <div class="wrap">
    <h1>My Account</h1>
    <p class="sub">Signed in as <strong><%= customer.email %></strong></p>

    <div class="nav-links">
      <a href="/portal/" class="active">Dashboard</a>
      <a href="/portal/files">Files</a>
      <a href="/portal/billing">Billing</a>
      <a href="/portal/chat">AI Strategist</a>
      <% if (typeof featureWhiteboard !== 'undefined' && featureWhiteboard) { %><a href="/portal/boards">Boards</a><% } %>
      <a href="/portal/profile">Profile</a>
    </div>

    <% if (typeof requestSent !== 'undefined' && requestSent) { %>
    <div class="sent-note">Thanks — your request is in. We'll get back to you by email, usually within one business day.</div>
    <% } %>

    <%
      var recent = (typeof recentFiles !== 'undefined' && recentFiles) ? recentFiles : [];
      var nFiles = (typeof fileCount !== 'undefined') ? fileCount : recent.length;
      var awaiting = orders.filter(function (o) { return o.status === 'awaiting_payment'; }).length;
      var savedList = (typeof savedServices !== 'undefined' && savedServices) ? savedServices : [];
      function fmtSize(b) {
        if (b == null) return '';
        if (b < 1024) return b + ' B';
        if (b < 1048576) return (b / 1024).toFixed(0) + ' KB';
        return (b / 1048576).toFixed(1) + ' MB';
      }
    %>
    <div class="stats">
      <div class="stat"><div class="num"><%= savedList.length %></div><div class="lbl">Active services</div></div>
      <div class="stat"><div class="num"><%= orders.length %></div><div class="lbl">Orders</div></div>
      <div class="stat"><div class="num"><%= nFiles %></div><div class="lbl">Files</div></div>
      <% if (awaiting > 0) { %>
      <div class="stat warn"><div class="num"><%= awaiting %></div><div class="lbl">Awaiting payment</div></div>
      <% } %>
    </div>

    <div class="card">
      <h2>Quick actions</h2>
      <div class="qa-btns">
        <button type="button" data-kind="content">Request new content</button>
        <button type="button" data-kind="question">Ask a question</button>
      </div>
      <form id="qa-form" method="POST" action="/portal/request" hidden>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="kind" id="qa-kind" value="">
        <textarea name="message" id="qa-message" maxlength="4000" required placeholder=""></textarea>
        <button type="submit">Send request</button>
      </form>
    </div>
    <script nonce="<%= cspNonce %>">
      (function () {
        var form = document.getElementById('qa-form');
        var kindInput = document.getElementById('qa-kind');
        var msg = document.getElementById('qa-message');
        var btns = document.querySelectorAll('.qa-btns button');
        var HINTS = {
          content: 'Tell us what you need — topic, audience, where it will be used, and any deadline.',
          question: 'Ask us anything about your services, orders, or marketing — we read every message.'
        };
        btns.forEach(function (b) {
          b.addEventListener('click', function () {
            var kind = b.getAttribute('data-kind');
            btns.forEach(function (o) { o.setAttribute('aria-pressed', o === b ? 'true' : 'false'); });
            kindInput.value = kind;
            msg.placeholder = HINTS[kind];
            form.hidden = false;
            msg.focus();
          });
        });
      })();
    </script>

    <div class="card">
      <h2>Your files</h2>
      <% if (recent.length === 0) { %>
        <p style="color:#64748b;font-size:0.88rem;">No files yet — your deliverables will appear here.</p>
      <% } else { %>
        <% recent.forEach(function (f) { %>
        <div class="file-row">
          <span>
            <strong style="color:#1a1a2e;"><%= f.title %></strong>
            <span class="fmeta"> · <%= new Date(f.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %><%= f.external_url ? ' · link' : (f.file_size != null ? ' · ' + fmtSize(f.file_size) : '') %></span>
          </span>
          <a class="get" href="/portal/files/<%= f.id %>/download"><%= f.external_url ? 'Open' : 'Download' %></a>
        </div>
        <% }); %>
        <a class="view-all" href="/portal/files">View all files &rarr;</a>
      <% } %>
    </div>

    <% if (typeof hasPassword !== 'undefined' && !hasPassword) { %>
    <div class="pw-tip" id="pw-tip" hidden>
      <span>Tip: Set a password for instant access next time — no email checking required. <a href="/portal/profile">Set password</a></span>
      <button type="button" id="pw-tip-dismiss" aria-label="Dismiss">&times;</button>
    </div>
    <script nonce="<%= cspNonce %>">
      (function () {
        var tip = document.getElementById('pw-tip');
        if (sessionStorage.getItem('wts-pw-nudge-dismissed') !== '1') tip.hidden = false;
        document.getElementById('pw-tip-dismiss').addEventListener('click', function () {
          tip.hidden = true;
          sessionStorage.setItem('wts-pw-nudge-dismissed', '1');
        });
      })();
    </script>
    <% } %>

    <% var saved = (typeof savedServices !== 'undefined' && savedServices) ? savedServices : []; %>
    <% if (saved.length > 0) { %>
    <h2 style="font-size:1.05rem;color:#1a1a2e;margin:0 0 0.6rem;">My Services plan</h2>
    <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:1.5rem;">
      <% saved.forEach((s) => { %>
      <a href="https://wordsthatsells.website/en/digital-marketing-services/<%= s.service_page %>/#wts-product-<%= s.slug %>"
         style="display:inline-flex;align-items:center;gap:0.4rem;background:#fff;border:1px solid #e2e8f0;border-radius:999px;padding:0.4rem 0.9rem;font-size:0.85rem;font-weight:600;color:#334155;text-decoration:none;">
        <span style="color:#d62b83;">&#9733;</span> <%= s.name %><%= s.billing_period ? ' · ' + s.billing_period : '' %>
      </a>
      <% }); %>
    </div>
    <% } %>

    <h2 style="font-size:1.05rem;color:#1a1a2e;margin:0 0 0.6rem;">My Orders</h2>

    <% if (orders.length === 0) { %>
      <div class="empty">
        <p style="margin-bottom:0.5rem;">No orders on this account yet.</p>
        <p style="font-size:0.85rem;">Orders placed with <strong><%= customer.email %></strong> appear here automatically — or <a href="https://wordsthatsells.website">browse our services</a> to get started.</p>
      </div>
    <% } %>

    <% orders.forEach((order) => {
      const meta = order.metadata || {};
      const isBcel = order.payment_method === 'bcel_qr';
      const statusLabel = order.status === 'awaiting_payment' ? 'Awaiting payment'
        : order.status.charAt(0).toUpperCase() + order.status.slice(1);
    %>
    <div class="order">
      <div class="order-head">
        <strong><%= order.product_name || 'Order' %></strong>
        <span class="order-date"><%= new Date(order.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
      </div>
      <div class="row">
        <span>
          <% if (order.amount != null) { %>
            <span class="amount"><%= parseFloat(order.amount).toFixed(2) %> <%= order.currency %></span>
          <% } %>
          <% if (meta.price_lak) { %>
            <span class="lak"><%= order.amount != null ? ' · ' : '' %><%= Math.round(meta.price_lak).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',') %> LAK</span>
          <% } %>
        </span>
        <span>
          <span class="method"><%- isBcel ? '<span class="bcel">BCEL OnePay</span>' : 'Card (Stripe)' %></span>
          &nbsp;<span class="badge <%= order.status %>"><%= statusLabel %></span>
        </span>
      </div>
      <% if (isBcel && order.status === 'awaiting_payment' && meta.reference) { %>
      <div class="ref-box">
        Waiting for your BCEL One transfer. Include reference <code><%= meta.reference %></code> in the payment note — we confirm within one business day of receiving it.
      </div>
      <% } %>
      <% if (order.status === 'completed' && order.download_url && (order.product_type === 'digital' || order.download_url)) { %>
      <a class="dl" href="<%= order.download_url %>" rel="noopener">Download your files</a>
      <% } %>
    </div>
    <% }); %>
  </div>
  <div class="foot">Need help with an order? Reply to any of our emails or use the contact form on wordsthatsells.website</div>
</body>
</html>

<%- include('partials/head') %>
  <style>
    .error-wrap { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2rem 1.25rem; }
    .error-card {
      background: #fff;
      border: 1px solid var(--wts-border);
      border-radius: var(--wts-radius);
      padding: 2rem 1.75rem;
      max-width: 420px;
      width: 100%;
      box-shadow: var(--wts-shadow);
      text-align: center;
    }
    .error-card h1 { font-size: 1.35rem; color: var(--wts-text); margin-bottom: 0.45rem; }
    .error-card p.sub { color: var(--wts-muted); font-size: 0.95rem; line-height: 1.55; margin-bottom: 1.25rem; }
    .error-card a.btn {
      display: inline-block;
      background: var(--wts-magenta);
      color: #fff;
      text-decoration: none;
      border-radius: 999px;
      padding: 0.7rem 1.4rem;
      font-size: 0.95rem;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <%- include('partials/topbar', { minimal: true }) %>
  <div class="error-wrap">
    <div class="error-card">
      <h1><%= title %></h1>
      <p class="sub"><%= message %></p>
      <a class="btn" href="/portal"><%= t('errors.backToPortal') %></a>
    </div>
  </div>
  <%- include('partials/footer', { simpleFooter: true }) %>

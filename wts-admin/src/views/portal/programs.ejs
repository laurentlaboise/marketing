<%- include('partials/head') %>
  <style>
    .card h2 { flex-wrap: wrap; }
    .card p.desc { color: var(--wts-text-3); font-size: 0.92rem; line-height: 1.55; margin: 0 0 0.35rem; }
    .card p.earn { color: #9d174d; font-size: 0.86rem; font-weight: 700; margin: 0 0 0.75rem; }
    .state-note { font-size: 0.88rem; color: var(--wts-muted); line-height: 1.5; margin: 0; font-weight: 500; }
    .admin-note { background: #f8fafc; border: 1px solid var(--wts-border); border-radius: 12px; padding: 0.65rem 0.85rem; font-size: 0.86rem; color: var(--wts-text-2); margin-top: 0.55rem; }
    label { display: block; font-size: 0.82rem; font-weight: 600; color: var(--wts-text-2); margin: 0.25rem 0 0.3rem; }
    textarea { width: 100%; padding: 0.65rem 0.8rem; border: 1px solid #cbd5e1; border-radius: 12px; font-size: 0.9rem; font-family: inherit; box-sizing: border-box; resize: vertical; }
    textarea:focus { outline: 2px solid var(--wts-magenta); border-color: transparent; }
    button { margin-top: 0.65rem; background: var(--wts-magenta); color: #fff; border: none; border-radius: 999px; padding: 0.55rem 1.35rem; font-size: 0.92rem; font-weight: 700; cursor: pointer; font-family: inherit; }
    button:hover { background: var(--wts-magenta-dark); }
    .programs-grid { display: grid; gap: 1rem; }
    @media (min-width: 800px) { .programs-grid { grid-template-columns: 1fr 1fr; } }
  </style>
</head>
<body class="portal-app">
  <%- include('partials/topbar') %>
  <div class="app-shell">
    <%- include('partials/nav', { active: 'programs' }) %>
    <main class="main">
      <div class="main-inner">
        <div class="page-head">
          <p class="page-kicker"><%= t('programs.kicker') %></p>
          <h1><%= t('programs.heading') %></h1>
          <p class="sub"><%= t('programs.intro') %></p>
        </div>

        <div class="programs-grid">
        <% programs.forEach(function (program) {
             var enr = byProgram[program];
             var status = enr ? enr.status : null; %>
          <div class="card">
            <h2>
              <%= t('programs.' + program + '.name') %>
              <% if (status) { %>
                <span class="badge <%= status %>"><%= t('programs.status' + status.charAt(0).toUpperCase() + status.slice(1)) %></span>
              <% } %>
            </h2>
            <p class="desc"><%= t('programs.' + program + '.desc') %></p>
            <p class="earn"><%= t('programs.' + program + '.earn') %></p>

            <% if (!status || status === 'rejected') { %>
              <% if (status === 'rejected') { %>
                <p class="state-note"><%= t('programs.rejectedBody') %></p>
                <% if (enr && enr.admin_note) { %>
                  <div class="admin-note"><strong><%= t('programs.adminNoteLabel') %>:</strong> <%= enr.admin_note %></div>
                <% } %>
              <% } %>
              <form method="POST" action="/portal/programs/enroll">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="program" value="<%= program %>">
                <label for="note-<%= program %>"><%= t('programs.noteLabel') %></label>
                <textarea id="note-<%= program %>" name="note" rows="2" maxlength="1000" placeholder="<%= t('programs.notePlaceholder') %>"><%= enr && enr.note ? enr.note : '' %></textarea>
                <button type="submit"><%= status === 'rejected' ? t('programs.reapply') : t('programs.apply') %></button>
              </form>
            <% } else if (status === 'pending') { %>
              <p class="state-note"><%= t('programs.pendingBody') %></p>
            <% } else if (status === 'active') { %>
              <p class="state-note"><%= t('programs.activeBody') %></p>
            <% } else if (status === 'suspended') { %>
              <p class="state-note"><%= t('programs.suspendedBody') %></p>
              <% if (enr && enr.admin_note) { %>
                <div class="admin-note"><strong><%= t('programs.adminNoteLabel') %>:</strong> <%= enr.admin_note %></div>
              <% } %>
            <% } %>
          </div>
        <% }); %>
        </div>
      </div>
    </main>
  </div>
  <%- include('partials/footer', { simpleFooter: true }) %>

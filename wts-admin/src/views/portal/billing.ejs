<%- include('partials/head') %>
  <style>
    .wrap { flex: 1; max-width: 760px; width: 100%; margin: 0 auto; padding: 1.5rem 1rem 2.5rem; }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin: 0.5rem 0 0.15rem; }
    p.sub { color: #64748b; font-size: 0.9rem; margin-bottom: 1rem; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.6rem; margin-bottom: 1.25rem; }
    .stat { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 0.8rem 1rem; }
    .stat .num { font-size: 1.25rem; font-weight: 700; color: #1a1a2e; }
    .stat .lbl { font-size: 0.78rem; color: #64748b; margin-top: 0.1rem; }
    .stat.warn { border-color: #fde68a; background: #fffbeb; }
    .stat.warn .num { color: #92400e; }
    .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem 1.15rem; margin-bottom: 1.25rem; }
    .card h2 { font-size: 1.05rem; color: #1a1a2e; margin: 0 0 0.6rem; }
    .pay-row { display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; padding: 0.6rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.88rem; flex-wrap: wrap; }
    .pay-row:last-of-type { border-bottom: none; }
    .pay-row .when { color: #94a3b8; font-size: 0.78rem; }
    .pay-row .amt { font-weight: 700; color: #1a1a2e; white-space: nowrap; }
    .badge { display: inline-block; border-radius: 999px; padding: 0.15rem 0.65rem; font-size: 0.74rem; font-weight: 600; line-height: 1.45; }
    .badge.completed { background: #dcfce7; color: #166534; }
    .badge.awaiting_payment { background: #fef3c7; color: #92400e; }
    .badge.pending { background: #e2e8f0; color: #475569; }
    .badge.expired, .badge.cancelled { background: #fee2e2; color: #991b1b; }
    .method { font-size: 0.74rem; color: #64748b; }
    .method .bcel { font-weight: 800; color: #c8102e; border: 1.5px solid #c8102e; border-radius: 4px; padding: 0.05rem 0.3rem; font-size: 0.66rem; line-height: 1.45; }
    .sub-chip { display: inline-flex; align-items: center; gap: 0.4rem; background: #fdf2f8; border: 1px solid #fbcfe8; border-radius: 999px; padding: 0.4rem 0.9rem; font-size: 0.85rem; font-weight: 600; color: #9d174d; margin: 0 0.4rem 0.4rem 0; line-height: 1.45; }
    .note { color: #64748b; font-size: 0.82rem; line-height: 1.5; }
    .note a { color: #d62b83; font-weight: 600; text-decoration: none; }
    .empty { background: #fff; border: 1px dashed #cbd5e1; border-radius: 14px; padding: 2.5rem 1rem; text-align: center; color: #64748b; }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>
  <div class="wrap">
    <h1><%= t('billing.heading') %></h1>
    <p class="sub"><%= t('billing.subtitle') %></p>

    <%- include('partials/nav', { active: 'billing' }) %>

    <% var totalKeys = Object.keys(totals); %>
    <div class="stats">
      <% if (totalKeys.length === 0) { %>
      <div class="stat"><div class="num"><%= fmtMoney(0, 'USD') %></div><div class="lbl"><%= t('billing.totalPaid') %></div></div>
      <% } else { totalKeys.forEach(function (cur) { %>
      <div class="stat"><div class="num"><%= fmtMoney(totals[cur], cur) %></div><div class="lbl"><%= t('billing.totalPaid') %></div></div>
      <% }); } %>
      <div class="stat"><div class="num"><%= orders.length %></div><div class="lbl"><%= t('billing.paymentsOrders') %></div></div>
      <% if (awaitingCount > 0) { %>
      <div class="stat warn"><div class="num"><%= awaitingCount %></div><div class="lbl"><%= t('billing.awaitingTransfer') %></div></div>
      <% } %>
    </div>

    <% if (subscriptions.length > 0) { %>
    <div class="card">
      <h2><%= t('billing.activeSubscriptions') %></h2>
      <div>
        <% subscriptions.forEach(function (s) { const m = s.metadata || {}; %>
        <span class="sub-chip"><span style="color:#d62b83;">&#8635;</span> <%= s.product_name || t('billing.subscriptionFallback') %><%= m.billing_period ? ' · ' + m.billing_period : '' %></span>
        <% }); %>
      </div>
      <p class="note" style="margin-top:0.6rem;"><%- t('billing.cancelNote', { link: '<a href="/portal/?sent=0#qa-form">' + esc(t('billing.cancelNoteLink')) + '</a>' }) %></p>
    </div>
    <% } %>

    <div class="card">
      <h2><%= t('billing.paymentHistory') %></h2>
      <% if (orders.length === 0) { %>
        <p class="note"><%= t('billing.historyEmpty') %></p>
      <% } %>
      <% orders.forEach(function (o) {
        const meta = o.metadata || {};
        const isBcel = o.payment_method === 'bcel_qr';
      %>
      <div class="pay-row">
        <span style="flex:1;min-width:160px;">
          <strong style="color:#1a1a2e;"><%= o.product_name || t('billing.orderFallback') %></strong><br>
          <span class="when"><%= fmtDate(o.created_at) %></span>
          <span class="method"> · <%- isBcel ? '<span class="bcel">' + esc(t('payment.bcel')) + '</span>' : esc(t('payment.card')) %></span>
          <% if (meta.reference) { %><span class="when"> · <%= t('billing.ref', { ref: meta.reference }) %></span><% } %>
        </span>
        <span style="text-align:right;">
          <span class="amt"><%= o.amount != null ? fmtMoney(o.amount, o.currency || 'USD') : '—' %></span>
          <% if (meta.price_lak) { %><br><span class="when" style="color:#c8102e;font-weight:600;"><%= fmtMoney(meta.price_lak, 'LAK') %></span><% } %>
          <br><span class="badge <%= o.status %>"><%= t('status.' + o.status) %></span>
        </span>
      </div>
      <% }); %>
    </div>

    <p class="note"><%- t('billing.invoiceNote', { link: '<a href="/portal/">' + esc(t('billing.invoiceNoteLink')) + '</a>' }) %></p>
  </div>
  <%- include('partials/footer') %>

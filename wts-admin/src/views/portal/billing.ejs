<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background: #f1f5f9; min-height: 100vh; display: flex; flex-direction: column; }
    .topbar { background: #122a3f; padding: 0.9rem 1.25rem; display: flex; justify-content: space-between; align-items: center; }
    .topbar a.brand { color: #fff; font-weight: 700; text-decoration: none; font-size: 1.05rem; }
    .topbar form button { background: none; border: 1px solid rgba(255,255,255,0.35); color: #e2e8f0; border-radius: 8px; padding: 0.35rem 0.9rem; font-size: 0.85rem; cursor: pointer; font-family: inherit; }
    .wrap { flex: 1; max-width: 760px; width: 100%; margin: 0 auto; padding: 1.5rem 1rem 2.5rem; }
    h1 { font-size: 1.35rem; color: #1a1a2e; margin: 0.5rem 0 0.15rem; }
    p.sub { color: #64748b; font-size: 0.9rem; margin-bottom: 1rem; }
    .nav-links { display: flex; gap: 1rem; margin: 0 0 1rem; font-size: 0.88rem; }
    .nav-links a { color: #475569; text-decoration: none; font-weight: 600; }
    .nav-links a.active { color: #d62b83; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.6rem; margin-bottom: 1.25rem; }
    .stat { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 0.8rem 1rem; }
    .stat .num { font-size: 1.25rem; font-weight: 700; color: #1a1a2e; }
    .stat .lbl { font-size: 0.78rem; color: #64748b; margin-top: 0.1rem; }
    .stat.warn { border-color: #fde68a; background: #fffbeb; }
    .stat.warn .num { color: #92400e; }
    .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem 1.15rem; margin-bottom: 1.25rem; }
    .card h2 { font-size: 1.05rem; color: #1a1a2e; margin: 0 0 0.6rem; }
    .pay-row { display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; padding: 0.6rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.88rem; flex-wrap: wrap; }
    .pay-row:last-of-type { border-bottom: none; }
    .pay-row .when { color: #94a3b8; font-size: 0.78rem; }
    .pay-row .amt { font-weight: 700; color: #1a1a2e; white-space: nowrap; }
    .badge { display: inline-block; border-radius: 999px; padding: 0.15rem 0.65rem; font-size: 0.74rem; font-weight: 600; }
    .badge.completed { background: #dcfce7; color: #166534; }
    .badge.awaiting_payment { background: #fef3c7; color: #92400e; }
    .badge.pending { background: #e2e8f0; color: #475569; }
    .badge.expired, .badge.cancelled { background: #fee2e2; color: #991b1b; }
    .method { font-size: 0.74rem; color: #64748b; }
    .method .bcel { font-weight: 800; color: #c8102e; border: 1.5px solid #c8102e; border-radius: 4px; padding: 0.05rem 0.3rem; font-size: 0.66rem; }
    .sub-chip { display: inline-flex; align-items: center; gap: 0.4rem; background: #fdf2f8; border: 1px solid #fbcfe8; border-radius: 999px; padding: 0.4rem 0.9rem; font-size: 0.85rem; font-weight: 600; color: #9d174d; margin: 0 0.4rem 0.4rem 0; }
    .note { color: #64748b; font-size: 0.82rem; line-height: 1.5; }
    .note a { color: #d62b83; font-weight: 600; text-decoration: none; }
    .empty { background: #fff; border: 1px dashed #cbd5e1; border-radius: 14px; padding: 2.5rem 1rem; text-align: center; color: #64748b; }
    .foot { text-align: center; color: #94a3b8; font-size: 0.78rem; padding: 1rem; }
  </style>
</head>
<body>
  <div class="topbar">
    <a class="brand" href="https://wordsthatsells.website">Words That Sells</a>
    <div style="display:flex;gap:0.5rem;align-items:center;">
      <a href="/portal/profile" style="background:none;border:1px solid rgba(255,255,255,0.35);color:#e2e8f0;border-radius:8px;padding:0.35rem 0.9rem;font-size:0.85rem;text-decoration:none;">My Profile</a>
      <form method="POST" action="/portal/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit">Sign out</button>
      </form>
    </div>
  </div>
  <div class="wrap">
    <h1>Billing</h1>
    <p class="sub">Your payments, pending transfers and subscriptions — all in one place.</p>

    <div class="nav-links">
      <a href="/portal/">Dashboard</a>
      <a href="/portal/files">Files</a>
      <a href="/portal/billing" class="active">Billing</a>
      <a href="/portal/chat">AI Strategist</a>
      <a href="/portal/profile">Profile</a>
    </div>

    <% var totalKeys = Object.keys(totals); %>
    <div class="stats">
      <% if (totalKeys.length === 0) { %>
      <div class="stat"><div class="num">0.00 USD</div><div class="lbl">Total paid</div></div>
      <% } else { totalKeys.forEach(function (cur) { %>
      <div class="stat"><div class="num"><%= totals[cur].toFixed(2) %> <%= cur %></div><div class="lbl">Total paid</div></div>
      <% }); } %>
      <div class="stat"><div class="num"><%= orders.length %></div><div class="lbl">Payments &amp; orders</div></div>
      <% if (awaitingCount > 0) { %>
      <div class="stat warn"><div class="num"><%= awaitingCount %></div><div class="lbl">Awaiting your transfer</div></div>
      <% } %>
    </div>

    <% if (subscriptions.length > 0) { %>
    <div class="card">
      <h2>Active subscriptions</h2>
      <div>
        <% subscriptions.forEach(function (s) { const m = s.metadata || {}; %>
        <span class="sub-chip"><span style="color:#d62b83;">&#8635;</span> <%= s.product_name || 'Subscription' %><%= m.billing_period ? ' · ' + m.billing_period : '' %></span>
        <% }); %>
      </div>
      <p class="note" style="margin-top:0.6rem;">To change or cancel a subscription, <a href="/portal/?sent=0#qa-form">send us a quick request</a> from your dashboard — we handle it the same business day.</p>
    </div>
    <% } %>

    <div class="card">
      <h2>Payment history</h2>
      <% if (orders.length === 0) { %>
        <p class="note">Nothing here yet. Orders placed with your email appear automatically.</p>
      <% } %>
      <% orders.forEach(function (o) {
        const meta = o.metadata || {};
        const isBcel = o.payment_method === 'bcel_qr';
        const label = o.status === 'awaiting_payment' ? 'Awaiting payment' : o.status.charAt(0).toUpperCase() + o.status.slice(1);
      %>
      <div class="pay-row">
        <span style="flex:1;min-width:160px;">
          <strong style="color:#1a1a2e;"><%= o.product_name || 'Order' %></strong><br>
          <span class="when"><%= new Date(o.created_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
          <span class="method"> · <%- isBcel ? '<span class="bcel">BCEL OnePay</span>' : 'Card (Stripe)' %></span>
          <% if (meta.reference) { %><span class="when"> · ref <%= meta.reference %></span><% } %>
        </span>
        <span style="text-align:right;">
          <span class="amt"><%= o.amount != null ? parseFloat(o.amount).toFixed(2) + ' ' + (o.currency || 'USD') : '—' %></span>
          <% if (meta.price_lak) { %><br><span class="when" style="color:#c8102e;font-weight:600;"><%= Math.round(meta.price_lak).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',') %> LAK</span><% } %>
          <br><span class="badge <%= o.status %>"><%= label %></span>
        </span>
      </div>
      <% }); %>
    </div>

    <p class="note">Need an invoice or receipt for any payment? <a href="/portal/">Ask us from your dashboard</a> and we'll email it over.</p>
  </div>
  <div class="foot">Questions about a charge? Reply to any of our emails or use the contact form on wordsthatsells.website</div>
</body>
</html>

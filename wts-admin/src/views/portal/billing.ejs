<%- include('partials/head') %>
  <style>
    .pay-row { display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; padding: 0.7rem 0; border-bottom: 1px solid #f1f5f9; font-size: 0.88rem; flex-wrap: wrap; }
    .pay-row:last-of-type { border-bottom: none; }
    .pay-row .when { color: var(--wts-muted); font-size: 0.8rem; font-weight: 600; }
    .pay-row .amt { font-weight: 800; color: var(--wts-text); white-space: nowrap; }
    .method { font-size: 0.74rem; color: var(--wts-muted); }
    .method .bcel { font-weight: 800; color: #c8102e; border: 1.5px solid #c8102e; border-radius: 4px; padding: 0.05rem 0.3rem; font-size: 0.66rem; line-height: 1.45; }
    .sub-chip { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--wts-magenta-soft); border: 1px solid #fbcfe8; border-radius: 999px; padding: 0.4rem 0.9rem; font-size: 0.85rem; font-weight: 600; color: #9d174d; margin: 0 0.4rem 0.4rem 0; line-height: 1.45; }
    .note { color: var(--wts-muted); font-size: 0.85rem; line-height: 1.5; }
    .note a { color: var(--wts-magenta); font-weight: 700; text-decoration: none; }
  </style>
</head>
<body class="portal-app">
  <%- include('partials/topbar') %>
  <div class="app-shell">
    <%- include('partials/nav', { active: 'billing' }) %>
    <main class="main">
      <div class="main-inner">
        <div class="page-head">
          <p class="page-kicker"><%= t('billing.kicker') %></p>
          <h1><%= t('billing.heading') %></h1>
          <p class="sub"><%= t('billing.subtitle') %></p>
        </div>

        <% var totalKeys = Object.keys(totals); %>
        <div class="stats">
          <% if (totalKeys.length === 0) { %>
          <div class="stat">
            <div class="stat-top"><span class="stat-ico" aria-hidden="true">$</span></div>
            <div class="num" style="font-size:1.25rem;"><%= fmtMoney(0, 'USD') %></div>
            <div class="lbl"><%= t('billing.totalPaid') %></div>
          </div>
          <% } else { totalKeys.forEach(function (cur) { %>
          <div class="stat">
            <div class="stat-top"><span class="stat-ico" aria-hidden="true">$</span></div>
            <div class="num" style="font-size:1.25rem;"><%= fmtMoney(totals[cur], cur) %></div>
            <div class="lbl"><%= t('billing.totalPaid') %></div>
          </div>
          <% }); } %>
          <div class="stat">
            <div class="stat-top"><span class="stat-ico" aria-hidden="true">🧾</span></div>
            <div class="num"><%= orders.length %></div>
            <div class="lbl"><%= t('billing.paymentsOrders') %></div>
          </div>
          <% if (awaitingCount > 0) { %>
          <div class="stat warn">
            <div class="stat-top"><span class="stat-ico" aria-hidden="true">⚠</span></div>
            <div class="num"><%= awaitingCount %></div>
            <div class="lbl"><%= t('billing.awaitingTransfer') %></div>
          </div>
          <% } %>
        </div>

        <% if (subscriptions.length > 0) { %>
        <div class="card">
          <h2><span class="sec-ico" aria-hidden="true">↻</span><%= t('billing.activeSubscriptions') %></h2>
          <div>
            <% subscriptions.forEach(function (s) { const m = s.metadata || {}; %>
            <span class="sub-chip"><span style="color:var(--wts-magenta);">↻</span> <%= s.product_name || t('billing.subscriptionFallback') %><%= m.billing_period ? ' · ' + m.billing_period : '' %></span>
            <% }); %>
          </div>
          <p class="note" style="margin-top:0.6rem;"><%- t('billing.cancelNote', { link: '<a href="/portal/?sent=0#qa-form">' + esc(t('billing.cancelNoteLink')) + '</a>' }) %></p>
        </div>
        <% } %>

        <div class="card">
          <h2><span class="sec-ico" aria-hidden="true">💳</span><%= t('billing.paymentHistory') %></h2>
          <% if (orders.length === 0) { %>
            <div class="empty-state" style="box-shadow:none;border-style:dashed;">
              <p class="lead-empty"><%= t('billing.historyEmpty') %></p>
            </div>
          <% } %>
          <% orders.forEach(function (o) {
            const meta = o.metadata || {};
            const isBcel = o.payment_method === 'bcel_qr';
          %>
          <div class="pay-row">
            <span style="flex:1;min-width:160px;">
              <strong style="color:var(--wts-text);"><%= o.product_name || t('billing.orderFallback') %></strong><br>
              <span class="when"><%= fmtDate(o.created_at) %></span>
              <span class="method"> · <%- isBcel ? '<span class="bcel">' + esc(t('payment.bcel')) + '</span>' : esc(t('payment.card')) %></span>
              <% if (meta.reference) { %><span class="when"> · <%= t('billing.ref', { ref: meta.reference }) %></span><% } %>
            </span>
            <span style="text-align:right;">
              <span class="amt"><%= o.amount != null ? fmtMoney(o.amount, o.currency || 'USD') : '—' %></span>
              <% if (meta.price_lak) { %><br><span class="when" style="color:#c8102e;font-weight:600;"><%= fmtMoney(meta.price_lak, 'LAK') %></span><% } %>
              <br><span class="badge <%= o.status %>"><%= t('status.' + o.status) %></span>
            </span>
          </div>
          <% }); %>
        </div>

        <p class="note"><%- t('billing.invoiceNote', { link: '<a href="/portal/">' + esc(t('billing.invoiceNoteLink')) + '</a>' }) %></p>
      </div>
    </main>
  </div>
  <%- include('partials/footer') %>

<%# WTS Assistant — floating multilingual help widget.

    Included from partials/footer.ejs for every page that uses the admin
    footer. Renders NOTHING unless a user is signed in (footer.ejs is also
    used by the public auth pages — login/signup/reset — where `user` is
    null), so the guard below is the real gate and the include-side guard
    in footer.ejs is defense in depth.

    Configured-check choice (documented per spec): the widget renders for
    every signed-in user without any server-side "is the API key set?"
    plumbing. On first open per tab it POSTs { ping: true } to
    /api/assistant — a cheap probe that never calls the model — and on a
    503 shows "Assistant not configured on this server." inside the panel
    and disables input. The successful probe is cached in sessionStorage so
    subsequent page loads skip it. This keeps EJS free of require() tricks
    and adds no res.locals wiring.

    Security: all chat content (user text, model replies, server errors) is
    rendered via textContent — never innerHTML. History lives only in
    sessionStorage (per-tab, cleared on close). The CSRF token comes from
    the <meta name="csrf-token"> tag like every other admin fetch. %>
<% if (typeof user !== 'undefined' && user) { %>
<style>
  /* Scoped wtsa- prefix; kept inside the partial on purpose (style.css untouched). */
  .wtsa-fab {
    position: fixed; right: 20px; bottom: 20px; z-index: 950;
    width: 52px; height: 52px; border-radius: 50%; border: none; cursor: pointer;
    background: var(--primary-color, #d62b83); color: #fff; font-size: 1.3rem;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
  }
  .wtsa-fab:hover { filter: brightness(1.08); }
  .wtsa-panel {
    position: fixed; right: 20px; bottom: 84px; z-index: 950;
    width: 360px; max-width: calc(100vw - 32px);
    height: 480px; max-height: calc(100vh - 120px);
    background: var(--white, #ffffff);
    border: 1px solid var(--gray-200, #e2e8f0); border-radius: 14px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
    display: flex; flex-direction: column; overflow: hidden;
  }
  .wtsa-panel[hidden] { display: none; }
  .wtsa-head {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem;
    padding: 0.7rem 1rem; background: var(--primary-color, #d62b83); color: #fff;
  }
  .wtsa-title { font-weight: 700; font-size: 0.95rem; }
  .wtsa-hint { font-size: 0.7rem; opacity: 0.92; margin-top: 2px; }
  .wtsa-close {
    background: none; border: none; color: #fff; font-size: 1.4rem; line-height: 1;
    cursor: pointer; padding: 0 0.25rem; flex: 0 0 auto;
  }
  .wtsa-messages {
    flex: 1; overflow-y: auto; padding: 0.75rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    background: var(--gray-50, #f8fafc);
  }
  .wtsa-msg {
    max-width: 85%; padding: 0.5rem 0.7rem; border-radius: 12px;
    font-size: 0.85rem; line-height: 1.45; white-space: pre-wrap; word-break: break-word;
  }
  .wtsa-user {
    align-self: flex-end; background: var(--primary-color, #d62b83); color: #fff;
    border-bottom-right-radius: 4px;
  }
  .wtsa-bot {
    align-self: flex-start; background: var(--white, #ffffff);
    color: var(--gray-800, #1e293b); border: 1px solid var(--gray-200, #e2e8f0);
    border-bottom-left-radius: 4px;
  }
  .wtsa-notice {
    align-self: center; text-align: center; font-size: 0.75rem;
    color: var(--gray-500, #64748b); padding: 0.15rem 0.5rem;
  }
  .wtsa-foot {
    border-top: 1px solid var(--gray-200, #e2e8f0);
    padding: 0.5rem 0.75rem 0.65rem; background: var(--white, #ffffff);
  }
  .wtsa-disclaimer { font-size: 0.68rem; color: var(--gray-500, #64748b); margin-bottom: 0.4rem; }
  .wtsa-inputrow { display: flex; gap: 0.5rem; align-items: flex-end; }
  .wtsa-input {
    flex: 1; resize: none; min-height: 38px; max-height: 90px;
    border: 1px solid var(--gray-300, #cbd5e1); border-radius: 10px;
    padding: 0.5rem 0.65rem; font-size: 0.85rem; font-family: inherit;
    color: var(--gray-800, #1e293b); background: var(--white, #ffffff);
  }
  .wtsa-send {
    flex: 0 0 auto; width: 38px; height: 38px; border: none; border-radius: 10px;
    background: var(--primary-color, #d62b83); color: #fff; cursor: pointer;
  }
  .wtsa-send:disabled, .wtsa-input:disabled { opacity: 0.55; cursor: not-allowed; }
  @media (max-width: 768px) {
    /* Clear the fixed mobile bottom dock (.bottom-dock: z-index 900, ~68px
       + safe-area tall) — the widget floats above it and stays below the
       nav drawer/overlay (z-index 1000), which must cover everything. */
    .wtsa-fab { right: 14px; bottom: calc(80px + env(safe-area-inset-bottom)); }
    .wtsa-panel {
      right: 8px; left: 8px; width: auto;
      bottom: calc(76px + env(safe-area-inset-bottom));
      height: auto; max-height: calc(100vh - 170px);
    }
    #wtsAssistant.open .wtsa-fab { display: none; }
  }
</style>
<div id="wtsAssistant">
  <div id="wtsAssistantPanel" class="wtsa-panel" role="dialog" aria-label="WTS Assistant" hidden>
    <div class="wtsa-head">
      <div>
        <div class="wtsa-title">WTS Assistant</div>
        <div class="wtsa-hint">Ask in any language / ຖາມເປັນພາສາລາວໄດ້ / ถามเป็นภาษาไทยได้</div>
      </div>
      <button type="button" id="wtsAssistantClose" class="wtsa-close" aria-label="Close assistant">&times;</button>
    </div>
    <div id="wtsAssistantMessages" class="wtsa-messages" aria-live="polite"></div>
    <div class="wtsa-foot">
      <div class="wtsa-disclaimer">Never share bank account numbers or passwords in chat.</div>
      <div class="wtsa-inputrow">
        <textarea id="wtsAssistantInput" class="wtsa-input" rows="1" maxlength="2000"
                  placeholder="Type a question…" aria-label="Message the assistant"></textarea>
        <button type="button" id="wtsAssistantSend" class="wtsa-send" aria-label="Send message">
          <i class="fas fa-paper-plane"></i>
        </button>
      </div>
    </div>
  </div>
  <button type="button" id="wtsAssistantFab" class="wtsa-fab" aria-label="Open WTS Assistant" aria-expanded="false">
    <i class="fas fa-comment-dots"></i>
  </button>
</div>
<script nonce="<%= cspNonce %>">
(function () {
  var root = document.getElementById('wtsAssistant');
  if (!root) return;
  var fab = document.getElementById('wtsAssistantFab');
  var panel = document.getElementById('wtsAssistantPanel');
  var list = document.getElementById('wtsAssistantMessages');
  var input = document.getElementById('wtsAssistantInput');
  var sendBtn = document.getElementById('wtsAssistantSend');
  var closeBtn = document.getElementById('wtsAssistantClose');

  var HISTORY_KEY = 'wts_assistant_history';   // last 8 turns, per tab
  var READY_KEY = 'wts_assistant_ready';       // '1' once a ping succeeded this tab
  var MAX_TURNS = 8;
  var csrfMeta = document.querySelector('meta[name="csrf-token"]');
  var csrf = csrfMeta ? csrfMeta.content : '';
  var busy = false;
  var rendered = false;
  var pinged = false;

  function loadHistory() {
    try {
      var h = JSON.parse(sessionStorage.getItem(HISTORY_KEY) || '[]');
      return Array.isArray(h) ? h.slice(-MAX_TURNS) : [];
    } catch (e) { return []; }
  }
  function saveHistory(h) {
    try { sessionStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(-MAX_TURNS))); } catch (e) {}
  }

  // All chat content goes through textContent — never innerHTML.
  function addBubble(role, text) {
    var div = document.createElement('div');
    div.className = 'wtsa-msg ' + (role === 'user' ? 'wtsa-user' : 'wtsa-bot');
    div.textContent = text;
    list.appendChild(div);
    list.scrollTop = list.scrollHeight;
    return div;
  }
  function addNotice(text) {
    var div = document.createElement('div');
    div.className = 'wtsa-notice';
    div.textContent = text;
    list.appendChild(div);
    list.scrollTop = list.scrollHeight;
    return div;
  }
  function setDisabled(flag) { input.disabled = flag; sendBtn.disabled = flag; }

  function post(body) {
    return fetch('/api/assistant', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'content-type': 'application/json', accept: 'application/json', 'x-csrf-token': csrf },
      body: JSON.stringify(body)
    }).then(function (res) {
      return res.json().catch(function () { return null; }).then(function (data) {
        return { status: res.status, data: data };
      });
    });
  }

  // First-open probe: cheap ping (no model call). 503 = key not set on the
  // server → say so and disable input. Success is remembered per tab.
  function ensureReady() {
    if (pinged || sessionStorage.getItem(READY_KEY) === '1') { pinged = true; return; }
    pinged = true;
    post({ ping: true }).then(function (r) {
      if (r.status === 200) {
        try { sessionStorage.setItem(READY_KEY, '1'); } catch (e) {}
      } else if (r.status === 503) {
        addNotice('Assistant not configured on this server.');
        setDisabled(true);
      }
    }).catch(function () { /* network blip — a real send will surface it */ });
  }

  function openPanel() {
    panel.hidden = false;
    root.classList.add('open');
    fab.setAttribute('aria-expanded', 'true');
    if (!rendered) {
      rendered = true;
      loadHistory().forEach(function (t) { addBubble(t.role, t.content); });
      if (!list.childNodes.length) {
        addNotice('Hi! Ask me how to use any part of the platform — in your own language.');
      }
    }
    ensureReady();
    input.focus();
  }
  function closePanel() {
    panel.hidden = true;
    root.classList.remove('open');
    fab.setAttribute('aria-expanded', 'false');
  }

  function sendMessage() {
    var text = input.value.trim();
    if (!text || busy || input.disabled) return;
    input.value = '';
    addBubble('user', text);
    var history = loadHistory();
    busy = true;
    sendBtn.disabled = true;
    var thinking = addNotice('…');
    post({
      message: text,
      page: location.pathname + ' — ' + document.title,
      history: history
    }).then(function (r) {
      thinking.remove();
      if (r.status === 200 && r.data && r.data.success && typeof r.data.reply === 'string') {
        addBubble('assistant', r.data.reply);
        saveHistory(history.concat([
          { role: 'user', content: text.slice(0, 1000) },
          { role: 'assistant', content: r.data.reply.slice(0, 1000) }
        ]));
      } else if (r.status === 503) {
        addNotice('Assistant not configured on this server.');
        setDisabled(true);
      } else if (r.status === 429) {
        addNotice('Too many messages — please wait a moment and try again.');
      } else {
        addNotice((r.data && r.data.error) || 'Something went wrong. Please try again.');
      }
    }).catch(function () {
      thinking.remove();
      addNotice('Network error — please try again.');
    }).then(function () {
      busy = false;
      if (!input.disabled) sendBtn.disabled = false;
      input.focus();
    });
  }

  fab.addEventListener('click', function () { panel.hidden ? openPanel() : closePanel(); });
  closeBtn.addEventListener('click', closePanel);
  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', function (e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  panel.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closePanel();
  });
})();
</script>
<% } %>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <img src="/images/SEO_AI_Digital_Marketing_Agency_Laos_Thailand_Asia_logo_with-words_white_colour_SVG.svg" alt="WTS Admin" class="logo-img">
    </div>
    <button class="rail-toggle" id="railToggle" aria-pressed="false" aria-label="Collapse menu" title="Collapse menu">
      <i class="fas fa-angles-left"></i>
    </button>
    <button class="sidebar-toggle" id="sidebarToggle" aria-label="Close menu">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <%
    // Role-scoped, job-organized navigation (three zones):
    //   WORKSPACE — pinned daily surfaces, never collapses
    //   OPERATE   — one accordion, one section open at a time
    //   UTILITY   — profile/settings/legal, collapsed out of the way
    // Workers (translators and payable vendors) see their workspace, work
    // hub and earnings; the operations accordion is the admin control
    // plane ('admin' and 'superadmin' are synonyms).
    var isAdminRole = user && ['admin', 'superadmin'].includes(user.role);
    var isTranslatorRole = user && user.role === 'translator';
    var isWorker = user && (isTranslatorRole || user.is_vendor === true);

    // currentPage keys per Operate section — the active section renders
    // open and the accordion keeps it that way.
    var OPERATE = {
      content: ['articles', 'seo-terms', 'ai-tools', 'glossary', 'guides'],
      localization: ['translations', 'translation-vendors', 'translation-payouts'],
      workforce: ['leads', 'engagement', 'work-hub'],
      commerce: ['orders', 'payments', 'customers', 'boards', 'products', 'pricing'],
      web: ['microsites', 'menus', 'footers', 'footer-settings', 'sidebar', 'form-templates', 'submissions', 'affiliates', 'agencies'],
    };
    var isOpen = function (key) { return OPERATE[key].includes(currentPage); };
    var isUtility = ['profile', 'settings'].includes(currentPage);
  %>

  <nav class="sidebar-nav">
    <ul class="nav-list">
      <!-- ── WORKSPACE: pinned daily surfaces ─────────────────── -->
      <li class="nav-zone-label">Workspace</li>

      <% if (!isTranslatorRole) { %>
      <li class="nav-item">
        <a href="/dashboard" class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>" title="Dashboard">
          <i class="fas fa-home"></i>
          <span>Dashboard</span>
        </a>
      </li>
      <% } %>

      <% if (isTranslatorRole || isAdminRole) { %>
      <li class="nav-item">
        <a href="/translations/workspace" class="nav-link <%= currentPage === 'workspace' ? 'active' : '' %>" title="My Workspace">
          <i class="fas fa-pen-to-square"></i>
          <span>My Workspace</span>
        </a>
      </li>
      <% } %>

      <% if (isWorker && !isAdminRole) { %>
      <li class="nav-item">
        <a href="/workforce/my" class="nav-link <%= currentPage === 'work-hub' ? 'active' : '' %>" title="My Work Hub">
          <i class="fas fa-briefcase"></i>
          <span>My Work Hub</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/translations/earnings" class="nav-link <%= currentPage === 'earnings' ? 'active' : '' %>" title="My Earnings">
          <i class="fas fa-coins"></i>
          <span>My Earnings</span>
        </a>
      </li>
      <% } %>

      <% if (isAdminRole) { %>
      <li class="nav-item">
        <a href="/partners" class="nav-link <%= currentPage === 'partners' ? 'active' : '' %>" title="Partner Programs">
          <i class="fas fa-handshake-angle"></i>
          <span>Partner Programs</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/images" class="nav-link <%= currentPage === 'images' ? 'active' : '' %>" title="Image Library">
          <i class="fas fa-images"></i>
          <span>Image Library</span>
        </a>
      </li>
      <% } %>

      <% if (isAdminRole) { %>
      <!-- ── OPERATE: one section open at a time ──────────────── -->
      <li class="nav-zone-label">Operate</li>

      <li class="nav-item has-submenu" data-accordion="operate" data-group="content">
        <a href="#" class="nav-link submenu-toggle <%= isOpen('content') ? 'active' : '' %>" title="Content">
          <i class="fas fa-file-alt"></i>
          <span>Content</span>
          <i class="fas fa-chevron-down submenu-arrow"></i>
        </a>
        <ul class="submenu <%= isOpen('content') ? 'open' : '' %>">
          <li><a href="/content/articles" class="<%= currentPage === 'articles' ? 'active' : '' %>"><i class="fas fa-newspaper"></i> Articles</a></li>
          <li><a href="/content/seo-terms" class="<%= currentPage === 'seo-terms' ? 'active' : '' %>"><i class="fas fa-search"></i> SEO Terms</a></li>
          <li><a href="/content/ai-tools" class="<%= currentPage === 'ai-tools' ? 'active' : '' %>"><i class="fas fa-robot"></i> AI Tools</a></li>
          <li><a href="/content/glossary" class="<%= currentPage === 'glossary' ? 'active' : '' %>"><i class="fas fa-book"></i> Glossary</a></li>
          <li><a href="/content/guides" class="<%= currentPage === 'guides' ? 'active' : '' %>"><i class="fas fa-book-reader"></i> E-Guides</a></li>
        </ul>
      </li>

      <li class="nav-item has-submenu" data-accordion="operate" data-group="localization">
        <a href="#" class="nav-link submenu-toggle <%= isOpen('localization') ? 'active' : '' %>" title="Localization">
          <i class="fas fa-language"></i>
          <span>Localization</span>
          <i class="fas fa-chevron-down submenu-arrow"></i>
        </a>
        <ul class="submenu <%= isOpen('localization') ? 'open' : '' %>">
          <li><a href="/translations" class="<%= currentPage === 'translations' ? 'active' : '' %>"><i class="fas fa-list-check"></i> Translations</a></li>
          <li><a href="/translations/vendors" class="<%= currentPage === 'translation-vendors' ? 'active' : '' %>"><i class="fas fa-user-tag"></i> Team &amp; Vendors</a></li>
          <li><a href="/translations/payouts" class="<%= currentPage === 'translation-payouts' ? 'active' : '' %>"><i class="fas fa-coins"></i> Payout Ledger</a></li>
        </ul>
      </li>

      <li class="nav-item has-submenu" data-accordion="operate" data-group="workforce">
        <a href="#" class="nav-link submenu-toggle <%= isOpen('workforce') ? 'active' : '' %>" title="Workforce">
          <i class="fas fa-people-group"></i>
          <span>Workforce</span>
          <i class="fas fa-chevron-down submenu-arrow"></i>
        </a>
        <ul class="submenu <%= isOpen('workforce') ? 'open' : '' %>">
          <li><a href="/workforce/leads" class="<%= currentPage === 'leads' ? 'active' : '' %>"><i class="fas fa-address-book"></i> Leads CRM</a></li>
          <li><a href="/workforce/engagement" class="<%= currentPage === 'engagement' ? 'active' : '' %>"><i class="fas fa-comments"></i> Engagement &amp; Cascades</a></li>
          <li><a href="/workforce/my" class="<%= currentPage === 'work-hub' ? 'active' : '' %>"><i class="fas fa-briefcase"></i> Work Hub (worker view)</a></li>
        </ul>
      </li>

      <li class="nav-item has-submenu" data-accordion="operate" data-group="commerce">
        <a href="#" class="nav-link submenu-toggle <%= isOpen('commerce') ? 'active' : '' %>" title="Commerce">
          <i class="fas fa-cash-register"></i>
          <span>Commerce</span>
          <i class="fas fa-chevron-down submenu-arrow"></i>
        </a>
        <ul class="submenu <%= isOpen('commerce') ? 'open' : '' %>">
          <li><a href="/business/orders" class="<%= currentPage === 'orders' ? 'active' : '' %>"><i class="fas fa-receipt"></i> Orders</a></li>
          <li><a href="/business/payments" class="<%= currentPage === 'payments' ? 'active' : '' %>"><i class="fas fa-credit-card"></i> Payments</a></li>
          <li><a href="/business/customers" class="<%= currentPage === 'customers' ? 'active' : '' %>"><i class="fas fa-user-group"></i> Clients</a></li>
          <li><a href="/business/products" class="<%= currentPage === 'products' ? 'active' : '' %>"><i class="fas fa-box"></i> Products</a></li>
          <li><a href="/business/pricing" class="<%= currentPage === 'pricing' ? 'active' : '' %>"><i class="fas fa-tags"></i> Packages</a></li>
          <% if (typeof featureWhiteboard !== 'undefined' && featureWhiteboard) { %>
          <li><a href="/business/boards" class="<%= currentPage === 'boards' ? 'active' : '' %>"><i class="fas fa-chalkboard"></i> Boards</a></li>
          <% } %>
        </ul>
      </li>

      <li class="nav-item has-submenu" data-accordion="operate" data-group="web">
        <a href="#" class="nav-link submenu-toggle <%= isOpen('web') ? 'active' : '' %>" title="Web &amp; Connections">
          <i class="fas fa-plug"></i>
          <span>Web &amp; Connections</span>
          <i class="fas fa-chevron-down submenu-arrow"></i>
        </a>
        <ul class="submenu <%= isOpen('web') ? 'open' : '' %>">
          <li><a href="/webdev/microsites" class="<%= currentPage === 'microsites' ? 'active' : '' %>"><i class="fas fa-globe"></i> Microsites</a></li>
          <li><a href="/webdev/menus" class="<%= currentPage === 'menus' ? 'active' : '' %>"><i class="fas fa-bars"></i> Menu Manager</a></li>
          <li><a href="/webdev/footers" class="<%= currentPage === 'footers' || currentPage === 'footer-settings' ? 'active' : '' %>"><i class="fas fa-shoe-prints"></i> Footer Manager</a></li>
          <li><a href="/webdev/sidebar" class="<%= currentPage === 'sidebar' ? 'active' : '' %>"><i class="fas fa-window-restore"></i> Sidebar Manager</a></li>
          <li><a href="/webdev/form-templates" class="<%= currentPage === 'form-templates' ? 'active' : '' %>"><i class="fas fa-file-lines"></i> Forms</a></li>
          <li><a href="/webdev/submissions" class="<%= currentPage === 'submissions' ? 'active' : '' %>"><i class="fas fa-inbox"></i> Submissions</a></li>
          <li><a href="/business/affiliates" class="<%= currentPage === 'affiliates' ? 'active' : '' %>"><i class="fas fa-handshake"></i> Affiliate Solutions</a></li>
          <li><a href="/business/agencies" class="<%= currentPage === 'agencies' ? 'active' : '' %>"><i class="fas fa-building"></i> Agency Management</a></li>
        </ul>
      </li>
      <% } %>

      <!-- ── UTILITY: configuration, collapsed out of the way ─── -->
      <li class="nav-divider"></li>
      <li class="nav-item has-submenu" data-accordion="utility" data-group="utility">
        <a href="#" class="nav-link submenu-toggle <%= isUtility ? 'active' : '' %>" title="Profile, settings &amp; legal">
          <i class="fas fa-sliders"></i>
          <span>Profile &amp; Settings</span>
          <i class="fas fa-chevron-down submenu-arrow"></i>
        </a>
        <ul class="submenu <%= isUtility ? 'open' : '' %>">
          <li><a href="/dashboard/profile" class="<%= currentPage === 'profile' ? 'active' : '' %>"><i class="fas fa-user"></i> Profile</a></li>
          <li><a href="/dashboard/settings" class="<%= currentPage === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i> Settings</a></li>
          <li><a href="https://wordsthatsells.website/en/company/legal/" target="_blank" rel="noopener noreferrer"><i class="fas fa-scale-balanced"></i> Legal</a></li>
        </ul>
      </li>
    </ul>
  </nav>

  <div class="sidebar-footer">
    <% if (user) { %>
    <div class="user-info">
      <div class="user-avatar">
        <% if (user.avatar_url) { %>
        <img src="<%= user.avatar_url %>" alt="<%= user.first_name %>">
        <% } else { %>
        <span><%= user.first_name ? user.first_name.charAt(0).toUpperCase() : 'U' %></span>
        <% } %>
      </div>
      <div class="user-details">
        <span class="user-name"><%= user.first_name %> <%= user.last_name || '' %></span>
        <span class="user-role"><%= user.role || 'User' %></span>
      </div>
    </div>
    <% } %>
    <a href="/auth/logout" class="logout-btn" title="Logout">
      <i class="fas fa-sign-out-alt"></i>
      <span>Logout</span>
    </a>
  </div>
</aside>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Mobile bottom dock: the 3 highest-frequency destinations for this
     role plus "More" (opens the drawer). Hidden ≥768px. -->
<nav class="bottom-dock" id="bottomDock" aria-label="Quick navigation">
  <% if (isAdminRole) { %>
    <a href="/dashboard" class="<%= currentPage === 'dashboard' ? 'active' : '' %>"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="/translations/workspace" class="<%= currentPage === 'workspace' ? 'active' : '' %>"><i class="fas fa-pen-to-square"></i><span>Workspace</span></a>
    <a href="/partners" class="<%= currentPage === 'partners' ? 'active' : '' %>"><i class="fas fa-handshake-angle"></i><span>Partners</span></a>
  <% } else if (isWorker) { %>
    <a href="/translations/workspace" class="<%= currentPage === 'workspace' ? 'active' : '' %>"><i class="fas fa-pen-to-square"></i><span>Workspace</span></a>
    <a href="/workforce/my" class="<%= currentPage === 'work-hub' ? 'active' : '' %>"><i class="fas fa-briefcase"></i><span>Work Hub</span></a>
    <a href="/translations/earnings" class="<%= currentPage === 'earnings' ? 'active' : '' %>"><i class="fas fa-coins"></i><span>Earnings</span></a>
  <% } else { %>
    <a href="/dashboard" class="<%= currentPage === 'dashboard' ? 'active' : '' %>"><i class="fas fa-home"></i><span>Dashboard</span></a>
    <a href="/dashboard/profile" class="<%= currentPage === 'profile' ? 'active' : '' %>"><i class="fas fa-user"></i><span>Profile</span></a>
    <a href="/dashboard/settings" class="<%= currentPage === 'settings' ? 'active' : '' %>"><i class="fas fa-cog"></i><span>Settings</span></a>
  <% } %>
  <button type="button" id="dockMore" aria-label="Open full menu"><i class="fas fa-bars"></i><span>More</span></button>
</nav>

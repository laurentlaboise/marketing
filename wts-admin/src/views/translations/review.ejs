<%- include('../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Review Translation</h1>
        <p class="page-subtitle" style="margin-bottom:0.25rem;">
          <em>Publishing review — the final gate before the site. Workers fix and sign off drafts in their own Verify screen; this page approves, publishes and credits payouts.</em>
        </p>
        <p class="page-subtitle">
          <%= entityConfig.label %> → <%= languageNames[item.target_language] || item.target_language %>
          · status: <strong><%= item.status.replace('_', ' ') %></strong>
          <% if (item.ai_model) { %> · drafted by <i class="fas fa-robot"></i> <%= item.ai_model %><% } %>
          <% if (item.ai_source_strategy === 'th_pivot') { %>
            <span title="English was the authoritative source; the entity's verified Thai translation guided style and phrasing.">(English source · Thai style reference)</span>
          <% } %>
          <% if (typeof pivotStale !== 'undefined' && pivotStale) { %>
            · <span style="color:#b45309;"><i class="fas fa-triangle-exclamation"></i> the Thai reference has changed since this draft</span>
          <% } %>
          <% if (translator) { %> · translator: <%= translator.first_name %> <%= translator.last_name || '' %> (<%= translator.email %>)<% } %>
          <% if (typeof verifier !== 'undefined' && verifier) { %>
            · verified by <%= verifier.first_name %> <%= verifier.last_name || '' %>
            (<%= item.target_char_count || 0 %> chars read<% if (item.edited_segments) { %>, <%= item.edited_segments %> segment(s) reworked — <%= item.edited_chars %> chars<% } else { %>, approved as-is<% } %>)
          <% } %>
          <%
            var revSS = item.section_status || {};
            var revSSDone = Object.keys(revSS).filter(function (k) { return revSS[k] && revSS[k].verified; }).length;
          %>
          <% if (revSSDone > 0) { %>
            · <span title="Sections the verifier ticked off individually, each stamped with who and when."><i class="fas fa-list-check"></i> <%= revSSDone %> section<%= revSSDone === 1 ? '' : 's' %> individually signed off</span>
          <% } %>
        </p>
      </div>
      <div class="page-actions">
        <a href="/translations" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
      </div>
    </div>

    <div class="card" style="margin-bottom:1rem;">
      <div class="card-body" style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center;">
        <% if (item.status === 'requires_review' || item.status === 'verified') { %>
          <button type="button" class="btn btn-primary" id="approveBtn">
            <i class="fas fa-check"></i> <%= item.status === 'verified' ? 'Publish (verified)' : 'Approve & Publish' %>
          </button>
          <button type="button" class="btn btn-danger" id="rejectBtn">
            <i class="fas fa-rotate-left"></i> Reject with Note
          </button>
          <button type="button" class="btn btn-secondary" id="interlinkBtn" title="Hyperlink glossary and SEO term mentions in this translation to their term pages (internal-link SEO)">
            <i class="fas fa-link"></i> Link SEO Terms
          </button>
          <% if (item.status === 'requires_review' && !item.translator_id) { %>
            <button type="button" class="btn btn-secondary" id="retranslateBtn" title="Overwrite this draft with a fresh AI translation from the English source<%= item.target_language === 'la' ? ' (verified Thai attached as a style reference when available)' : '' %>. Stays an unpaid AI draft in requires review.">
              <i class="fas fa-robot"></i> Re-translate with AI
            </button>
          <% } %>
        <% } else if (item.status === 'published') { %>
          <button type="button" class="btn btn-secondary" id="reopenBtn">
            <i class="fas fa-lock-open"></i> Reopen for Editing
          </button>
        <% } %>
        <% if (typeof thaiRef !== 'undefined' && thaiRef) { %>
          <button type="button" class="btn btn-secondary" id="thaiRefBtn" title="Show the verified Thai translation of this content beside each field — reference only, English remains the source.">
            <i class="fas fa-language"></i> Show Thai reference
          </button>
        <% } %>
        <span style="margin-left:auto; color:var(--gray-500);">
          <% if (ledgerEntry) { %>
            <i class="fas fa-coins"></i> Credited <%= ledgerEntry.currency %> <%= parseFloat(ledgerEntry.amount).toFixed(2) %> (<%= ledgerEntry.status %>)
          <% } else if (payoutPreview) { %>
            <i class="fas fa-coins"></i> On publish: <%= payoutPreview.currency %> <%= payoutPreview.amount.toFixed(2) %>
            (<%= payoutPreview.rateType === 'per_word' ? (payoutPreview.rateAmount + '/word × ' + (item.word_count || 0)) : payoutPreview.rateType %>)
          <% } else if (translator && translator.is_vendor) { %>
            <i class="fas fa-triangle-exclamation"></i> No payout rate configured for this vendor
          <% } else if (item.ai_model && !item.translator_id) { %>
            AI translation — no payout
          <% } %>
        </span>
      </div>
      <% if (item.review_note) { %>
      <div class="card-body" style="border-top:1px solid var(--gray-200); color:var(--gray-600);">
        <strong>Last review note:</strong> <%= item.review_note %>
      </div>
      <% } %>
    </div>

    <%
      // Dynamic entities (site pages) list one field per extracted segment,
      // in page reading order; fall back to payload keys if the source is gone.
      var fieldList = entityConfig.dynamic
        ? Object.keys((source && source.fields) || item.content_payload || {})
        : entityConfig.fields;
      var segIndex = 0;
    %>
    <% var hasThaiRef = typeof thaiRef !== 'undefined' && thaiRef; %>
    <% fieldList.forEach(field => {
         var sourceValue = source && source.fields[field];
         var targetValue = item.content_payload ? item.content_payload[field] : null;
         var thaiValue = hasThaiRef ? thaiRef.content_payload[field] : null;
         if (!sourceValue && !targetValue) return;
         segIndex += 1;
         var fieldLabel = entityConfig.dynamic ? ('Segment ' + segIndex) : field.replace(/_/g, ' '); %>
      <div class="card" style="margin-bottom:1rem;">
        <div class="card-body">
          <h3 style="margin:0 0 0.75rem; font-size:0.9rem; text-transform:uppercase; color:var(--gray-500);"><%= fieldLabel %></h3>
          <div class="cmp-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div>
              <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;">English source</div>
              <div style="border:1px solid var(--gray-200); border-radius:6px; padding:0.75rem; max-height:320px; overflow:auto; white-space:pre-wrap; background:var(--gray-50, #f9fafb);"><%= sourceValue || '—' %></div>
            </div>
            <div>
              <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;"><%= languageNames[item.target_language] || item.target_language %></div>
              <div style="border:1px solid var(--gray-200); border-radius:6px; padding:0.75rem; max-height:320px; overflow:auto; white-space:pre-wrap;"><%= targetValue || '—' %></div>
            </div>
            <% if (hasThaiRef) { %>
              <div class="thai-ref-cell" hidden>
                <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;">Thai (verified · reference only)</div>
                <div style="border:1px dashed var(--gray-300, #d1d5db); border-radius:6px; padding:0.75rem; max-height:320px; overflow:auto; white-space:pre-wrap; background:var(--gray-50, #f9fafb);"><%= thaiValue || '—' %></div>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
</main>

<script nonce="<%= cspNonce %>">
(function () {
  var csrfMeta = document.querySelector('meta[name="csrf-token"]');
  var csrf = csrfMeta ? csrfMeta.content : '';
  var id = '<%= item.id %>';

  // Robust POST wrapper: non-JSON bodies (rate-limit text, proxy error
  // pages) and network failures resolve to a readable error instead of an
  // unhandled rejection that leaves buttons dead.
  function post(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(body || {})
    }).then(function (r) {
      return r.json().catch(function () {
        return { error: r.status === 429 ? 'Too many requests — wait a minute and try again.' : ('Request failed (' + r.status + '). Try again.') };
      }).then(function (d) {
        if (r.status === 401) {
          d.error = d.error || 'Your session has expired — please log in again.';
        }
        return { ok: r.ok, data: d };
      });
    }).catch(function () {
      return { ok: false, data: { error: 'No connection — check your internet and try again.' } };
    });
  }

  var approveBtn = document.getElementById('approveBtn');
  if (approveBtn) approveBtn.addEventListener('click', function () {
    if (!confirm('Publish this translation? Vendor payout (if configured) is credited immediately.')) return;
    function doApprove(body) {
      post('/translations/' + id + '/approve', body).then(function (res) {
        if (res.ok) {
          var p = res.data.payout;
          alert(p ? ('Published. Credited ' + p.currency + ' ' + p.amount.toFixed(2) + ' to the vendor ledger.') : 'Published.');
          location.reload();
          return;
        }
        // Money guard: a missing rate card would silently skip credits —
        // the server stops and asks for explicit acknowledgement.
        if (res.data.requiresAcknowledgement) {
          var msg = 'PRE-PUBLISH WARNINGS\n\n\u2022 ' + res.data.warnings.join('\n\u2022 ') +
            '\n\nFix these first (recommended), or publish anyway?';
          if (confirm(msg)) doApprove({ acknowledge: true });
          return;
        }
        alert(res.data.error || 'Approve failed');
      });
    }
    doApprove({});
  });

  var rejectBtn = document.getElementById('rejectBtn');
  var REASONS = ['mistranslation', 'tone', 'terminology', 'markup', 'incomplete', 'other'];
  if (rejectBtn) rejectBtn.addEventListener('click', function () {
    var pick = prompt('Reason \u2014 type a number:\n1 mistranslation  2 tone  3 terminology\n4 markup  5 incomplete  6 other');
    if (pick === null) return;
    var reason = REASONS[parseInt(pick, 10) - 1] || 'other';
    var note = prompt('Note for the translator (what needs to change)?');
    if (note === null) return;
    post('/translations/' + id + '/reject', { note: note, reason: reason }).then(function (res) {
      if (res.ok) location.href = '/translations'; else alert(res.data.error || 'Reject failed');
    });
  });

  var reopenBtn = document.getElementById('reopenBtn');
  if (reopenBtn) reopenBtn.addEventListener('click', function () {
    if (!confirm('Reopen this published translation for editing? Re-publishing will NOT credit the vendor again.')) return;
    post('/translations/' + id + '/reopen').then(function (res) {
      if (res.ok) location.reload(); else alert(res.data.error || 'Reopen failed');
    });
  });

  // Reference-only Thai column for Lao rows: the reviewer pool reads Thai
  // fluently, and Lao AI drafts lean on the verified Thai for style. The
  // English column stays the authority; this is a comparison aid.
  var thaiRefBtn = document.getElementById('thaiRefBtn');
  if (thaiRefBtn) thaiRefBtn.addEventListener('click', function () {
    var showing = this.dataset.showing === '1';
    this.dataset.showing = showing ? '0' : '1';
    this.innerHTML = showing
      ? '<i class="fas fa-language"></i> Show Thai reference'
      : '<i class="fas fa-language"></i> Hide Thai reference';
    document.querySelectorAll('.thai-ref-cell').forEach(function (cell) { cell.hidden = showing; });
    document.querySelectorAll('.cmp-grid').forEach(function (grid) {
      grid.style.gridTemplateColumns = showing ? '1fr 1fr' : '1fr 1fr 1fr';
    });
  });

  // Per-item AI redraft. Runs through the shared batch engine (one job at
  // a time), so this polls the same status endpoint until the single-row
  // job finishes, then reloads to show the new draft.
  var retranslateBtn = document.getElementById('retranslateBtn');
  if (retranslateBtn) retranslateBtn.addEventListener('click', function () {
    var msg = 'Re-draft this translation with AI now?\n\n' +
      'This OVERWRITES the current draft text in place (including any saved verifier fixes) ' +
      'and the row returns to "requires review". It stays an unpaid AI draft — no payout is created.';
    if (!confirm(msg)) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Re-translating…';
    function watchJob() {
      fetch('/translations/ai-batch/status', { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (d.job && d.job.status === 'running') { setTimeout(watchJob, 2000); return; }
          if (d.job && d.job.failed > 0) {
            var last = d.job.errors && d.job.errors.length ? d.job.errors[d.job.errors.length - 1].error : 'unknown error';
            alert('Re-translation failed: ' + last);
          } else if (d.job && d.job.skipped > 0 && d.job.translated === 0) {
            alert('Nothing was re-drafted — the row was skipped (' + JSON.stringify(d.job.skipReasons) + ').');
          }
          location.reload();
        })
        .catch(function () { setTimeout(watchJob, 4000); });
    }
    post('/translations/' + id + '/retranslate').then(function (res) {
      if (!res.ok) {
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-robot"></i> Re-translate with AI';
        alert(res.data.error || 'Could not start re-translation');
        return;
      }
      watchJob();
    });
  });

  // Hyperlink glossary/SEO term mentions to their term pages in this
  // language (internal-link SEO). Idempotent: linked terms sit inside
  // anchors, which the injector never touches again.
  var interlinkBtn = document.getElementById('interlinkBtn');
  if (interlinkBtn) interlinkBtn.addEventListener('click', function () {
    var btn = this;
    btn.disabled = true;
    post('/translations/' + id + '/interlink').then(function (res) {
      if (!res.ok) { btn.disabled = false; return alert(res.data.error || 'Linking failed'); }
      if (res.data.count > 0) {
        alert('Linked ' + res.data.count + ' term(s): ' + res.data.linked.map(function (l) { return l.term; }).join(', '));
        location.reload();
      } else {
        btn.disabled = false;
        alert(res.data.note || 'No linkable term mentions found in this translation.');
      }
    });
  });
})();
</script>

<%- include('../partials/footer') %>

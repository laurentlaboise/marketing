<%- include('../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Translations</h1>
        <p class="page-subtitle">Localization pipeline — /en /th /la /fr</p>
      </div>
      <div class="page-actions">
        <button type="button" class="btn btn-secondary" id="syncPagesBtn" title="Import every public website page (homepage, services, prices, company, legal, glossary pages…) as translatable content">
          <i class="fas fa-file-import"></i> Sync Site Pages
        </button>
        <button type="button" class="btn btn-secondary" id="syncBtn" title="Create translation rows for database content (articles, glossary, products, guides) and flag stale ones">
          <i class="fas fa-rotate"></i> Sync Content
        </button>
        <button type="button" class="btn btn-primary" id="aiBatchBtn" <%= aiConfigured ? '' : 'disabled title="Set ANTHROPIC_API_KEY to enable"' %>>
          <i class="fas fa-robot"></i> Run AI Batch
        </button>
      </div>
    </div>

    <div class="card" style="margin-bottom: 1rem;">
      <div class="card-body" style="display:flex; gap:1.5rem; flex-wrap:wrap; align-items:center;">
        <% ['pending', 'translating', 'requires_review', 'verified', 'published', 'rejected'].forEach(s => { %>
          <a href="/translations?status=<%= s %>" style="text-decoration:none;">
            <strong><%= counts[s] || 0 %></strong> <%= s.replace('_', ' ') %>
          </a>
        <% }); %>
        <% if (counts.verified > 0) { %>
          <button type="button" class="btn btn-sm btn-primary" id="publishVerifiedBtn">
            <i class="fas fa-check-double"></i> Publish all verified (<%= counts.verified %>)
          </button>
        <% } %>
        <span id="aiJobStatus" style="margin-left:auto; color: var(--gray-500);">
          <% if (aiJob && aiJob.status === 'running') { %>
            <i class="fas fa-spinner fa-spin"></i> AI batch: <%= aiJob.processed %>/<%= aiJob.total %>
          <% } %>
        </span>
      </div>
    </div>

    <!-- Per-language progress: the operations view of the pipeline -->
    <div class="card" style="margin-bottom: 1rem;">
      <div class="card-body" style="display:flex; gap:1.25rem; flex-wrap:wrap;">
        <% languages.forEach(function (l) {
             var s = (typeof langStats !== 'undefined' && langStats[l]) || {};
             var total = Object.values(s).reduce(function (a, b) { return a + b; }, 0);
             var published = s.published || 0;
             var pct = total ? Math.round(published * 100 / total) : 0; %>
          <a href="/translations?lang=<%= l %>" style="text-decoration:none; color:inherit; min-width:150px;">
            <div style="font-size:0.75rem; text-transform:uppercase; color:var(--gray-500);"><%= languageNames[l] || l %></div>
            <div style="font-size:1.15rem; font-weight:700;"><%= pct %>% <span style="font-size:0.75rem; font-weight:400; color:var(--gray-500);">published</span></div>
            <div style="height:6px; background:var(--gray-200); border-radius:999px; overflow:hidden; margin:0.25rem 0;">
              <div style="height:100%; width:<%= pct %>%; background:#059669;"></div>
            </div>
            <div style="font-size:0.72rem; color:var(--gray-500);">
              <%= published %> live · <%= (s.verified || 0) %> verified · <%= (s.requires_review || 0) %> in review · <%= (s.pending || 0) + (s.translating || 0) %> queued<%= s.rejected ? ' \u00b7 ' + s.rejected + ' returned' : '' %>
            </div>
          </a>
        <% }); %>
      </div>
    </div>

    <div class="card" style="margin-bottom: 1rem;">
      <div class="card-body">
        <form method="GET" action="/translations" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:end;">
          <div class="form-group" style="margin:0;">
            <label class="form-label" for="filterStatus">Status</label>
            <select class="form-input" id="filterStatus" name="status">
              <option value="">All</option>
              <% statuses.forEach(s => { %>
                <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.replace('_', ' ') %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label" for="filterLang">Language</label>
            <select class="form-input" id="filterLang" name="lang">
              <option value="">All</option>
              <% languages.forEach(l => { %>
                <option value="<%= l %>" <%= filters.lang === l ? 'selected' : '' %>><%= languageNames[l] || l %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label" for="filterEntity">Content type</label>
            <select class="form-input" id="filterEntity" name="entity_type">
              <option value="">All</option>
              <% entityTypes.forEach(t => { %>
                <option value="<%= t %>" <%= filters.entity_type === t ? 'selected' : '' %>><%= t %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn btn-secondary">Filter</button>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-body" style="padding: 0;">
        <% if (items.length > 0) { %>
        <!-- Bulk actions for the checked rows -->
        <div id="bulkBar" hidden style="display:flex; gap:0.75rem; align-items:center; padding:0.75rem 1rem; border-bottom:1px solid var(--gray-200); background:var(--gray-50, #f9fafb);">
          <strong><span id="bulkCount">0</span> selected</strong>
          <select class="form-input" id="bulkWorker" style="max-width:220px; padding:0.25rem;">
            <option value="">Choose worker&hellip;</option>
            <% translators.forEach(t => { %>
              <option value="<%= t.id %>" data-langs="<%= (t.assigned_languages || []).join(',') %>"><%= t.first_name %> <%= t.last_name || '' %> (<%= (t.assigned_languages || []).join(', ') || 'no languages' %>)</option>
            <% }); %>
          </select>
          <button type="button" class="btn btn-sm btn-secondary" id="bulkAssignBtn"><i class="fas fa-user-pen"></i> Assign as translator</button>
          <button type="button" class="btn btn-sm btn-secondary" id="bulkVerifyBtn"><i class="fas fa-clipboard-check"></i> Send to verify</button>
          <span style="color:var(--gray-500); font-size:0.8rem;">Rows the worker can't take (language, self-verification, status) are skipped and reported.</span>
        </div>
        <div class="table-container">
          <table class="table table-responsive-cards">
            <thead>
              <tr>
                <th style="width:2rem;"><input type="checkbox" id="selectAll" title="Select all on this page"></th>
                <th>Content</th>
                <th>Language</th>
                <th>Status</th>
                <th>Translator</th>
                <th>Verifier</th>
                <th>Chars</th>
                <th>Updated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
              <tr>
                <td data-label="Select"><input type="checkbox" class="row-check" value="<%= item.id %>"></td>
                <td data-label="Content">
                  <span style="color:var(--gray-500);"><%= item.entity_type %></span>
                  <% if (item.entity_title || item.page_path) { %>
                    <strong><%= item.entity_title || item.page_path %></strong>
                  <% } else { %>
                    <code style="font-size:0.75rem;"><%= item.entity_id.slice(0, 8) %></code>
                  <% } %>
                </td>
                <td data-label="Language"><%= languageNames[item.target_language] || item.target_language %></td>
                <td data-label="Status">
                  <%
                    var statusColors = { pending: '#6b7280', translating: '#2563eb', requires_review: '#d97706', published: '#059669', rejected: '#dc2626' };
                  %>
                  <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:999px; font-size:0.75rem; color:#fff; background:<%= statusColors[item.status] || '#6b7280' %>;">
                    <%= item.status.replace('_', ' ') %>
                  </span>
                </td>
                <td data-label="Translator">
                  <% if (item.translator_id) { %>
                    <%= item.translator_first_name || '' %> <%= item.translator_last_name || '' %>
                  <% } else if (item.ai_model) { %>
                    <i class="fas fa-robot" title="<%= item.ai_model %>"></i> AI
                  <% } else { %>
                    <select class="form-input assign-select" data-id="<%= item.id %>" style="max-width:180px; padding:0.25rem;">
                      <option value="">Assign…</option>
                      <% translators.filter(t => (t.assigned_languages || []).includes(item.target_language)).forEach(t => { %>
                        <option value="<%= t.id %>"><%= t.first_name %> <%= t.last_name || '' %></option>
                      <% }); %>
                    </select>
                  <% } %>
                </td>
                <td data-label="Verifier">
                  <% if (item.verifier_id) { %>
                    <%= item.verifier_first_name || '' %> <%= item.verifier_last_name || '' %>
                  <% } else if (item.status === 'requires_review') { %>
                    <%
                      // Push a drafted row to a specific verifier: same-language
                      // translators, never the row's own translator (no
                      // self-verification). AI rows (no translator_id) can go
                      // to anyone assigned the language.
                      var eligibleVerifiers = translators.filter(function (t) {
                        return (t.assigned_languages || []).includes(item.target_language)
                          && String(t.id) !== String(item.translator_id || '');
                      });
                    %>
                    <% if (eligibleVerifiers.length) { %>
                      <select class="form-input verifier-select" data-id="<%= item.id %>" style="max-width:170px; padding:0.25rem;">
                        <option value="">Send to verify…</option>
                        <% eligibleVerifiers.forEach(function (t) { %>
                          <option value="<%= t.id %>"><%= t.first_name %> <%= t.last_name || '' %></option>
                        <% }); %>
                      </select>
                    <% } else { %>
                      <span style="color:var(--gray-400);">—</span>
                    <% } %>
                  <% } else { %>
                    <span style="color:var(--gray-400);">—</span>
                  <% } %>
                </td>
                <td data-label="Chars"><%= item.target_char_count ? Number(item.target_char_count).toLocaleString() : '-' %></td>
                <td data-label="Updated"><%= new Date(item.updated_at).toLocaleDateString() %></td>
                <td data-label="Actions">
                  <a href="/translations/review/<%= item.id %>" class="btn btn-sm btn-secondary"><i class="fas fa-eye"></i> Review</a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Batch navigation (Gmail-style): choose 50 / 100 / 200 per page
             and step through; the filter querystring is preserved so paging
             never drops the active status/language/type filter. -->
        <div class="pagination-bar" style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap; margin-top:1rem;">
          <div style="color:var(--gray-600); font-size:0.9rem;">
            Showing <strong><%= pagination.from %></strong>–<strong><%= pagination.to %></strong> of <strong><%= pagination.totalItems.toLocaleString() %></strong>
          </div>
          <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.9rem;">
            <label for="perPageSelect" style="color:var(--gray-600);">Per page</label>
            <select id="perPageSelect" class="form-input" style="width:auto; padding:0.25rem 0.5rem;">
              <% pagination.perPageChoices.forEach(function (n) { %>
                <option value="<%= n %>" <%= pagination.perPage === n ? 'selected' : '' %>><%= n %></option>
              <% }); %>
            </select>
          </div>
          <%
            // Build a filter-preserving querystring for the page links.
            var qs = function (p) {
              var parts = [];
              if (filters.status) parts.push('status=' + encodeURIComponent(filters.status));
              if (filters.lang) parts.push('lang=' + encodeURIComponent(filters.lang));
              if (filters.entity_type) parts.push('entity_type=' + encodeURIComponent(filters.entity_type));
              parts.push('per_page=' + pagination.perPage);
              parts.push('page=' + p);
              return '/translations?' + parts.join('&');
            };
          %>
          <div style="margin-left:auto; display:flex; align-items:center; gap:0.5rem;">
            <% if (pagination.page > 1) { %>
              <a class="btn btn-sm btn-secondary" href="<%= qs(pagination.page - 1) %>"><i class="fas fa-chevron-left"></i> Prev</a>
            <% } else { %>
              <span class="btn btn-sm btn-secondary" style="opacity:0.5; pointer-events:none;"><i class="fas fa-chevron-left"></i> Prev</span>
            <% } %>
            <span style="font-size:0.9rem; color:var(--gray-600);">Page <%= pagination.page %> / <%= pagination.totalPages %></span>
            <% if (pagination.page < pagination.totalPages) { %>
              <a class="btn btn-sm btn-secondary" href="<%= qs(pagination.page + 1) %>">Next <i class="fas fa-chevron-right"></i></a>
            <% } else { %>
              <span class="btn btn-sm btn-secondary" style="opacity:0.5; pointer-events:none;">Next <i class="fas fa-chevron-right"></i></span>
            <% } %>
          </div>
        </div>
        <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="fas fa-language"></i></div>
          <h3>No Translations Yet</h3>
          <p>Run "Sync Site Pages" to import the website pages, and "Sync Content" for database content (articles, glossary, products, guides).</p>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Pre-run options for the AI batch: which languages and content types,
       how many rows of real model work this run, and how Lao sources are
       chosen. Live counts come from /translations/ai-batch/preview. -->
  <div id="aiModal" hidden style="position:fixed; inset:0; background:rgba(15,23,42,0.55); z-index:1000;">
    <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; padding:1rem;">
      <div style="background:var(--white,#fff); border-radius:10px; max-width:580px; width:100%; max-height:90vh; overflow:auto; padding:1.25rem 1.5rem; box-shadow:0 20px 60px rgba(0,0,0,0.3);">
        <h3 style="margin:0 0 0.25rem;"><i class="fas fa-robot"></i> Run AI translation batch</h3>
        <p style="margin:0 0 1rem; color:var(--gray-500); font-size:0.85rem;">
          Drafts are unpaid machine translations that land in "requires review" for a human to check.
          Rows owned by human translators are never touched.
        </p>

        <div style="margin-bottom:0.9rem;">
          <div style="font-size:0.75rem; text-transform:uppercase; color:var(--gray-500); margin-bottom:0.35rem;">Languages</div>
          <div style="display:flex; gap:1rem; flex-wrap:wrap;">
            <% languages.forEach(function (l) { %>
              <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;">
                <input type="checkbox" class="ai-lang" value="<%= l %>" checked> <%= languageNames[l] || l %>
              </label>
            <% }); %>
          </div>
        </div>

        <div id="aiLaoBox" style="margin-bottom:0.9rem; padding:0.6rem 0.75rem; border:1px solid var(--gray-200); border-radius:8px; background:var(--gray-50,#f9fafb); font-size:0.85rem;">
          <div style="margin-bottom:0.4rem;">
            <i class="fas fa-route"></i> <strong>Lao source strategy:</strong> English → Lao, with the entity's
            <em>verified Thai</em> attached as a style reference when one exists.
            Where Thai and English diverge, the English wins.
          </div>
          <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;">
            <input type="checkbox" id="aiLaoStrict"> Only draft Lao rows that already have a verified Thai (skip the rest for now)
          </label>
        </div>

        <div style="margin-bottom:0.9rem;">
          <div style="font-size:0.75rem; text-transform:uppercase; color:var(--gray-500); margin-bottom:0.35rem;">Content types</div>
          <div style="display:flex; gap:0.5rem 1rem; flex-wrap:wrap;">
            <% entityTypes.forEach(function (t) { %>
              <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;">
                <input type="checkbox" class="ai-type" value="<%= t %>" checked> <%= t.replace(/_/g, ' ') %>
              </label>
            <% }); %>
          </div>
        </div>

        <div style="margin-bottom:0.9rem;">
          <div style="font-size:0.75rem; text-transform:uppercase; color:var(--gray-500); margin-bottom:0.35rem;">Batch size — rows of real model work this run</div>
          <div style="display:flex; gap:1rem; flex-wrap:wrap;">
            <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;"><input type="radio" name="aiLimit" value="25"> 25</label>
            <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;"><input type="radio" name="aiLimit" value="50" checked> 50</label>
            <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;"><input type="radio" name="aiLimit" value="100"> 100</label>
            <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer;"><input type="radio" name="aiLimit" value="all"> All remaining (up to 500)</label>
          </div>
          <div style="font-size:0.78rem; color:var(--gray-500); margin-top:0.3rem;">
            Already-drafted rows are skipped without using up the batch — the cap counts only rows actually sent to the model.
            A capped run reports what's left and can simply be run again.
          </div>
        </div>

        <label style="display:flex; gap:0.4rem; align-items:center; cursor:pointer; margin-bottom:0.9rem;">
          <input type="checkbox" id="aiForce"> Re-draft even where the English source is unchanged (force)
        </label>

        <div id="aiPreviewLine" style="min-height:2.2em; font-size:0.85rem; color:var(--gray-600); border-top:1px solid var(--gray-200); padding-top:0.75rem;">
          <i class="fas fa-spinner fa-spin"></i> Counting queued rows…
        </div>

        <div style="display:flex; gap:0.75rem; justify-content:flex-end; margin-top:0.75rem;">
          <button type="button" class="btn btn-secondary" id="aiCancelBtn">Cancel</button>
          <button type="button" class="btn btn-primary" id="aiStartBtn"><i class="fas fa-robot"></i> Start batch</button>
        </div>
      </div>
    </div>
  </div>
</main>

<script nonce="<%= cspNonce %>">
(function () {
  var csrf = document.querySelector('meta[name="csrf-token"]').content;

  function post(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': csrf
      },
      body: JSON.stringify(body || {})
    }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); });
  }

  document.getElementById('syncBtn').addEventListener('click', function () {
    if (!confirm('Scan articles, glossary, SEO terms, guides and products for new or changed English content and (re)queue translations? Existing work is never overwritten.')) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Syncing…';
    post('/translations/sync').then(function (res) {
      if (res.ok) {
        alert('Sync complete: ' + res.data.summary.created + ' created, ' + res.data.summary.stale + ' re-opened (source changed), ' + res.data.summary.scanned + ' entities scanned.');
        location.reload();
      } else {
        alert(res.data.error || 'Sync failed');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-rotate"></i> Sync Content';
      }
    });
  });

  // Import every public website page as translatable content. Can take up
  // to a minute on deployments that fetch the live site page-by-page.
  document.getElementById('syncPagesBtn').addEventListener('click', function () {
    if (!confirm('Import all public website pages (homepage, services, prices, company, legal, glossary pages…) into the translation pipeline? This can take up to a minute.')) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Importing pages…';
    post('/translations/sync-pages').then(function (res) {
      if (res.ok) {
        var s = res.data.summary, t = res.data.translations;
        alert('Site pages imported (' + s.mode + '): ' + s.upserted + ' pages, ' +
          t.created + ' new translation rows, ' + t.stale + ' re-opened' +
          (s.failed ? ', ' + s.failed + ' pages failed to fetch' : '') + '.');
        location.reload();
      } else {
        alert(res.data.error || 'Site page import failed');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-file-import"></i> Sync Site Pages';
      }
    });
  });

  // AI batch: pre-run options modal. Language and content-type choices
  // drive a live count from /ai-batch/preview so the operator sees what a
  // run will actually pick up before committing to it.
  var LANG_NAMES = <%- JSON.stringify(languageNames).replace(/</g, '\\u003c') %>;
  var aiBtn = document.getElementById('aiBatchBtn');
  var aiModal = document.getElementById('aiModal');
  if (aiBtn && !aiBtn.disabled && aiModal) {
    function aiChecked(sel) {
      return Array.prototype.map.call(document.querySelectorAll(sel + ':checked'), function (c) { return c.value; });
    }
    function aiCap() {
      var v = document.querySelector('input[name="aiLimit"]:checked').value;
      return v === 'all' ? 500 : parseInt(v, 10);
    }
    function refreshLaoBox() {
      document.getElementById('aiLaoBox').hidden = aiChecked('.ai-lang').indexOf('la') === -1;
    }
    function refreshPreview() {
      var langs = aiChecked('.ai-lang'), types = aiChecked('.ai-type');
      var el = document.getElementById('aiPreviewLine');
      if (!langs.length || !types.length) {
        el.textContent = 'Pick at least one language and one content type.';
        return;
      }
      el.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Counting queued rows…';
      fetch('/translations/ai-batch/preview?languages=' + langs.join(',') + '&entity_types=' + types.join(','),
        { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          if (!d.success) { el.textContent = 'Could not count queued rows.'; return; }
          var total = 0, queued = 0, laoThai = null;
          var perLang = d.preview.map(function (p) {
            total += p.candidates; queued += p.queued;
            if (p.lang === 'la') laoThai = p.with_thai;
            return (LANG_NAMES[p.lang] || p.lang) + ' ' + p.candidates;
          });
          if (total === 0) {
            el.textContent = 'Nothing queued for this selection — the pipeline is clear.';
            return;
          }
          var work = Math.min(aiCap(), total);
          var mins = Math.max(1, Math.round(work * 5 / 60));
          el.textContent = 'Will scan ' + total + ' candidate row(s): ' + perLang.join(' · ') +
            (laoThai !== null ? ' — ' + laoThai + ' Lao row(s) have a verified Thai reference' : '') + '. ' +
            (total - queued) + ' already drafted (re-drawn only if the English changed). ' +
            'Rough estimate: ~' + mins + ' min for up to ' + work + ' drafted row(s); API cost scales with content length.';
        })
        .catch(function () { el.textContent = 'Could not count queued rows.'; });
    }
    aiBtn.addEventListener('click', function () {
      aiModal.hidden = false;
      refreshLaoBox();
      refreshPreview();
    });
    document.getElementById('aiCancelBtn').addEventListener('click', function () { aiModal.hidden = true; });
    aiModal.addEventListener('click', function (e) { if (e.target === aiModal) aiModal.hidden = true; });
    Array.prototype.forEach.call(document.querySelectorAll('.ai-lang, .ai-type, input[name="aiLimit"]'), function (el) {
      el.addEventListener('change', function () { refreshLaoBox(); refreshPreview(); });
    });
    document.getElementById('aiStartBtn').addEventListener('click', function () {
      var langs = aiChecked('.ai-lang'), types = aiChecked('.ai-type');
      if (!langs.length || !types.length) { alert('Pick at least one language and one content type.'); return; }
      var limitVal = document.querySelector('input[name="aiLimit"]:checked').value;
      var startBtn = this;
      startBtn.disabled = true;
      post('/translations/ai-batch', {
        languages: langs,
        entity_types: types,
        limit: limitVal === 'all' ? 'all' : parseInt(limitVal, 10),
        force: document.getElementById('aiForce').checked,
        lao_pivot_strict: document.getElementById('aiLaoStrict').checked
      }).then(function (res) {
        startBtn.disabled = false;
        if (res.ok) {
          aiModal.hidden = true;
          jobWasRunning = true; pollCount = 0; pollJob();
        } else {
          alert(res.data.error || 'Could not start batch');
        }
      });
    });
  }

  // Human-readable completion line: skips are explained, not just counted,
  // and a capped run says how much is left and how to continue.
  var SKIP_LABELS = {
    unchanged: 'already drafted, source unchanged',
    no_source: 'source content missing',
    claimed: 'claimed by a human mid-run',
    awaiting_thai: 'awaiting verified Thai'
  };
  function jobSummary(job) {
    var skipBits = [];
    var reasons = job.skipReasons || {};
    Object.keys(reasons).forEach(function (k) {
      if (reasons[k] > 0) skipBits.push(reasons[k] + ' ' + (SKIP_LABELS[k] || k.replace(/_/g, ' ')));
    });
    var text = 'AI batch ' + job.status + ': ' + job.translated + ' translated' +
      (job.pivoted ? ' (' + job.pivoted + ' via Thai reference)' : '') +
      ', ' + job.skipped + ' skipped' + (skipBits.length ? ' (' + skipBits.join('; ') + ')' : '') +
      ', ' + job.failed + ' failed.';
    if (job.capped) text += ' Batch cap reached — about ' + job.remaining + ' row(s) left; run again to continue.';
    return text;
  }

  // Status polling: 5s at first, backing off to 15s after two minutes,
  // and paused entirely while the tab is hidden — long batches must never
  // burn the rate-limit budget from a forgotten background tab.
  var pollCount = 0;
  function pollDelay() { return pollCount > 24 ? 15000 : 5000; }
  function schedulePoll() {
    if (document.hidden) return; // resumed by visibilitychange below
    setTimeout(pollJob, pollDelay());
  }
  function pollJob() {
    if (document.hidden) return;
    pollCount += 1;
    fetch('/translations/ai-batch/status', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var el = document.getElementById('aiJobStatus');
        if (d.job && d.job.status === 'running') {
          el.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI batch: ' + d.job.processed + '/' + d.job.total +
            ' scanned · ' + d.job.translated + ' drafted';
          schedulePoll();
        } else if (d.job) {
          el.textContent = jobSummary(d.job);
        }
      })
      .catch(function () { schedulePoll(); });
  }
  var jobWasRunning = <%= aiJob && aiJob.status === 'running' ? 'true' : 'false' %>;
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && jobWasRunning) pollJob();
  });
  <% if (aiJob && aiJob.status === 'running') { %>pollJob();<% } %>

  var publishVerifiedBtn = document.getElementById('publishVerifiedBtn');
  if (publishVerifiedBtn) publishVerifiedBtn.addEventListener('click', function () {
    if (!confirm('Publish everything the verifiers have signed off? Translator and verifier payouts are credited per configured rates.')) return;
    var btn = this;
    btn.disabled = true;
    post('/translations/publish-verified', {}).then(function (res) {
      if (res.ok) {
        alert('Published ' + res.data.published + ' translation(s)' + (res.data.errors.length ? ', ' + res.data.errors.length + ' failed' : '') + '.');
        location.reload();
      } else {
        btn.disabled = false;
        alert(res.data.error || 'Bulk publish failed');
      }
    });
  });

  // Bulk assignment: loops the checked rows through the existing per-row
  // endpoints; the server enforces language/self-verification/status per
  // row, so partial success reports honestly instead of failing the batch.
  function checkedIds() {
    return Array.prototype.map.call(document.querySelectorAll('.row-check:checked'), function (c) { return c.value; });
  }
  function refreshBulkBar() {
    var n = checkedIds().length;
    var bar = document.getElementById('bulkBar');
    if (bar) { bar.hidden = n === 0; document.getElementById('bulkCount').textContent = n; }
  }
  var selectAll = document.getElementById('selectAll');
  if (selectAll) selectAll.addEventListener('change', function () {
    document.querySelectorAll('.row-check').forEach(function (c) { c.checked = selectAll.checked; });
    refreshBulkBar();
  });
  document.querySelectorAll('.row-check').forEach(function (c) { c.addEventListener('change', refreshBulkBar); });

  function bulkRun(pathFor, body) {
    var ids = checkedIds();
    var worker = document.getElementById('bulkWorker').value;
    if (!worker) return alert('Choose a worker first.');
    if (!ids.length) return;
    var done = 0, ok = 0, skipped = [];
    var btns = [document.getElementById('bulkAssignBtn'), document.getElementById('bulkVerifyBtn')];
    btns.forEach(function (b) { b.disabled = true; });
    function next() {
      if (done >= ids.length) {
        btns.forEach(function (b) { b.disabled = false; });
        alert(ok + ' of ' + ids.length + ' assigned.' + (skipped.length ? '\n\nSkipped:\n' + skipped.join('\n') : ''));
        if (ok) location.reload();
        return;
      }
      var rowId = ids[done++];
      post('/translations/' + rowId + pathFor, body(worker)).then(function (res) {
        if (res.ok) ok++; else skipped.push((res.data.error || 'error') + ' (' + rowId.slice(0, 8) + ')');
        next();
      }).catch(function () { skipped.push('network error (' + rowId.slice(0, 8) + ')'); next(); });
    }
    next();
  }
  var bulkAssignBtn = document.getElementById('bulkAssignBtn');
  if (bulkAssignBtn) bulkAssignBtn.addEventListener('click', function () {
    bulkRun('/assign', function (w) { return { translator_id: w }; });
  });
  var bulkVerifyBtn = document.getElementById('bulkVerifyBtn');
  if (bulkVerifyBtn) bulkVerifyBtn.addEventListener('click', function () {
    bulkRun('/assign-verifier', function (w) { return { verifier_id: w }; });
  });

  document.querySelectorAll('.assign-select').forEach(function (select) {
    select.addEventListener('change', function () {
      if (!this.value) return;
      post('/translations/' + this.dataset.id + '/assign', { translator_id: this.value }).then(function (res) {
        if (res.ok) location.reload(); else alert(res.data.error || 'Assign failed');
      });
    });
  });

  // Send a drafted (AI or human) translation to a chosen verifier.
  document.querySelectorAll('.verifier-select').forEach(function (select) {
    select.addEventListener('change', function () {
      if (!this.value) return;
      post('/translations/' + this.dataset.id + '/assign-verifier', { verifier_id: this.value }).then(function (res) {
        if (res.ok) location.reload(); else alert(res.data.error || 'Assign failed');
      });
    });
  });

  // Batch size selector: reset to page 1 at the new size, keeping filters.
  var perPageSelect = document.getElementById('perPageSelect');
  if (perPageSelect) perPageSelect.addEventListener('change', function () {
    var url = new URL(window.location.href);
    url.searchParams.set('per_page', this.value);
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
  });
})();
</script>

<%- include('../partials/footer') %>

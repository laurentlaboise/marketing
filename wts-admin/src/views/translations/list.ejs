<%- include('../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Translations</h1>
        <p class="page-subtitle">Localization pipeline — /en /th /la /fr</p>
      </div>
      <div class="page-actions">
        <button type="button" class="btn btn-secondary" id="syncPagesBtn" title="Import every public website page (homepage, services, prices, company, legal, glossary pages…) as translatable content">
          <i class="fas fa-file-import"></i> Sync Site Pages
        </button>
        <button type="button" class="btn btn-secondary" id="syncBtn" title="Create translation rows for database content (articles, glossary, products, guides) and flag stale ones">
          <i class="fas fa-rotate"></i> Sync Content
        </button>
        <button type="button" class="btn btn-primary" id="aiBatchBtn" <%= aiConfigured ? '' : 'disabled title="Set ANTHROPIC_API_KEY to enable"' %>>
          <i class="fas fa-robot"></i> Run AI Batch
        </button>
      </div>
    </div>

    <div class="card" style="margin-bottom: 1rem;">
      <div class="card-body" style="display:flex; gap:1.5rem; flex-wrap:wrap; align-items:center;">
        <% ['pending', 'translating', 'requires_review', 'verified', 'published', 'rejected'].forEach(s => { %>
          <a href="/translations?status=<%= s %>" style="text-decoration:none;">
            <strong><%= counts[s] || 0 %></strong> <%= s.replace('_', ' ') %>
          </a>
        <% }); %>
        <% if (counts.verified > 0) { %>
          <button type="button" class="btn btn-sm btn-primary" id="publishVerifiedBtn">
            <i class="fas fa-check-double"></i> Publish all verified (<%= counts.verified %>)
          </button>
        <% } %>
        <span id="aiJobStatus" style="margin-left:auto; color: var(--gray-500);">
          <% if (aiJob && aiJob.status === 'running') { %>
            <i class="fas fa-spinner fa-spin"></i> AI batch: <%= aiJob.processed %>/<%= aiJob.total %>
          <% } %>
        </span>
      </div>
    </div>

    <div class="card" style="margin-bottom: 1rem;">
      <div class="card-body">
        <form method="GET" action="/translations" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:end;">
          <div class="form-group" style="margin:0;">
            <label class="form-label" for="filterStatus">Status</label>
            <select class="form-input" id="filterStatus" name="status">
              <option value="">All</option>
              <% statuses.forEach(s => { %>
                <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.replace('_', ' ') %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label" for="filterLang">Language</label>
            <select class="form-input" id="filterLang" name="lang">
              <option value="">All</option>
              <% languages.forEach(l => { %>
                <option value="<%= l %>" <%= filters.lang === l ? 'selected' : '' %>><%= languageNames[l] || l %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label" for="filterEntity">Content type</label>
            <select class="form-input" id="filterEntity" name="entity_type">
              <option value="">All</option>
              <% entityTypes.forEach(t => { %>
                <option value="<%= t %>" <%= filters.entity_type === t ? 'selected' : '' %>><%= t %></option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn btn-secondary">Filter</button>
        </form>
      </div>
    </div>

    <div class="card">
      <div class="card-body" style="padding: 0;">
        <% if (items.length > 0) { %>
        <div class="table-container">
          <table class="table table-responsive-cards">
            <thead>
              <tr>
                <th>Content</th>
                <th>Language</th>
                <th>Status</th>
                <th>Translator</th>
                <th>Verifier</th>
                <th>Chars</th>
                <th>Updated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(item => { %>
              <tr>
                <td data-label="Content">
                  <span style="color:var(--gray-500);"><%= item.entity_type %></span>
                  <% if (item.entity_title || item.page_path) { %>
                    <strong><%= item.entity_title || item.page_path %></strong>
                  <% } else { %>
                    <code style="font-size:0.75rem;"><%= item.entity_id.slice(0, 8) %></code>
                  <% } %>
                </td>
                <td data-label="Language"><%= languageNames[item.target_language] || item.target_language %></td>
                <td data-label="Status">
                  <%
                    var statusColors = { pending: '#6b7280', translating: '#2563eb', requires_review: '#d97706', published: '#059669', rejected: '#dc2626' };
                  %>
                  <span style="display:inline-block; padding:0.15rem 0.5rem; border-radius:999px; font-size:0.75rem; color:#fff; background:<%= statusColors[item.status] || '#6b7280' %>;">
                    <%= item.status.replace('_', ' ') %>
                  </span>
                </td>
                <td data-label="Translator">
                  <% if (item.translator_id) { %>
                    <%= item.translator_first_name || '' %> <%= item.translator_last_name || '' %>
                  <% } else if (item.ai_model) { %>
                    <i class="fas fa-robot" title="<%= item.ai_model %>"></i> AI
                  <% } else { %>
                    <select class="form-input assign-select" data-id="<%= item.id %>" style="max-width:180px; padding:0.25rem;">
                      <option value="">Assign…</option>
                      <% translators.filter(t => (t.assigned_languages || []).includes(item.target_language)).forEach(t => { %>
                        <option value="<%= t.id %>"><%= t.first_name %> <%= t.last_name || '' %></option>
                      <% }); %>
                    </select>
                  <% } %>
                </td>
                <td data-label="Verifier">
                  <% if (item.verifier_id) { %>
                    <%= item.verifier_first_name || '' %> <%= item.verifier_last_name || '' %>
                  <% } else if (item.status === 'requires_review') { %>
                    <%
                      // Push a drafted row to a specific verifier: same-language
                      // translators, never the row's own translator (no
                      // self-verification). AI rows (no translator_id) can go
                      // to anyone assigned the language.
                      var eligibleVerifiers = translators.filter(function (t) {
                        return (t.assigned_languages || []).includes(item.target_language)
                          && String(t.id) !== String(item.translator_id || '');
                      });
                    %>
                    <% if (eligibleVerifiers.length) { %>
                      <select class="form-input verifier-select" data-id="<%= item.id %>" style="max-width:170px; padding:0.25rem;">
                        <option value="">Send to verify…</option>
                        <% eligibleVerifiers.forEach(function (t) { %>
                          <option value="<%= t.id %>"><%= t.first_name %> <%= t.last_name || '' %></option>
                        <% }); %>
                      </select>
                    <% } else { %>
                      <span style="color:var(--gray-400);">—</span>
                    <% } %>
                  <% } else { %>
                    <span style="color:var(--gray-400);">—</span>
                  <% } %>
                </td>
                <td data-label="Chars"><%= item.target_char_count ? Number(item.target_char_count).toLocaleString() : '-' %></td>
                <td data-label="Updated"><%= new Date(item.updated_at).toLocaleDateString() %></td>
                <td data-label="Actions">
                  <a href="/translations/review/<%= item.id %>" class="btn btn-sm btn-secondary"><i class="fas fa-eye"></i> Review</a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Batch navigation (Gmail-style): choose 50 / 100 / 200 per page
             and step through; the filter querystring is preserved so paging
             never drops the active status/language/type filter. -->
        <div class="pagination-bar" style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap; margin-top:1rem;">
          <div style="color:var(--gray-600); font-size:0.9rem;">
            Showing <strong><%= pagination.from %></strong>–<strong><%= pagination.to %></strong> of <strong><%= pagination.totalItems.toLocaleString() %></strong>
          </div>
          <div style="display:flex; align-items:center; gap:0.4rem; font-size:0.9rem;">
            <label for="perPageSelect" style="color:var(--gray-600);">Per page</label>
            <select id="perPageSelect" class="form-input" style="width:auto; padding:0.25rem 0.5rem;">
              <% pagination.perPageChoices.forEach(function (n) { %>
                <option value="<%= n %>" <%= pagination.perPage === n ? 'selected' : '' %>><%= n %></option>
              <% }); %>
            </select>
          </div>
          <%
            // Build a filter-preserving querystring for the page links.
            var qs = function (p) {
              var parts = [];
              if (filters.status) parts.push('status=' + encodeURIComponent(filters.status));
              if (filters.lang) parts.push('lang=' + encodeURIComponent(filters.lang));
              if (filters.entity_type) parts.push('entity_type=' + encodeURIComponent(filters.entity_type));
              parts.push('per_page=' + pagination.perPage);
              parts.push('page=' + p);
              return '/translations?' + parts.join('&');
            };
          %>
          <div style="margin-left:auto; display:flex; align-items:center; gap:0.5rem;">
            <% if (pagination.page > 1) { %>
              <a class="btn btn-sm btn-secondary" href="<%= qs(pagination.page - 1) %>"><i class="fas fa-chevron-left"></i> Prev</a>
            <% } else { %>
              <span class="btn btn-sm btn-secondary" style="opacity:0.5; pointer-events:none;"><i class="fas fa-chevron-left"></i> Prev</span>
            <% } %>
            <span style="font-size:0.9rem; color:var(--gray-600);">Page <%= pagination.page %> / <%= pagination.totalPages %></span>
            <% if (pagination.page < pagination.totalPages) { %>
              <a class="btn btn-sm btn-secondary" href="<%= qs(pagination.page + 1) %>">Next <i class="fas fa-chevron-right"></i></a>
            <% } else { %>
              <span class="btn btn-sm btn-secondary" style="opacity:0.5; pointer-events:none;">Next <i class="fas fa-chevron-right"></i></span>
            <% } %>
          </div>
        </div>
        <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="fas fa-language"></i></div>
          <h3>No Translations Yet</h3>
          <p>Run "Sync Site Pages" to import the website pages, and "Sync Content" for database content (articles, glossary, products, guides).</p>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<script nonce="<%= cspNonce %>">
(function () {
  var csrf = document.querySelector('meta[name="csrf-token"]').content;

  function post(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'X-CSRF-Token': csrf
      },
      body: JSON.stringify(body || {})
    }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); });
  }

  document.getElementById('syncBtn').addEventListener('click', function () {
    if (!confirm('Scan articles, glossary, SEO terms, guides and products for new or changed English content and (re)queue translations? Existing work is never overwritten.')) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Syncing…';
    post('/translations/sync').then(function (res) {
      if (res.ok) {
        alert('Sync complete: ' + res.data.summary.created + ' created, ' + res.data.summary.stale + ' re-opened (source changed), ' + res.data.summary.scanned + ' entities scanned.');
        location.reload();
      } else {
        alert(res.data.error || 'Sync failed');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-rotate"></i> Sync Content';
      }
    });
  });

  // Import every public website page as translatable content. Can take up
  // to a minute on deployments that fetch the live site page-by-page.
  document.getElementById('syncPagesBtn').addEventListener('click', function () {
    if (!confirm('Import all public website pages (homepage, services, prices, company, legal, glossary pages…) into the translation pipeline? This can take up to a minute.')) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Importing pages…';
    post('/translations/sync-pages').then(function (res) {
      if (res.ok) {
        var s = res.data.summary, t = res.data.translations;
        alert('Site pages imported (' + s.mode + '): ' + s.upserted + ' pages, ' +
          t.created + ' new translation rows, ' + t.stale + ' re-opened' +
          (s.failed ? ', ' + s.failed + ' pages failed to fetch' : '') + '.');
        location.reload();
      } else {
        alert(res.data.error || 'Site page import failed');
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-file-import"></i> Sync Site Pages';
      }
    });
  });

  var aiBtn = document.getElementById('aiBatchBtn');
  if (aiBtn && !aiBtn.disabled) {
    aiBtn.addEventListener('click', function () {
      if (!confirm('Run the AI translation batch for Thai and French now?')) return;
      post('/translations/ai-batch', {}).then(function (res) {
        if (res.ok) { jobWasRunning = true; pollCount = 0; pollJob(); } else { alert(res.data.error || 'Could not start batch'); }
      });
    });
  }

  // Status polling: 5s at first, backing off to 15s after two minutes,
  // and paused entirely while the tab is hidden — long batches must never
  // burn the rate-limit budget from a forgotten background tab.
  var pollCount = 0;
  function pollDelay() { return pollCount > 24 ? 15000 : 5000; }
  function schedulePoll() {
    if (document.hidden) return; // resumed by visibilitychange below
    setTimeout(pollJob, pollDelay());
  }
  function pollJob() {
    if (document.hidden) return;
    pollCount += 1;
    fetch('/translations/ai-batch/status', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        var el = document.getElementById('aiJobStatus');
        if (d.job && d.job.status === 'running') {
          el.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI batch: ' + d.job.processed + '/' + d.job.total;
          schedulePoll();
        } else if (d.job) {
          el.textContent = 'AI batch ' + d.job.status + ': ' + d.job.translated + ' translated, ' + d.job.skipped + ' skipped, ' + d.job.failed + ' failed';
        }
      })
      .catch(function () { schedulePoll(); });
  }
  var jobWasRunning = <%= aiJob && aiJob.status === 'running' ? 'true' : 'false' %>;
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden && jobWasRunning) pollJob();
  });
  <% if (aiJob && aiJob.status === 'running') { %>pollJob();<% } %>

  var publishVerifiedBtn = document.getElementById('publishVerifiedBtn');
  if (publishVerifiedBtn) publishVerifiedBtn.addEventListener('click', function () {
    if (!confirm('Publish everything the verifiers have signed off? Translator and verifier payouts are credited per configured rates.')) return;
    var btn = this;
    btn.disabled = true;
    post('/translations/publish-verified', {}).then(function (res) {
      if (res.ok) {
        alert('Published ' + res.data.published + ' translation(s)' + (res.data.errors.length ? ', ' + res.data.errors.length + ' failed' : '') + '.');
        location.reload();
      } else {
        btn.disabled = false;
        alert(res.data.error || 'Bulk publish failed');
      }
    });
  });

  document.querySelectorAll('.assign-select').forEach(function (select) {
    select.addEventListener('change', function () {
      if (!this.value) return;
      post('/translations/' + this.dataset.id + '/assign', { translator_id: this.value }).then(function (res) {
        if (res.ok) location.reload(); else alert(res.data.error || 'Assign failed');
      });
    });
  });

  // Send a drafted (AI or human) translation to a chosen verifier.
  document.querySelectorAll('.verifier-select').forEach(function (select) {
    select.addEventListener('change', function () {
      if (!this.value) return;
      post('/translations/' + this.dataset.id + '/assign-verifier', { verifier_id: this.value }).then(function (res) {
        if (res.ok) location.reload(); else alert(res.data.error || 'Assign failed');
      });
    });
  });

  // Batch size selector: reset to page 1 at the new size, keeping filters.
  var perPageSelect = document.getElementById('perPageSelect');
  if (perPageSelect) perPageSelect.addEventListener('change', function () {
    var url = new URL(window.location.href);
    url.searchParams.set('per_page', this.value);
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
  });
})();
</script>

<%- include('../partials/footer') %>

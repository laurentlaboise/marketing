<%- include('../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title">Team &amp; Vendors</h1>
        <p class="page-subtitle">Invite workers, set roles, languages, positions (from the role briefs), team structure and payability.</p>
      </div>
    </div>

    <!-- Invite a new worker: the onboarding path — creates a translator
         account and hands you a set-password link (emailed too when the
         mailer is configured). -->
    <div class="card" style="margin-bottom:1rem;">
      <div class="card-body">
        <h3 style="margin:0 0 0.75rem;"><i class="fas fa-user-plus"></i> Invite a Worker</h3>
        <form id="inviteForm" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:end;">
          <div class="form-group" style="margin:0;">
            <label class="form-label">Email *</label>
            <input class="form-input" name="email" type="email" required placeholder="worker@example.com" style="min-width:220px;">
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label">First name</label>
            <input class="form-input" name="first_name" style="max-width:140px;">
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label">Last name</label>
            <input class="form-input" name="last_name" style="max-width:140px;">
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label">Languages</label>
            <span style="display:inline-flex; gap:0.6rem; padding:0.45rem 0;">
              <% languages.forEach(l => { %>
                <label style="font-weight:normal; display:inline-flex; gap:0.25rem; align-items:center;">
                  <input type="checkbox" name="invite_lang" value="<%= l %>"> <%= languageNames[l] || l %>
                </label>
              <% }); %>
            </span>
          </div>
          <div class="form-group" style="margin:0;">
            <label class="form-label">Position</label>
            <select class="form-input" name="position">
              <option value="">—</option>
              <% positions.forEach(p => { %><option value="<%= p %>"><%= p.replace(/_/g, ' ') %></option><% }); %>
            </select>
          </div>
          <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Invite</button>
        </form>
        <p style="color:var(--gray-500); font-size:0.8rem; margin:0.5rem 0 0;">
          The invite creates a worker account and a set-password link (valid 7 days). The link is emailed when
          email is configured, and always shown to you so you can share it over WhatsApp/LINE.
        </p>
      </div>
    </div>

    <div class="card">
      <div class="card-body" style="padding: 0;">
        <div class="table-container">
          <table class="table table-responsive-cards">
            <thead>
              <tr>
                <th>User</th>
                <th>Role</th>
                <th>Position</th>
                <th>Manager</th>
                <th>Languages</th>
                <th>Payable Vendor</th>
                <th>Payout Method</th>
                <th>Available</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => {
                   var isAdminAccount = ['admin', 'superadmin'].includes(u.role); %>
              <tr data-user="<%= u.id %>">
                <td data-label="User">
                  <strong><%= u.first_name || '' %> <%= u.last_name || '' %></strong><br>
                  <span style="color:var(--gray-500); font-size:0.85rem;"><%= u.email %></span>
                </td>
                <td data-label="Role">
                  <% if (isAdminAccount) { %>
                    <span style="font-weight:600;"><%= u.role %></span>
                  <% } else { %>
                    <select class="form-input role-select" style="max-width:130px; padding:0.25rem;">
                      <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                      <option value="translator" <%= u.role === 'translator' ? 'selected' : '' %>>translator</option>
                    </select>
                  <% } %>
                </td>
                <td data-label="Position">
                  <% if (isAdminAccount) { %>
                    —
                  <% } else { %>
                    <select class="form-input position-select" style="max-width:190px; padding:0.25rem;">
                      <option value="">none</option>
                      <% positions.forEach(p => { %>
                        <option value="<%= p %>" <%= u.position === p ? 'selected' : '' %>><%= p.replace(/_/g, ' ') %></option>
                      <% }); %>
                    </select>
                  <% } %>
                </td>
                <td data-label="Manager">
                  <% if (isAdminAccount) { %>
                    —
                  <% } else { %>
                    <select class="form-input manager-select" style="max-width:170px; padding:0.25rem;">
                      <option value="">none</option>
                      <% users.filter(m => m.id !== u.id && (m.role === 'translator' || m.is_vendor || ['admin','superadmin'].includes(m.role))).forEach(m => { %>
                        <option value="<%= m.id %>" <%= u.manager_id === m.id ? 'selected' : '' %>><%= m.first_name %> <%= m.last_name || '' %></option>
                      <% }); %>
                    </select>
                  <% } %>
                </td>
                <td data-label="Languages">
                  <% if (isAdminAccount) { %>
                    <span style="color:var(--gray-500);">all</span>
                  <% } else { %>
                    <% languages.forEach(l => { %>
                      <label style="margin-right:0.75rem; white-space:nowrap;">
                        <input type="checkbox" class="lang-check" value="<%= l %>"
                          <%= (u.assigned_languages || []).includes(l) ? 'checked' : '' %>>
                        <%= languageNames[l] || l %>
                      </label>
                    <% }); %>
                  <% } %>
                </td>
                <td data-label="Payable Vendor">
                  <% if (isAdminAccount) { %>
                    —
                  <% } else { %>
                    <input type="checkbox" class="vendor-check" <%= u.is_vendor ? 'checked' : '' %> title="Publishing their work credits the payout ledger">
                  <% } %>
                </td>
                <td data-label="Payout Method">
                  <% if (u.payout && u.payout.configured) { %>
                    <%= u.payout.gateway %> <span style="color:var(--gray-500);"><%= u.payout.label %></span>
                  <% } else { %>
                    <span style="color:var(--gray-500);">not set</span>
                  <% } %>
                </td>
                <td data-label="Available">
                  <% if (u.balances.length === 0) { %>—<% } else { u.balances.forEach(b => { %>
                    <div><%= b.currency %> <%= b.currency === 'LAK' ? Math.round(parseFloat(b.available)).toLocaleString() : parseFloat(b.available).toFixed(2) %></div>
                  <% }); } %>
                </td>
                <td data-label="Actions">
                  <% if (!isAdminAccount) { %>
                    <button type="button" class="btn btn-sm btn-primary save-user"><i class="fas fa-save"></i> Save</button>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<script nonce="<%= cspNonce %>">
(function () {
  var csrf = document.querySelector('meta[name="csrf-token"]').content;

  var inviteForm = document.getElementById('inviteForm');
  if (inviteForm) inviteForm.addEventListener('submit', function (e) {
    e.preventDefault();
    var submitBtn = inviteForm.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    var langs = Array.prototype.map.call(inviteForm.querySelectorAll('input[name="invite_lang"]:checked'), function (c) { return c.value; });
    var body = {
      email: inviteForm.querySelector('[name="email"]').value.trim(),
      first_name: inviteForm.querySelector('[name="first_name"]').value.trim(),
      last_name: inviteForm.querySelector('[name="last_name"]').value.trim(),
      assigned_languages: langs,
      position: inviteForm.querySelector('[name="position"]').value
    };
    fetch('/translations/vendors/invite', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(body)
    }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
      .then(function (res) {
        if (!res.ok) { submitBtn.disabled = false; return alert(res.data.error || 'Invite failed'); }
        prompt((res.data.emailed
          ? 'Invited! An email was sent. You can also share this set-password link directly:'
          : 'Invited! Email is not configured — share this set-password link with the worker:'), res.data.inviteLink);
        location.reload();
      })
      .catch(function () { submitBtn.disabled = false; alert('Invite failed: network error'); });
  });


  function post(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(body)
    }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); });
  }

  document.querySelectorAll('.save-user').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var row = btn.closest('tr');
      var id = row.dataset.user;
      btn.disabled = true;
      post('/translations/vendors/' + id, {
        role: row.querySelector('.role-select').value,
        assigned_languages: Array.prototype.slice.call(row.querySelectorAll('.lang-check:checked')).map(function (c) { return c.value; }),
        is_vendor: row.querySelector('.vendor-check').checked
      }).then(function (res) {
        if (!res.ok) throw new Error(res.data.error || 'Update failed');
        return post('/workforce/team/' + id, {
          position: row.querySelector('.position-select').value,
          manager_id: row.querySelector('.manager-select').value || null
        });
      }).then(function (res) {
        btn.disabled = false;
        if (res.ok) {
          btn.innerHTML = '<i class="fas fa-check"></i> Saved';
          setTimeout(function () { btn.innerHTML = '<i class="fas fa-save"></i> Save'; }, 1500);
        } else {
          alert(res.data.error || 'Team update failed');
        }
      }).catch(function (err) {
        btn.disabled = false;
        alert(err.message);
      });
    });
  });
})();
</script>

<%- include('../partials/footer') %>

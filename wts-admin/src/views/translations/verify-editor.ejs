<%- include('../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title"><%= source ? source.title : item.entity_type %></h1>
        <p class="page-subtitle">
          Verify: <%= entityConfig.label %> → <strong><%= languageNames[item.target_language] || item.target_language %></strong>
          · <%= item.ai_model ? 'AI draft (' + item.ai_model + ')' : 'human translation' %>
          · <span id="charCount"><%= targetChars %></span> characters
          <% if (item.status === 'verified') { %> · <strong>already verified</strong><% } %>
        </p>
      </div>
      <div class="page-actions">
        <a href="/translations/workspace" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
        <% if (!readOnly) { %>
        <button type="button" class="btn btn-secondary" id="saveBtn"><i class="fas fa-save"></i> Save Fixes</button>
        <button type="button" class="btn btn-primary" id="approveBtn"><i class="fas fa-check"></i> Approve</button>
        <button type="button" class="btn btn-danger" id="returnBtn" title="Needs a full re-translation, not a quick fix"><i class="fas fa-rotate-left"></i> Return</button>
        <% } %>
      </div>
    </div>

    <div class="alert alert-success" style="position:static; margin-bottom:1rem;">
      <i class="fas fa-circle-info"></i>
      <span>
        This is a sense-check, not a re-translation: confirm the text reads naturally and carries the
        meaning, fix light issues (phrasing, word choice, tone) directly in the right column, and
        <strong>Return</strong> anything that needs a full re-do. Verification pays per 1,000 characters read;
        segments you rework are compensated on top.
      </span>
    </div>

    <form id="verifyForm">
      <%
        var fieldList = entityConfig.dynamic
          ? Object.keys((source && source.fields) || item.content_payload || {})
          : entityConfig.fields;
        var segIndex = 0;
      %>
      <% fieldList.forEach(field => {
           var sourceValue = source && source.fields ? source.fields[field] : null;
           var targetValue = (item.content_payload && item.content_payload[field]) || '';
           if (!sourceValue && !targetValue) return;
           segIndex += 1;
           var fieldLabel = entityConfig.dynamic ? ('Segment ' + segIndex) : field.replace(/_/g, ' ');
           var isLong = String(targetValue || sourceValue || '').length > 300; %>
        <div class="card" style="margin-bottom:1rem;">
          <div class="card-body">
            <h3 style="margin:0 0 0.75rem; font-size:0.9rem; text-transform:uppercase; color:var(--gray-500);"><%= fieldLabel %></h3>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;">English source (reference)</div>
                <div style="border:1px solid var(--gray-200); border-radius:6px; padding:0.75rem; max-height:400px; overflow:auto; white-space:pre-wrap; background:var(--gray-50, #f9fafb);"><%= sourceValue || '—' %></div>
              </div>
              <div>
                <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;">
                  <%= languageNames[item.target_language] || item.target_language %> — fix directly if needed
                </div>
                <textarea
                  class="form-input verify-field"
                  name="<%= field %>"
                  rows="<%= isLong ? 14 : 3 %>"
                  style="width:100%; font-family:inherit; resize:vertical; line-height:1.7;"
                  <%= readOnly ? 'readonly' : '' %>><%= targetValue %></textarea>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </form>
  </div>
</main>

<script nonce="<%= cspNonce %>">
(function () {
  var csrf = document.querySelector('meta[name="csrf-token"]').content;
  var id = '<%= item.id %>';
  var dirty = false;

  document.querySelectorAll('.verify-field').forEach(function (field) {
    field.addEventListener('input', function () { dirty = true; });
  });
  window.addEventListener('beforeunload', function (e) {
    if (dirty) { e.preventDefault(); e.returnValue = ''; }
  });

  function collectPayload() {
    var payload = {};
    document.querySelectorAll('.verify-field').forEach(function (field) {
      payload[field.name] = field.value;
    });
    return payload;
  }

  function post(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(body || {})
    }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); });
  }

  var saveBtn = document.getElementById('saveBtn');
  if (saveBtn) saveBtn.addEventListener('click', function () {
    var btn = this;
    btn.disabled = true;
    post('/translations/verify/' + id + '/save', { content_payload: collectPayload() }).then(function (res) {
      btn.disabled = false;
      if (res.ok) {
        dirty = false;
        btn.innerHTML = '<i class="fas fa-check"></i> Saved (' + res.data.editedSegments + ' reworked)';
        setTimeout(function () { btn.innerHTML = '<i class="fas fa-save"></i> Save Fixes'; }, 2000);
      } else {
        alert(res.data.error || 'Save failed');
      }
    });
  });

  var approveBtn = document.getElementById('approveBtn');
  if (approveBtn) approveBtn.addEventListener('click', function () {
    if (!confirm('Approve this content for publication? Your verification (and any reworked segments) are credited when the admin publishes it.')) return;
    var btn = this;
    btn.disabled = true;
    post('/translations/verify/' + id + '/approve', { content_payload: collectPayload() }).then(function (res) {
      if (res.ok) {
        dirty = false;
        location.href = '/translations/workspace';
      } else {
        btn.disabled = false;
        alert(res.data.error || 'Approve failed');
      }
    });
  });

  var returnBtn = document.getElementById('returnBtn');
  if (returnBtn) returnBtn.addEventListener('click', function () {
    var note = prompt('What is wrong with this draft? (goes to the translator / re-translation queue)');
    if (note === null) return;
    post('/translations/verify/' + id + '/return', { note: note }).then(function (res) {
      if (res.ok) location.href = '/translations/workspace';
      else alert(res.data.error || 'Return failed');
    });
  });
})();
</script>

<%- include('../partials/footer') %>

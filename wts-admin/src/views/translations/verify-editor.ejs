<%- include('../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header">
      <div>
        <h1 class="page-title"><%= source ? source.title : item.entity_type %></h1>
        <p class="page-subtitle">
          Verify: <%= entityConfig.label %> → <strong><%= languageNames[item.target_language] || item.target_language %></strong>
          · <%= item.ai_model ? 'AI draft (' + item.ai_model + ')' : 'human translation' %>
          · <span id="charCount"><%= targetChars %></span> characters
          <span id="payEstimate" style="color:#059669;"></span>
          <% if (item.status === 'verified') { %> · <strong>already verified</strong><% } %>
        </p>
      </div>
      <div class="page-actions">
        <a href="/translations/workspace" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
        <% if (!readOnly) { %>
        <button type="button" class="btn btn-secondary" id="saveBtn"><i class="fas fa-save"></i> Save Fixes</button>
        <button type="button" class="btn btn-primary" id="approveBtn"><i class="fas fa-check"></i> Mark Verified</button>
        <button type="button" class="btn btn-danger" id="returnBtn" title="Needs a full re-translation, not a quick fix"><i class="fas fa-rotate-left"></i> Return for Redo</button>
        <% } %>
      </div>
    </div>

    <div class="alert alert-success" style="position:static; margin-bottom:1rem;">
      <i class="fas fa-circle-info"></i>
      <span>
        This is a sense-check, not a re-translation: confirm the text reads naturally and carries the
        meaning, fix light issues (phrasing, word choice, tone) directly in the right column, and
        <strong>Return</strong> anything that needs a full re-do.
        <% if (typeof verifyRate !== 'undefined' && verifyRate) { %>
          Verification pays <strong><%= (verifyRate.currency || 'USD') %> <%= verifyRate.currency === 'LAK' ? Math.round(parseFloat(verifyRate.rate_amount)).toLocaleString('en-US') : parseFloat(verifyRate.rate_amount).toFixed(2) %><%= verifyRate.rate_type === 'per_1000_chars' ? ' per 1,000 characters read' : (verifyRate.rate_type === 'per_word' ? ' per source word' : ' per item') %></strong>;
        <% } else { %>
          Verification pays per 1,000 characters read;
        <% } %>
        segments you rework are compensated on top. Work one section at a time — tick
        <strong>"Section verified"</strong> as you finish each one (it saves automatically), then press
        <strong>Mark Verified</strong> when the bar is full.
      </span>
    </div>

    <%
      // Same visible-card rule as the loop below — the progress numbers
      // must agree with what the page actually renders.
      var secStatus = item.section_status || {};
      var secKeys = (entityConfig.dynamic
        ? Object.keys((source && source.fields) || item.content_payload || {})
        : entityConfig.fields).filter(function (f) {
          var sv = source && source.fields ? source.fields[f] : null;
          var tv = item.content_payload && item.content_payload[f];
          return sv || tv;
        });
      var secDone = secKeys.filter(function (f) { return secStatus[f] && secStatus[f].verified; }).length;
    %>
    <!-- Sticky progress: the worker's finish line through a long item. -->
    <div style="position:sticky; top:0.5rem; z-index:40; background:var(--white,#fff); border:1px solid var(--gray-200); border-radius:8px; padding:0.5rem 1rem; margin-bottom:1rem; display:flex; align-items:center; gap:0.75rem; box-shadow:0 2px 8px rgba(0,0,0,0.06);">
      <i class="fas fa-list-check" style="color:var(--gray-500);"></i>
      <span style="font-size:0.9rem; white-space:nowrap;"><strong id="secDone"><%= secDone %></strong> of <strong id="secTotal"><%= secKeys.length %></strong> sections verified</span>
      <div style="flex:1; height:6px; background:var(--gray-200); border-radius:999px; overflow:hidden;">
        <div id="secBar" style="height:100%; width:<%= secKeys.length ? Math.round(secDone * 100 / secKeys.length) : 0 %>%; background:#059669; transition:width 0.25s;"></div>
      </div>
      <span id="saveToast" hidden style="font-size:0.78rem; color:#059669; white-space:nowrap;"><i class="fas fa-check"></i> Saved</span>
    </div>

    <!-- Termbase: terms the source mentions, with the approved name for
         this language. Presence re-checks live as the worker types. -->
    <div class="card" id="termPanel" hidden style="margin-bottom:1rem;">
      <div class="card-body">
        <h3 style="margin:0 0 0.5rem; font-size:0.9rem;"><i class="fas fa-book"></i> Glossary terms in this content</h3>
        <div id="termList" style="display:flex; flex-wrap:wrap; gap:0.5rem;"></div>
        <p style="margin:0.5rem 0 0; font-size:0.75rem; color:var(--gray-500);">
          Green = the approved name is used in your translation · red = missing. Using approved names keeps
          terminology consistent across the whole site.
        </p>
      </div>
    </div>

    <form id="verifyForm">
      <%
        var fieldList = entityConfig.dynamic
          ? Object.keys((source && source.fields) || item.content_payload || {})
          : entityConfig.fields;
        var segIndex = 0;
      %>
      <% fieldList.forEach(field => {
           var sourceValue = source && source.fields ? source.fields[field] : null;
           var targetValue = (item.content_payload && item.content_payload[field]) || '';
           if (!sourceValue && !targetValue) return;
           segIndex += 1;
           var fieldLabel = entityConfig.dynamic ? ('Segment ' + segIndex) : field.replace(/_/g, ' ');
           var isLong = String(targetValue || sourceValue || '').length > 300;
           var thaiValue = (typeof thaiRef !== 'undefined' && thaiRef && thaiRef.content_payload[field]) || null;
           var secV = Boolean(secStatus[field] && secStatus[field].verified); %>
        <div class="card sec-card" data-field="<%= field %>" style="margin-bottom:1rem;<%= secV ? ' border-left:4px solid #059669; opacity:0.88;' : '' %>">
          <div class="card-body">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; margin:0 0 0.75rem;">
              <h3 style="margin:0; font-size:0.9rem; text-transform:uppercase; color:var(--gray-500);"><%= fieldLabel %><%= secV ? ' ' : '' %><% if (secV) { %><i class="fas fa-circle-check" style="color:#059669;"></i><% } %></h3>
              <label class="sec-pill" data-for="<%= field %>" style="display:inline-flex; align-items:center; gap:0.35rem; font-size:0.8rem; padding:0.2rem 0.65rem; border-radius:999px; cursor:pointer; user-select:none; border:1px solid <%= secV ? '#059669' : 'var(--gray-300, #d1d5db)' %>; background:<%= secV ? '#d1fae5' : 'transparent' %>; color:<%= secV ? '#065f46' : 'var(--gray-600, #4b5563)' %>;">
                <input type="checkbox" class="sec-check" data-for="<%= field %>" <%= secV ? 'checked' : '' %> <%= readOnly ? 'disabled' : '' %> style="accent-color:#059669;">
                Section verified
              </label>
            </div>
            <div class="seg-grid">
              <div>
                <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;">English source (reference)</div>
                <div style="border:1px solid var(--gray-200); border-radius:6px; padding:0.75rem; max-height:400px; overflow:auto; white-space:pre-wrap; background:var(--gray-50, #f9fafb);"><%= sourceValue || '—' %></div>
              </div>
              <div>
                <div style="font-size:0.75rem; color:var(--gray-500); margin-bottom:0.25rem;">
                  <%= languageNames[item.target_language] || item.target_language %> — fix directly if needed
                </div>
                <textarea
                  class="form-input verify-field"
                  name="<%= field %>"
                  rows="<%= isLong ? 14 : 3 %>"
                  style="width:100%; font-family:inherit; resize:vertical; line-height:1.7;"
                  <%= (readOnly || secV) ? 'readonly' : '' %>><%= targetValue %></textarea>
                <div style="display:flex; gap:0.75rem; align-items:center; font-size:0.72rem; color:var(--gray-500); margin-top:0.25rem;">
                  <span class="vf-count" data-for="<%= field %>"></span>
                  <span class="vf-edited" data-for="<%= field %>" hidden style="color:#d97706;">&#9679; reworked — paid on top</span>
                  <button type="button" class="vf-draft-toggle" data-for="<%= field %>" hidden
                    style="background:none; border:none; padding:0; color:#2563eb; cursor:pointer; font-size:0.72rem; text-decoration:underline;">View AI draft (diff)</button>
                  <% if (thaiValue) { %>
                    <button type="button" class="vf-thai-toggle" data-for="<%= field %>"
                      style="background:none; border:none; padding:0; color:#2563eb; cursor:pointer; font-size:0.72rem; text-decoration:underline;">View Thai reference</button>
                  <% } %>
                  <span class="vf-copy-slot" data-for="<%= field %>"></span>
                </div>
                <div class="vf-draft" data-for="<%= field %>" hidden
                  style="border:1px dashed var(--gray-300); border-radius:6px; padding:0.5rem; margin-top:0.25rem; font-size:0.85rem; line-height:1.8; white-space:pre-wrap; background:#fffbeb; max-height:260px; overflow:auto;"></div>
                <% if (thaiValue) { %>
                  <div class="vf-thai" data-for="<%= field %>" hidden
                    style="border:1px dashed var(--gray-300); border-radius:6px; padding:0.5rem; margin-top:0.25rem; font-size:0.85rem; line-height:1.8; white-space:pre-wrap; background:#eff6ff; max-height:260px; overflow:auto;"><div style="font-size:0.7rem; color:var(--gray-500); margin-bottom:0.25rem;">Thai (verified &middot; reference only &mdash; the English source is the authority)</div><%= thaiValue %></div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </form>
  </div>
</main>

<style nonce="<%= cspNonce %>">
  /* Side-by-side on desktop; stacked on phones so the target textarea
     gets the full width (this workforce is mobile-first). */
  .seg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 767px) { .seg-grid { grid-template-columns: 1fr; } }
</style>
<script nonce="<%= cspNonce %>">
  // Baseline for edit tracking: the AI draft snapshot when it exists (that
  // is what edit pay is measured against server-side), else the payload as
  // loaded. Sources ship only when short — TM-lite needs them to spot
  // repeated fields, and page-length sources aren't repeated fields.
  window.__VERIFY_BASE__ = <%- JSON.stringify(item.ai_draft_payload || item.content_payload || {}).replace(/</g, '\\u003c') %>;
  // Active verification rate for the live pay estimate (null when no card).
  window.__VERIFY_RATE__ = <%- JSON.stringify((typeof verifyRate !== 'undefined' && verifyRate) ? { amount: parseFloat(verifyRate.rate_amount), currency: verifyRate.currency || 'USD', type: verifyRate.rate_type } : null).replace(/</g, '\\u003c') %>;
  window.__VERIFY_SRC__ = <%- JSON.stringify((function () {
      var out = {};
      if (source && source.fields) Object.keys(source.fields).forEach(function (f) {
        var v = String(source.fields[f] == null ? '' : source.fields[f]);
        if (v && v.length <= 400) out[f] = v;
      });
      return out;
    })()).replace(/</g, '\\u003c') %>;
</script>
<script nonce="<%= cspNonce %>">
(function () {
  var csrfMeta = document.querySelector('meta[name="csrf-token"]');
  var csrf = csrfMeta ? csrfMeta.content : '';
  var id = '<%= item.id %>';
  var PAGE_READONLY = <%= readOnly ? 'true' : 'false' %>;
  // Unsaved changes tracked per field: section auto-saves clear only the
  // field they persisted, so the leave-warning stays honest.
  var dirtyFields = new Set();
  var BASE = window.__VERIFY_BASE__ || {};
  var SRC = window.__VERIFY_SRC__ || {};

  function esc(s) { var d = document.createElement('div'); d.textContent = String(s == null ? '' : s); return d.innerHTML; }
  // Mirrors the server's pay meter: tags stripped, whitespace collapsed —
  // the counter shows exactly what is billable.
  function payText(v) { return String(v == null ? '' : v).replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim(); }

  // Compact word-level diff (LCS). Deletions struck red, insertions green.
  function wordDiff(a, b) {
    var A = payText(a).split(' '), B = payText(b).split(' ');
    if (A.length * B.length > 160000) return null; // too large — skip gracefully
    var m = A.length, n = B.length, i, j;
    var L = [];
    for (i = 0; i <= m; i++) { L.push(new Uint16Array(n + 1)); }
    for (i = m - 1; i >= 0; i--) for (j = n - 1; j >= 0; j--) {
      L[i][j] = A[i] === B[j] ? L[i + 1][j + 1] + 1 : Math.max(L[i + 1][j], L[i][j + 1]);
    }
    var out = [];
    i = 0; j = 0;
    while (i < m && j < n) {
      if (A[i] === B[j]) { out.push(esc(A[i])); i++; j++; }
      else if (L[i + 1][j] >= L[i][j + 1]) { out.push('<del style="color:#dc2626; background:#fee2e2;">' + esc(A[i]) + '</del>'); i++; }
      else { out.push('<ins style="color:#059669; background:#d1fae5; text-decoration:none;">' + esc(B[j]) + '</ins>'); j++; }
    }
    while (i < m) { out.push('<del style="color:#dc2626; background:#fee2e2;">' + esc(A[i++]) + '</del>'); }
    while (j < n) { out.push('<ins style="color:#059669; background:#d1fae5; text-decoration:none;">' + esc(B[j++]) + '</ins>'); }
    return out.join(' ');
  }

  function fieldEl(cls, name) { return document.querySelector('.' + cls + '[data-for="' + CSS.escape(name) + '"]'); }

  function refreshField(field) {
    var name = field.name;
    var current = field.value;
    var counter = fieldEl('vf-count', name);
    if (counter) counter.textContent = payText(current).length.toLocaleString() + ' chars';
    var base = BASE[name];
    var edited = base != null && payText(base) !== payText(current);
    var badge = fieldEl('vf-edited', name);
    if (badge) badge.hidden = !edited;
    var toggle = fieldEl('vf-draft-toggle', name);
    if (toggle) toggle.hidden = !(edited && payText(base || ''));
    var draftBox = fieldEl('vf-draft', name);
    if (draftBox && !draftBox.hidden) renderDraft(name); // keep an open diff live
  }

  function refreshTotal() {
    var total = 0;
    document.querySelectorAll('.verify-field').forEach(function (f) { total += payText(f.value).length; });
    var el = document.getElementById('charCount');
    if (el) el.textContent = total.toLocaleString();
    // Live pay estimate: what THIS item earns at the worker's rate card.
    var rate = window.__VERIFY_RATE__;
    var est = document.getElementById('payEstimate');
    if (est && rate && rate.amount > 0) {
      var amount = rate.type === 'per_1000_chars' ? rate.amount * total / 1000
        : (rate.type === 'per_word' ? null : rate.amount);
      if (amount != null) {
        est.textContent = ' · ≈ ' + rate.currency + ' ' +
          (rate.currency === 'LAK' ? Math.round(amount).toLocaleString() : amount.toFixed(2)) +
          ' for this item';
      }
    }
  }

  function renderDraft(name) {
    var field = document.querySelector('.verify-field[name="' + CSS.escape(name) + '"]');
    var box = fieldEl('vf-draft', name);
    if (!field || !box) return;
    var diff = wordDiff(BASE[name] || '', field.value);
    box.innerHTML = diff !== null
      ? diff
      : esc(payText(BASE[name] || '')); // too large to diff — show the draft plain
  }

  document.querySelectorAll('.vf-draft-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var name = btn.getAttribute('data-for');
      var box = fieldEl('vf-draft', name);
      box.hidden = !box.hidden;
      if (!box.hidden) renderDraft(name);
      btn.textContent = box.hidden ? 'View AI draft (diff)' : 'Hide AI draft';
    });
  });

  // Verified Thai reference (Lao rows): read-only comparison aid — the
  // English source stays the authority, but the verifier pool reads Thai
  // fluently and Lao drafts leaned on this text for style.
  document.querySelectorAll('.vf-thai-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var name = btn.getAttribute('data-for');
      var box = fieldEl('vf-thai', name);
      if (!box) return;
      box.hidden = !box.hidden;
      btn.textContent = box.hidden ? 'View Thai reference' : 'Hide Thai reference';
    });
  });

  // TM-lite: identical source fields should carry identical translations —
  // offer one-click copy when one is filled and its twin differs.
  (function tmLite() {
    var groups = {};
    Object.keys(SRC).forEach(function (f) {
      var key = payText(SRC[f]).toLowerCase();
      if (!key) return;
      (groups[key] = groups[key] || []).push(f);
    });
    Object.keys(groups).forEach(function (key) {
      var fields = groups[key];
      if (fields.length < 2) return;
      fields.forEach(function (name) {
        var slot = fieldEl('vf-copy-slot', name);
        var mine = document.querySelector('.verify-field[name="' + CSS.escape(name) + '"]');
        if (!slot || !mine) return;
        var twin = fields.find(function (other) {
          if (other === name) return false;
          var el = document.querySelector('.verify-field[name="' + CSS.escape(other) + '"]');
          return el && payText(el.value) && payText(el.value) !== payText(mine.value);
        });
        if (!twin) return;
        var b = document.createElement('button');
        b.type = 'button';
        b.textContent = 'Same source as \u201C' + twin.replace(/_/g, ' ') + '\u201D — copy its translation';
        b.style.cssText = 'background:none;border:none;padding:0;color:#2563eb;cursor:pointer;font-size:0.72rem;text-decoration:underline;';
        b.addEventListener('click', function () {
          var from = document.querySelector('.verify-field[name="' + CSS.escape(twin) + '"]');
          mine.value = from.value;
          mine.dispatchEvent(new Event('input'));
        });
        slot.replaceChildren(b);
      });
    });
  })();

  // Termbase panel: fetch once, re-check presence live.
  var TERMS = [];
  function refreshTerms() {
    if (!TERMS.length) return;
    var all = '';
    document.querySelectorAll('.verify-field').forEach(function (f) { all += ' ' + payText(f.value).toLowerCase(); });
    TERMS.forEach(function (t) {
      if (!t.approved || !t.el) return;
      var present = all.indexOf(t.approved.toLowerCase()) !== -1;
      t.el.style.background = present ? '#d1fae5' : '#fee2e2';
      t.el.style.color = present ? '#065f46' : '#991b1b';
      t.el.title = present ? 'Approved name is used' : 'Approved name is NOT used in the translation yet';
    });
  }
  fetch('/translations/verify/' + id + '/termbase', { headers: { 'Accept': 'application/json' } })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      TERMS = (d.terms || []).filter(function (t) { return t.approved; });
      if (!TERMS.length) return;
      var list = document.getElementById('termList');
      TERMS.forEach(function (t) {
        var chip = document.createElement('span');
        chip.style.cssText = 'display:inline-block; padding:0.2rem 0.6rem; border-radius:999px; font-size:0.78rem;';
        chip.textContent = t.name + ' \u2192 ' + t.approved;
        t.el = chip;
        list.appendChild(chip);
      });
      document.getElementById('termPanel').hidden = false;
      refreshTerms();
    })
    .catch(function () { /* panel is progressive enhancement */ });

  document.querySelectorAll('.verify-field').forEach(function (field) {
    field.addEventListener('input', function () {
      dirtyFields.add(field.name);
      refreshField(field);
      refreshTotal();
      refreshTerms();
    });
    refreshField(field);
  });
  refreshTotal();
  window.addEventListener('beforeunload', function (e) {
    if (dirtyFields.size > 0) { e.preventDefault(); e.returnValue = ''; }
  });

  // --- Per-section verification: tick to sign off (auto-saves and locks
  // the card), untick to reopen. Field blur auto-saves edits so partial
  // progress is never lost.
  function applySectionState(name, verified) {
    var card = document.querySelector('.sec-card[data-field="' + CSS.escape(name) + '"]');
    var pill = fieldEl('sec-pill', name);
    var check = fieldEl('sec-check', name);
    var ta = document.querySelector('.verify-field[name="' + CSS.escape(name) + '"]');
    if (check) check.checked = verified;
    if (card) {
      card.style.borderLeft = verified ? '4px solid #059669' : '';
      card.style.opacity = verified ? '0.88' : '';
    }
    if (pill) {
      pill.style.borderColor = verified ? '#059669' : 'var(--gray-300, #d1d5db)';
      pill.style.background = verified ? '#d1fae5' : 'transparent';
      pill.style.color = verified ? '#065f46' : 'var(--gray-600, #4b5563)';
    }
    if (ta && !PAGE_READONLY) ta.readOnly = verified;
  }
  function updateProgress(done, total) {
    var doneEl = document.getElementById('secDone');
    var totalEl = document.getElementById('secTotal');
    var bar = document.getElementById('secBar');
    if (doneEl) doneEl.textContent = done;
    if (totalEl) totalEl.textContent = total;
    if (bar) bar.style.width = (total ? Math.round(done * 100 / total) : 0) + '%';
    var approve = document.getElementById('approveBtn');
    if (approve) approve.title = done < total
      ? 'Verify all ' + total + ' sections to finish — finishing early asks for confirmation'
      : 'All sections verified — finish the item';
  }
  function savedToast() {
    var t = document.getElementById('saveToast');
    if (!t) return;
    t.hidden = false;
    clearTimeout(savedToast._t);
    savedToast._t = setTimeout(function () { t.hidden = true; }, 1600);
  }
  function postSection(name, verified, cb) {
    var ta = document.querySelector('.verify-field[name="' + CSS.escape(name) + '"]');
    var body = { field: name, value: ta ? ta.value : '' };
    if (verified === true || verified === false) body.verified = verified;
    post('/translations/verify/' + id + '/section', body).then(function (res) {
      if (!res.ok) { cb(false, res.data); return; }
      dirtyFields.delete(name);
      savedToast();
      cb(true, res.data);
    });
  }
  document.querySelectorAll('.sec-check').forEach(function (check) {
    check.addEventListener('change', function () {
      var name = check.getAttribute('data-for');
      var want = check.checked;
      check.disabled = true;
      postSection(name, want, function (ok, data) {
        check.disabled = false;
        if (!ok) {
          check.checked = !want;
          alert((data && data.error) || 'Section save failed');
          return;
        }
        applySectionState(name, want);
        updateProgress(data.verifiedCount, data.totalSections);
      });
    });
  });
  document.querySelectorAll('.verify-field').forEach(function (field) {
    field.addEventListener('blur', function () {
      if (PAGE_READONLY || !dirtyFields.has(field.name)) return;
      // Best-effort auto-save; on failure the field simply stays dirty and
      // Save Fixes / the next blur retries.
      postSection(field.name, null, function () {});
    });
  });
  updateProgress(parseInt(document.getElementById('secDone') ? document.getElementById('secDone').textContent : '0', 10) || 0,
    parseInt(document.getElementById('secTotal') ? document.getElementById('secTotal').textContent : '0', 10) || 0);

  function collectPayload() {
    var payload = {};
    document.querySelectorAll('.verify-field').forEach(function (field) {
      payload[field.name] = field.value;
    });
    return payload;
  }

  // Robust POST wrapper: non-JSON bodies (rate-limit text, proxy error
  // pages) and network failures resolve to a readable error instead of an
  // unhandled rejection that leaves buttons dead. A 401 names the real
  // problem — an expired session — rather than a cryptic token error.
  function post(url, body) {
    return fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': csrf },
      body: JSON.stringify(body || {})
    }).then(function (r) {
      return r.json().catch(function () {
        return { error: r.status === 429 ? 'Too many requests — wait a minute and try again.' : ('Request failed (' + r.status + '). Try again.') };
      }).then(function (d) {
        if (r.status === 401) {
          d.error = d.error || 'Your session has expired. Open the login page in a new tab, sign in, then retry — your text is still here.';
        }
        return { ok: r.ok, data: d };
      });
    }).catch(function () {
      return { ok: false, data: { error: 'No connection — check your internet and try again. Your text is still here.' } };
    });
  }

  var saveBtn = document.getElementById('saveBtn');
  if (saveBtn) saveBtn.addEventListener('click', function () {
    var btn = this;
    btn.disabled = true;
    post('/translations/verify/' + id + '/save', { content_payload: collectPayload() }).then(function (res) {
      btn.disabled = false;
      if (res.ok) {
        dirtyFields.clear();
        btn.innerHTML = '<i class="fas fa-check"></i> Saved (' + res.data.editedSegments + ' reworked)';
        setTimeout(function () { btn.innerHTML = '<i class="fas fa-save"></i> Save Fixes'; }, 2000);
      } else {
        alert(res.data.error || 'Save failed');
      }
    });
  });

  var approveBtn = document.getElementById('approveBtn');
  if (approveBtn) approveBtn.addEventListener('click', function () {
    if (!confirm('Approve this content for publication? Your verification (and any reworked segments) are credited when the admin publishes it.')) return;
    var btn = this;
    function doApprove(body) {
      btn.disabled = true;
      post('/translations/verify/' + id + '/approve', body).then(function (res) {
        if (res.ok) {
          dirtyFields.clear();
          location.href = '/translations/workspace';
          return;
        }
        btn.disabled = false;
        // Soft completeness gate: finishing with unticked sections needs an
        // explicit go-ahead — the nudge is completeness, never a hard block.
        if (res.data && res.data.requiresAcknowledgement) {
          var msg = (res.data.error || 'Some sections are not marked verified.') +
            '\n\nFinish anyway? Unticked sections stay recorded as not individually signed off.';
          if (confirm(msg)) doApprove({ content_payload: collectPayload(), acknowledge_incomplete: true });
          return;
        }
        alert(res.data.error || 'Approve failed');
      });
    }
    doApprove({ content_payload: collectPayload() });
  });

  var returnBtn = document.getElementById('returnBtn');
  var REASONS = ['mistranslation', 'tone', 'terminology', 'markup', 'incomplete', 'other'];
  if (returnBtn) returnBtn.addEventListener('click', function () {
    var pick = prompt('Reason \u2014 type a number:\n1 mistranslation  2 tone  3 terminology\n4 markup  5 incomplete  6 other');
    if (pick === null) return;
    var reason = REASONS[parseInt(pick, 10) - 1] || 'other';
    var note = prompt('Details for the translator (what is wrong / what to fix)?');
    if (note === null) return;
    post('/translations/verify/' + id + '/return', { note: note, reason: reason }).then(function (res) {
      if (res.ok) location.href = '/translations/workspace';
      else alert(res.data.error || 'Return failed');
    });
  });
})();
</script>


<%- include('../../partials/head', { title, bodyClass: 'dashboard-layout' }) %>
<%- include('../../partials/sidebar', { currentPage, user }) %>

<main class="main-content">
  <%- include('../../partials/header', { user, messages }) %>

  <div class="page-content">
    <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <h1 class="page-title"><%= product ? 'Edit Product' : 'New Product' %></h1>
        <p class="page-subtitle"><a href="/business/products"><i class="fas fa-arrow-left"></i> Back to Products</a></p>
      </div>
      <button type="button" id="btn-preview-sidebar" class="btn btn-primary" style="white-space:nowrap;">
        <i class="fas fa-eye"></i> Preview Sidebar
      </button>
    </div>

    <form action="<%= product ? '/business/products/' + product.id : '/business/products' %>" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger" style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:0.85rem 1rem;border-radius:8px;margin-bottom:1.25rem;">
        <i class="fas fa-exclamation-triangle"></i> <%= error %>
      </div>
      <% } %>

      <!-- Readiness checklist -->
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-clipboard-check"></i> Readiness</h3>
          <p id="readiness-status" style="margin:0 0 0.6rem;font-size:0.95rem;font-weight:600;"></p>
          <ul id="readiness-list" style="list-style:none;padding:0;margin:0;font-size:0.9rem;color:#334155;">
            <li data-check="name" style="margin:0.35rem 0;"><span class="readiness-icon" style="display:inline-block;width:1.35rem;text-align:center;"><i class="fas fa-circle-xmark" style="color:#b91c1c;"></i></span> <span class="readiness-text">Name (3&ndash;80 characters)</span></li>
            <li data-check="description" style="margin:0.35rem 0;"><span class="readiness-icon" style="display:inline-block;width:1.35rem;text-align:center;"><i class="fas fa-circle-xmark" style="color:#b91c1c;"></i></span> <span class="readiness-text">Description (at least 20 characters)</span></li>
            <li data-check="classification" style="margin:0.35rem 0;"><span class="readiness-icon" style="display:inline-block;width:1.35rem;text-align:center;"><i class="fas fa-circle-xmark" style="color:#b91c1c;"></i></span> <span class="readiness-text">Service Page + Subcategory chosen</span></li>
            <li data-check="price" style="margin:0.35rem 0;"><span class="readiness-icon" style="display:inline-block;width:1.35rem;text-align:center;"><i class="fas fa-circle-xmark" style="color:#b91c1c;"></i></span> <span class="readiness-text">Price set for the chosen pricing type</span></li>
            <li data-check="sell" style="margin:0.35rem 0;"><span class="readiness-icon" style="display:inline-block;width:1.35rem;text-align:center;"><i class="fas fa-minus" style="color:#94a3b8;"></i></span> <span class="readiness-text">Sell online is off &mdash; quote requests only</span></li>
            <li data-check="icon" style="margin:0.35rem 0;"><span class="readiness-icon" style="display:inline-block;width:1.35rem;text-align:center;"><i class="fas fa-circle-exclamation" style="color:#d97706;"></i></span> <span class="readiness-text">Card icon set</span></li>
          </ul>
        </div>
      </div>

      <!-- Basic Information -->
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-info-circle"></i> Basic Information</h3>

          <div class="form-group">
            <label class="form-label" for="name">Product Name *</label>
            <input type="text" id="name" name="name" class="form-input" value="<%= product ? product.name : '' %>" required>
          </div>

          <div class="form-group">
            <label class="form-label" for="slug">Slug (URL-friendly name)</label>
            <input type="text" id="slug" name="slug" class="form-input" value="<%= product ? (product.slug || '') : '' %>" placeholder="auto-generated-from-name">
          </div>

          <div class="form-group">
            <label class="form-label" for="description">Description</label>
            <textarea id="description" name="description" class="form-input" rows="4"><%= product ? (product.description || '') : '' %></textarea>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="product_type">Product Type</label>
              <select id="product_type" name="product_type" class="form-input">
                <option value="service" <%= product && product.product_type === 'service' ? 'selected' : (!product ? 'selected' : '') %>>Service</option>
                <option value="digital" <%= product && product.product_type === 'digital' ? 'selected' : '' %>>Digital Product</option>
                <option value="subscription" <%= product && product.product_type === 'subscription' ? 'selected' : '' %>>Subscription</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="status">Status</label>
              <select id="status" name="status" class="form-input">
                <option value="active" <%= !product || product.status === 'active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= product && product.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                <option value="draft" <%= product && product.status === 'draft' ? 'selected' : '' %>>Draft</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Classification & Audience -->
      <% const tx = (typeof taxonomy !== 'undefined' && taxonomy) ? taxonomy : { SERVICE_PAGES: [], SUBCATEGORIES: {}, PURCHASE_MODES: [], INDUSTRIES: [], PRICE_UNITS: [] }; %>
      <% const curSP = (product && product.service_page) || ''; %>
      <% const curInd = (product && Array.isArray(product.industries)) ? product.industries : []; %>
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-sitemap"></i> Classification &amp; Audience</h3>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="service_page">Service Page (Category) *</label>
              <select id="service_page" name="service_page" class="form-input" required>
                <option value="">-- Select --</option>
                <% tx.SERVICE_PAGES.forEach(function(sp){ %>
                <option value="<%= sp.value %>" <%= curSP === sp.value ? 'selected' : '' %>><%= sp.label %></option>
                <% }); %>
              </select>
              <small style="color:#666;">The authoritative top-level category.</small>
            </div>
            <div class="form-group">
              <label class="form-label" for="subcategory">Subcategory *</label>
              <select id="subcategory" name="subcategory" class="form-input" required>
                <option value="">-- Select a Service Page first --</option>
                <% (tx.SUBCATEGORIES[curSP] || []).forEach(function(sc){ %>
                <option value="<%= sc.value %>" <%= product && product.subcategory === sc.value ? 'selected' : '' %>><%= sc.label %></option>
                <% }); %>
              </select>
              <small style="color:#666;">Options update based on the Service Page.</small>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="checkbox" id="purchase_mode" name="purchase_mode" value="buy" style="width:auto;margin:0;"
                  <%= product && product.purchase_mode === 'buy' ? 'checked' : '' %>>
                Sell online
              </label>
              <small style="color:#666;">Off: customers request a quote (default). On: signed-in clients can also buy directly — by card (Stripe) or BCEL OnePay — using the pricing below.</small>
            </div>
            <div class="form-group">
              <label class="form-label" for="sku">SKU (optional)</label>
              <input type="text" id="sku" name="sku" class="form-input" value="<%= product ? (product.sku || '') : '' %>" placeholder="e.g. 10259403">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="cta_form_type"><i class="fab fa-wpforms"></i> Request-a-Quote form</label>
            <% const fts = (typeof formTemplates !== 'undefined' && formTemplates) ? formTemplates : []; %>
            <% const curForm = product ? (product.cta_form_type || '') : ''; %>
            <select id="cta_form_type" name="cta_form_type" class="form-input">
              <option value="">Default — Consultation form</option>
              <% fts.forEach(function(ft){ %>
              <option value="<%= ft.form_type %>" <%= curForm === ft.form_type ? 'selected' : '' %>><%= ft.title %> (<%= ft.form_type %>)</option>
              <% }); %>
            </select>
            <small style="color:#666;">Which form opens when a visitor clicks this product's “Request a Quote” / enquiry button. Create forms under Message Board → Forms. One form can serve many products.</small>
          </div>

          <div class="form-group">
            <label class="form-label">Industries / Ideal For</label>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem 1rem;padding:0.5rem 0;">
              <% tx.INDUSTRIES.forEach(function(ind){ %>
              <label style="display:inline-flex;align-items:center;gap:0.35rem;font-weight:400;cursor:pointer;">
                <input type="checkbox" name="industries" value="<%= ind.value %>" style="width:auto;margin:0;" <%= curInd.indexOf(ind.value) !== -1 ? 'checked' : '' %>>
                <%= ind.label %>
              </label>
              <% }); %>
            </div>
            <small style="color:#666;">Cross-cutting audience tags — power the “browse by industry” tiers.</small>
          </div>
        </div>
      </div>

      <!-- Pricing & Category -->
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-tags"></i> Pricing & Billing</h3>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="pricing_type">Pricing Type</label>
              <select id="pricing_type" name="pricing_type" class="form-input">
                <option value="one_time" <%= !product || (product.pricing_type || 'one_time') === 'one_time' ? 'selected' : '' %>>One-Time Payment</option>
                <option value="subscription" <%= product && product.pricing_type === 'subscription' ? 'selected' : '' %>>Subscription</option>
                <option value="tiered" <%= product && product.pricing_type === 'tiered' ? 'selected' : '' %>>Quantity / Volume Pricing</option>
                <option value="options" <%= product && product.pricing_type === 'options' ? 'selected' : '' %>>Named Options (one product, multiple prices)</option>
              </select>
              <small style="color:#666;">Choose how this product is billed. “Options” = one service, several SKU/price paths (e.g. AI vs Designer).</small>
            </div>
            <div class="form-group">
              <label class="form-label" for="currency">Currency</label>
              <select id="currency" name="currency" class="form-input">
                <option value="USD" <%= !product || product.currency === 'USD' ? 'selected' : '' %>>USD</option>
                <option value="EUR" <%= product && product.currency === 'EUR' ? 'selected' : '' %>>EUR</option>
                <option value="GBP" <%= product && product.currency === 'GBP' ? 'selected' : '' %>>GBP</option>
                <option value="THB" <%= product && product.currency === 'THB' ? 'selected' : '' %>>THB</option>
                <option value="LAK" <%= product && product.currency === 'LAK' ? 'selected' : '' %>>LAK</option>
              </select>
            </div>
          </div>

          <!-- One-Time pricing -->
          <div id="one-time-pricing" class="pricing-block">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="price">One-Time Price</label>
                <input type="number" id="price" name="price" class="form-input" step="0.01" min="0" value="<%= product ? (product.price || '') : '' %>" placeholder="e.g. 99.00">
                <small style="color:#666;">The amount; leave blank for “Custom Quote”.</small>
              </div>
              <div class="form-group">
                <label class="form-label" for="price_unit">Price Unit</label>
                <select id="price_unit" name="price_unit" class="form-input">
                  <% tx.PRICE_UNITS && tx.PRICE_UNITS.forEach(function(u){ %>
                  <option value="<%= u.value %>" <%= (product ? (product.price_unit || 'fixed') : 'fixed') === u.value ? 'selected' : '' %>><%= u.label %></option>
                  <% }); %>
                </select>
                <small style="color:#666;">e.g. “Per hour” ($33/hr) or “Per agreed quantity”.</small>
              </div>
            </div>
          </div>

          <!-- Subscription pricing -->
          <div id="subscription-pricing" class="pricing-block" style="border-left:3px solid var(--accent-color,#d62b83);padding-left:1rem;margin-top:0.5rem;">
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="monthly_price">Monthly Price</label>
                <input type="number" id="monthly_price" name="monthly_price" class="form-input" step="0.01" min="0" value="<%= product && product.monthly_price != null ? product.monthly_price : '' %>" placeholder="e.g. 19.00">
                <small style="color:#666;">Leave blank to offer yearly only.</small>
              </div>
              <div class="form-group">
                <label class="form-label" for="yearly_price">Yearly Price</label>
                <input type="number" id="yearly_price" name="yearly_price" class="form-input" step="0.01" min="0" value="<%= product && product.yearly_price != null ? product.yearly_price : '' %>" placeholder="e.g. 190.00">
                <small style="color:#666;">Leave blank to offer monthly only.</small>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="annual_discount_pct">Annual Discount % (optional)</label>
                <input type="number" id="annual_discount_pct" name="annual_discount_pct" class="form-input" min="0" max="100" value="<%= product && product.annual_discount_pct != null ? product.annual_discount_pct : '' %>" placeholder="auto">
                <small style="color:#666;">Override the “Save X%” badge. Leave blank to auto-calculate from the prices above.</small>
              </div>
              <div class="form-group">
                <label class="form-label" for="default_billing">Default Billing Selection</label>
                <select id="default_billing" name="default_billing" class="form-input">
                  <option value="monthly" <%= !product || (product.default_billing || 'monthly') === 'monthly' ? 'selected' : '' %>>Monthly</option>
                  <option value="yearly" <%= product && product.default_billing === 'yearly' ? 'selected' : '' %>>Yearly</option>
                </select>
                <small style="color:#666;">Which option is pre-selected on the product page.</small>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="hidden" name="allow_billing_toggle" value="false">
                <input type="checkbox" name="allow_billing_toggle" value="true" style="width:auto;margin:0;"
                  <%= !product || product.allow_billing_toggle !== false ? 'checked' : '' %>>
                Allow customers to switch between Monthly and Yearly on the product page
              </label>
            </div>

            <div id="savings-preview" style="display:none;background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;padding:0.6rem 0.9rem;border-radius:8px;font-size:0.9rem;margin-top:0.25rem;">
              <i class="fas fa-piggy-bank"></i> <span id="savings-preview-text"></span>
            </div>

            <div class="form-row" style="margin-top:1rem;">
              <div class="form-group">
                <label class="form-label" for="stripe_price_id_monthly">Stripe Price ID (Monthly)</label>
                <input type="text" id="stripe_price_id_monthly" name="stripe_price_id_monthly" class="form-input" value="<%= product ? (product.stripe_price_id_monthly || '') : '' %>" placeholder="price_...">
              </div>
              <div class="form-group">
                <label class="form-label" for="stripe_price_id_yearly">Stripe Price ID (Yearly)</label>
                <input type="text" id="stripe_price_id_yearly" name="stripe_price_id_yearly" class="form-input" value="<%= product ? (product.stripe_price_id_yearly || '') : '' %>" placeholder="price_...">
              </div>
            </div>

            <!-- One-time setup fee charged with the first subscription payment -->
            <div style="margin-top:1rem;padding-top:0.85rem;border-top:1px dashed #e2e8f0;">
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="setup_fee">Setup Fee (one-time, optional)</label>
                  <input type="number" id="setup_fee" name="setup_fee" class="form-input" step="0.01" min="0" value="<%= product && product.setup_fee != null ? product.setup_fee : '' %>" placeholder="e.g. 54.00">
                  <small style="color:#666;">Charged once, in the same checkout as the first subscription payment. Customers can untick it on the product page.</small>
                </div>
                <div class="form-group">
                  <label class="form-label" for="setup_fee_label">Setup Fee Label</label>
                  <input type="text" id="setup_fee_label" name="setup_fee_label" class="form-input" maxlength="120" value="<%= product ? (product.setup_fee_label || '') : '' %>" placeholder="e.g. Custom design">
                  <small style="color:#666;">Shown on the product page and Stripe receipt. Blank shows “Setup fee”.</small>
                </div>
              </div>
              <div class="form-group">
                <label class="form-label" for="stripe_price_id_setup">Stripe Price ID (Setup Fee)</label>
                <input type="text" id="stripe_price_id_setup" name="stripe_price_id_setup" class="form-input" value="<%= product ? (product.stripe_price_id_setup || '') : '' %>" placeholder="price_... (one-time price — optional)">
                <small style="color:#666;">Optional. When set, checkout uses this one-time Price instead of the amount above.</small>
              </div>
            </div>
          </div>

          <!-- Quantity / Volume pricing -->
          <div id="tiered-pricing" class="pricing-block" style="border-left:3px solid #7c3aed;padding-left:1rem;margin-top:0.5rem;">
            <p style="font-size:0.85rem;color:#666;margin:0 0 0.6rem;">
              Set the <strong>unit price</strong> at each quantity threshold. Each price applies from that quantity up to the next — the per-unit price drops as customers buy more.
            </p>
            <%
              var curTiers = [];
              if (product && product.quantity_tiers) {
                try { curTiers = typeof product.quantity_tiers === 'string' ? JSON.parse(product.quantity_tiers) : product.quantity_tiers; } catch (e) { curTiers = []; }
              }
              if (!Array.isArray(curTiers) || curTiers.length === 0) { curTiers = [{ min_qty: 1, unit_price: '' }]; }
            %>
            <div id="tier-rows">
              <% curTiers.forEach(function(t){ %>
              <div class="tier-row" style="display:grid;grid-template-columns:1fr 1fr auto;gap:0.5rem;align-items:end;margin-bottom:0.5rem;">
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.78rem;">Min quantity</label>
                  <input type="number" name="tier_min_qty" class="form-input" min="1" step="1" value="<%= t.min_qty != null ? t.min_qty : '' %>" placeholder="e.g. 1">
                </div>
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.78rem;">Unit price</label>
                  <input type="number" name="tier_unit_price" class="form-input" min="0" step="0.01" value="<%= t.unit_price != null ? t.unit_price : '' %>" placeholder="e.g. 9.00">
                </div>
                <button type="button" class="btn btn-secondary btn-sm tier-remove" title="Remove tier" style="padding:0.4rem 0.6rem;">&times;</button>
              </div>
              <% }); %>
            </div>
            <button type="button" id="tier-add" class="btn btn-secondary btn-sm" style="margin-top:0.25rem;"><i class="fas fa-plus"></i> Add tier</button>
            <div id="tier-preview" style="display:none;background:#f5f3ff;border:1px solid #ddd6fe;color:#5b21b6;padding:0.6rem 0.9rem;border-radius:8px;font-size:0.85rem;margin-top:0.6rem;"></div>
          </div>

          <!-- Named options: one product, multiple price points / SKUs -->
          <div id="options-pricing" class="pricing-block" style="border-left:3px solid #e11d74;padding-left:1rem;margin-top:0.5rem;">
            <p style="font-size:0.85rem;color:#666;margin:0 0 0.6rem;">
              One service, several <strong>options</strong> (e.g. AI vs Designer). Each option has its own SKU, price, strategy, and Stripe Price ID.
            </p>
            <%
              var curOpts = [];
              if (product && product.price_options) {
                try { curOpts = typeof product.price_options === 'string' ? JSON.parse(product.price_options) : product.price_options; } catch (e) { curOpts = []; }
              }
              if (!Array.isArray(curOpts) || curOpts.length === 0) {
                curOpts = [
                  { key: 'ai', label: 'AI-Powered Creation', sku: '', price: '', strategy: 'entry_speed', stripe_price_id: '' },
                  { key: 'designer', label: 'Graphic Designer Support', sku: '', price: '', strategy: 'premium_craft', stripe_price_id: '' }
                ];
              }
            %>
            <div id="option-rows">
              <% curOpts.forEach(function(o){ %>
              <div class="option-row" style="display:grid;grid-template-columns:0.8fr 1.2fr 0.8fr 0.7fr 0.9fr 1fr auto;gap:0.4rem;align-items:end;margin-bottom:0.5rem;">
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.72rem;">Key</label>
                  <input type="text" name="opt_key" class="form-input" value="<%= o.key || '' %>" placeholder="ai">
                </div>
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.72rem;">Label</label>
                  <input type="text" name="opt_label" class="form-input" value="<%= o.label || '' %>" placeholder="AI-Powered">
                </div>
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.72rem;">SKU</label>
                  <input type="text" name="opt_sku" class="form-input" value="<%= o.sku || '' %>" placeholder="19106773">
                </div>
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.72rem;">Price</label>
                  <input type="number" name="opt_price" class="form-input" min="0" step="0.01" value="<%= o.price != null ? o.price : '' %>" placeholder="49">
                </div>
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.72rem;">Strategy</label>
                  <input type="text" name="opt_strategy" class="form-input" value="<%= o.strategy || '' %>" placeholder="entry_speed">
                </div>
                <div class="form-group" style="margin:0;">
                  <label class="form-label" style="font-size:0.72rem;">Stripe Price</label>
                  <input type="text" name="opt_stripe_price_id" class="form-input" value="<%= o.stripe_price_id || '' %>" placeholder="price_…">
                </div>
                <button type="button" class="btn btn-secondary btn-sm option-remove" title="Remove" style="padding:0.4rem 0.6rem;">&times;</button>
              </div>
              <% }); %>
            </div>
            <button type="button" id="option-add" class="btn btn-secondary btn-sm" style="margin-top:0.25rem;"><i class="fas fa-plus"></i> Add option</button>
          </div>

          <div class="form-group">
            <label class="form-label" for="category">Legacy Category (optional)</label>
            <input type="text" id="category" name="category" class="form-input" value="<%= product ? (product.category || '') : '' %>" placeholder="free-text — superseded by Service Page + Subcategory above">
            <small style="color:#666;">Kept for backward compatibility. Classification now comes from Service Page + Subcategory.</small>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="sort_order">Sort Order</label>
              <input type="number" id="sort_order" name="sort_order" class="form-input" value="<%= product ? (product.sort_order || 0) : 0 %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="is_featured">Featured</label>
              <select id="is_featured" name="is_featured" class="form-input">
                <option value="false" <%= !product || !product.is_featured ? 'selected' : '' %>>No</option>
                <option value="true" <%= product && product.is_featured ? 'selected' : '' %>>Yes</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Appearance -->
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-palette"></i> Appearance (Service Card)</h3>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="icon_class">Icon Class (Font Awesome)</label>
              <div style="display:flex;align-items:center;gap:0.75rem;">
                <input type="text" id="icon_class" name="icon_class" class="form-input" style="flex:1;" value="<%= product ? (product.icon_class || 'fas fa-box') : 'fas fa-box' %>" placeholder="fas fa-pen-nib">
                <span id="icon-class-preview" title="Live preview — an empty box means the class doesn't exist in Font Awesome" style="flex:none;width:42px;height:42px;display:inline-flex;align-items:center;justify-content:center;border:1px solid #e2e8f0;border-radius:8px;background:#f8fafc;color:#d62b83;font-size:1.2rem;"><i class="<%= product ? (product.icon_class || 'fas fa-box') : 'fas fa-box' %>"></i></span>
              </div>
              <small style="color: #666;">e.g. fas fa-pen-nib, fas fa-globe, fas fa-car — the box shows the icon as you type</small>
            </div>
            <div class="form-group">
              <label class="form-label" for="animation_class">Animation Class</label>
              <select id="animation_class" name="animation_class" class="form-input">
                <option value="kinetic-pulse-float" <%= !product || product.animation_class === 'kinetic-pulse-float' ? 'selected' : '' %>>Pulse Float</option>
                <option value="kinetic-rotate" <%= product && product.animation_class === 'kinetic-rotate' ? 'selected' : '' %>>Rotate</option>
                <option value="kinetic-oscillate" <%= product && product.animation_class === 'kinetic-oscillate' ? 'selected' : '' %>>Oscillate</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="image_url">Card Image URL</label>
            <input type="url" id="image_url" name="image_url" class="form-input" value="<%= product ? (product.image_url || '') : '' %>">
          </div>

          <div class="form-group">
            <label class="form-label" for="features">Features (one per line)</label>
            <textarea id="features" name="features" class="form-input" rows="4"><%= product && product.features ? product.features.join('\n') : '' %></textarea>
          </div>
        </div>
      </div>

      <!-- Slide-in Detail Panel -->
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-expand-arrows-alt"></i> Detail Panel (Learn More Slide-in)</h3>

          <div class="form-group">
            <label class="form-label" for="slide_in_title">Detail Title</label>
            <input type="text" id="slide_in_title" name="slide_in_title" class="form-input" value="<%= product ? (product.slide_in_title || '') : '' %>" placeholder="Headline for the detail panel">
          </div>

          <div class="form-group">
            <label class="form-label" for="slide_in_subtitle">Detail Subtitle</label>
            <textarea id="slide_in_subtitle" name="slide_in_subtitle" class="form-input" rows="2"><%= product ? (product.slide_in_subtitle || '') : '' %></textarea>
          </div>

          <div class="form-group">
            <label class="form-label" for="slide_in_content" style="display:flex;align-items:center;gap:0.5rem;">
              <i class="fas fa-code" style="color:#d62b83;"></i> Sidebar HTML Content
            </label>
            <textarea id="slide_in_content" name="slide_in_content" class="form-input" rows="16"
              style="font-family:'Fira Code','Cascadia Code','Consolas',monospace;font-size:13px;line-height:1.6;background:#1a1a2e;color:#e2e8f0;padding:1rem;border-radius:8px;tab-size:2;white-space:pre-wrap;resize:vertical;"
            ><%= product ? (product.slide_in_content || '') : '' %></textarea>
            <small style="color: #666; display:block; margin-top:0.4rem;">
              Write HTML that renders inside the sidebar panel. Use headings, lists, cards, etc.
              Click <strong>"Preview Sidebar"</strong> above to see the result live.
            </small>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="slide_in_image">Detail Image URL</label>
              <input type="url" id="slide_in_image" name="slide_in_image" class="form-input" value="<%= product ? (product.slide_in_image || '') : '' %>">
            </div>
            <div class="form-group">
              <label class="form-label" for="slide_in_video">Detail Video URL (YouTube embed)</label>
              <input type="url" id="slide_in_video" name="slide_in_video" class="form-input" value="<%= product ? (product.slide_in_video || '') : '' %>" placeholder="https://www.youtube.com/embed/...">
            </div>
          </div>
        </div>
      </div>

      <!-- Stripe & Digital Delivery -->
      <div class="card form-card" style="margin-bottom: 1.5rem;">
        <div class="card-body">
          <h3 style="margin-bottom: 1rem; color: var(--text-primary, #1a1a2e);"><i class="fas fa-credit-card"></i> Payments & Digital Delivery</h3>

          <h4 style="margin:0 0 0.75rem;color:#635bff;font-size:0.95rem;"><i class="fab fa-stripe"></i> Stripe — international cards</h4>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="stripe_product_id">Stripe Product ID</label>
              <input type="text" id="stripe_product_id" name="stripe_product_id" class="form-input" value="<%= product ? (product.stripe_product_id || '') : '' %>" placeholder="prod_...">
            </div>
            <div class="form-group">
              <label class="form-label" for="stripe_price_id">Stripe Price ID</label>
              <input type="text" id="stripe_price_id" name="stripe_price_id" class="form-input" value="<%= product ? (product.stripe_price_id || '') : '' %>" placeholder="price_...">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="stripe_payment_link">Stripe Payment Link (optional)</label>
            <input type="url" id="stripe_payment_link" name="stripe_payment_link" class="form-input" value="<%= product ? (product.stripe_payment_link || '') : '' %>" placeholder="https://buy.stripe.com/...">
            <small style="color:#666;">A ready-made Stripe checkout link, used directly for “Buy Now” products.</small>
          </div>

          <h4 style="margin:1.25rem 0 0.25rem;color:#c8102e;font-size:0.95rem;"><i class="fas fa-qrcode"></i> BCEL OnePay — Laos QR payment</h4>
          <p style="font-size:0.82rem;color:#666;margin:0 0 0.75rem;">
            Manual mode (no bank API yet): add one row per amount you sell at — e.g. “Yearly + design”, “Yearly only”, “Monthly” — each with its own QR from BCEL One and the exact kip amount. The customer picks the matching option in the payment modal and pays with a scan. Remove all rows to offer Stripe only.
          </p>
          <%
            var bcelRows = [];
            if (product && product.bcel_options) {
              try { bcelRows = typeof product.bcel_options === 'string' ? JSON.parse(product.bcel_options) : product.bcel_options; } catch (e) { bcelRows = []; }
            }
            if (!Array.isArray(bcelRows)) bcelRows = [];
            // Legacy single-QR products migrate into the first row on edit.
            if (bcelRows.length === 0 && product && product.bcel_qr_url) {
              bcelRows = [{ label: '', lak: product.price_lak != null ? Math.round(product.price_lak) : '', qr_url: product.bcel_qr_url }];
            }
            if (bcelRows.length === 0) { bcelRows = [{ label: '', lak: '', qr_url: '' }]; }
          %>
          <div id="bcel-rows">
            <% bcelRows.forEach(function(r){ %>
            <div class="bcel-row" style="display:grid;grid-template-columns:1fr 0.8fr 1.6fr 44px auto;gap:0.5rem;align-items:end;margin-bottom:0.5rem;">
              <div class="form-group" style="margin:0;">
                <label class="form-label" style="font-size:0.78rem;">Option label</label>
                <input type="text" name="bcel_label" class="form-input" maxlength="80" value="<%= r.label || '' %>" placeholder="e.g. Yearly + design">
              </div>
              <div class="form-group" style="margin:0;">
                <label class="form-label" style="font-size:0.78rem;">Amount (LAK ₭)</label>
                <input type="number" name="bcel_lak" class="form-input" min="0" step="1" value="<%= r.lak != null && r.lak !== '' ? Math.round(r.lak) : '' %>" placeholder="e.g. 1250000">
              </div>
              <div class="form-group" style="margin:0;">
                <label class="form-label" style="font-size:0.78rem;">QR image URL</label>
                <input type="url" name="bcel_qr" class="form-input" value="<%= r.qr_url || '' %>" placeholder="https://...">
              </div>
              <img class="bcel-qr-preview" src="<%= r.qr_url || '' %>" alt="QR" style="width:44px;height:44px;object-fit:contain;border:1px solid #e2e8f0;border-radius:8px;background:#f8fafc;<%= r.qr_url ? '' : 'visibility:hidden;' %>">
              <button type="button" class="btn btn-secondary btn-sm bcel-remove" title="Remove option" style="padding:0.4rem 0.6rem;">&times;</button>
            </div>
            <% }); %>
          </div>
          <button type="button" id="bcel-add" class="btn btn-secondary btn-sm" style="margin-top:0.25rem;"><i class="fas fa-plus"></i> Add price point</button>
          <small style="display:block;color:#666;margin-top:0.4rem;">Generate each fixed-amount QR in the BCEL One merchant app, upload the screenshot via Images, and paste its URL here. Whole kip only — no decimals.</small>

          <h4 style="margin:1.25rem 0 0.75rem;color:var(--text-primary,#1a1a2e);font-size:0.95rem;"><i class="fas fa-download"></i> Digital Delivery</h4>
          <div class="form-group">
            <label class="form-label" for="download_url">Download URL (for digital products)</label>
            <input type="url" id="download_url" name="download_url" class="form-input" value="<%= product ? (product.download_url || '') : '' %>" placeholder="URL to downloadable file after purchase">
          </div>
        </div>
      </div>

      <div class="form-actions form-actions-sticky" style="margin-bottom: 2rem;">
        <a href="/business/products" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Product</button>
      </div>
    </form>
  </div>
</main>

<!-- ── Sidebar Preview Panel ────────────────────────────────── -->
<div id="preview-overlay" style="position:fixed;inset:0;background:rgba(18,42,63,0.6);z-index:9998;opacity:0;visibility:hidden;transition:opacity .3s,visibility .3s;"></div>
<div id="preview-panel" style="position:fixed;top:0;right:0;width:75%;max-width:800px;height:100%;background:#fff;z-index:9999;transform:translateX(100%);transition:transform .35s ease;box-shadow:-10px 0 30px rgba(0,0,0,.2);display:flex;flex-direction:column;font-family:'Inter',sans-serif;">
  <div style="padding:1rem 1.5rem;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:center;">
    <h2 id="preview-title" style="font-size:1.4rem;margin:0;color:#1a1a2e;">Product Preview</h2>
    <button type="button" id="preview-close" style="font-size:1.6rem;background:none;border:none;cursor:pointer;color:#64748b;padding:0.25rem 0.5rem;">&times;</button>
  </div>
  <div id="preview-body" style="padding:1.5rem;overflow-y:auto;flex-grow:1;">
    <!-- filled by JS -->
  </div>
</div>

<script nonce="<%= cspNonce %>">
// ── Auto-generate slug ──────────────────────────────────────
document.getElementById('name').addEventListener('input', function() {
  const slugField = document.getElementById('slug');
  if (!slugField.dataset.manual) {
    slugField.value = this.value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
  }
});
document.getElementById('slug').addEventListener('input', function() {
  this.dataset.manual = 'true';
});
<% if (product && product.slug) { %>
document.getElementById('slug').dataset.manual = 'true';
<% } %>

// ── Dependent subcategory dropdown ──────────────────────────
(function() {
  var SUBCATS = <%- JSON.stringify((typeof taxonomy !== 'undefined' && taxonomy && taxonomy.SUBCATEGORIES) || {}) %>;
  var sp = document.getElementById('service_page');
  var sub = document.getElementById('subcategory');
  if (!sp || !sub) return;
  sp.addEventListener('change', function() {
    var list = SUBCATS[sp.value] || [];
    sub.innerHTML = '<option value="">-- Select --</option>';
    list.forEach(function(sc) {
      var o = document.createElement('option');
      o.value = sc.value;
      o.textContent = sc.label;
      sub.appendChild(o);
    });
  });
})();

// ── Pricing type toggle + annual savings preview ────────────
(function() {
  var pricingType   = document.getElementById('pricing_type');
  var oneTimeBlock  = document.getElementById('one-time-pricing');
  var subBlock      = document.getElementById('subscription-pricing');
  var monthlyInput  = document.getElementById('monthly_price');
  var yearlyInput   = document.getElementById('yearly_price');
  var discountInput = document.getElementById('annual_discount_pct');
  var currencySel   = document.getElementById('currency');
  var previewBox    = document.getElementById('savings-preview');
  var previewText   = document.getElementById('savings-preview-text');

  var tieredBlock = document.getElementById('tiered-pricing');
  var optionsBlock = document.getElementById('options-pricing');

  function syncBlocks() {
    var v = pricingType.value;
    var isSub = v === 'subscription';
    var isTiered = v === 'tiered';
    var isOptions = v === 'options';
    oneTimeBlock.style.display = (isSub || isTiered || isOptions) ? 'none' : '';
    subBlock.style.display = isSub ? '' : 'none';
    if (tieredBlock) tieredBlock.style.display = isTiered ? '' : 'none';
    if (optionsBlock) optionsBlock.style.display = isOptions ? '' : 'none';
    if (isSub) updateSavings();
    if (isTiered) updateTierPreview();
  }

  function updateSavings() {
    var monthly = parseFloat(monthlyInput.value);
    var yearly  = parseFloat(yearlyInput.value);
    var manual  = parseInt(discountInput.value, 10);
    var cur     = currencySel ? currencySel.value : 'USD';

    if (!(monthly > 0) || !(yearly >= 0) || isNaN(yearly)) {
      previewBox.style.display = 'none';
      return;
    }
    var annualizedMonthly = monthly * 12;
    var savings = annualizedMonthly - yearly;
    if (savings <= 0) {
      previewBox.style.display = 'none';
      return;
    }
    var pct = !isNaN(manual) ? manual : Math.round((savings / annualizedMonthly) * 100);
    previewText.textContent =
      'Save ' + savings.toFixed(2) + ' ' + cur + ' (' + pct + '%) with annual billing vs paying monthly.';
    previewBox.style.display = '';
  }

  // ── Quantity tier builder ──
  var tierRows = document.getElementById('tier-rows');
  var tierAdd  = document.getElementById('tier-add');
  var tierPreview = document.getElementById('tier-preview');

  function updateTierPreview() {
    if (!tierRows || !tierPreview) return;
    var cur = currencySel ? currencySel.value : 'USD';
    var rows = Array.prototype.slice.call(tierRows.querySelectorAll('.tier-row'));
    var tiers = rows.map(function(r) {
      return {
        min: parseInt(r.querySelector('[name="tier_min_qty"]').value, 10),
        price: parseFloat(r.querySelector('[name="tier_unit_price"]').value)
      };
    }).filter(function(t){ return t.min >= 1 && t.price >= 0 && !isNaN(t.price); })
      .sort(function(a,b){ return a.min - b.min; });
    if (!tiers.length) { tierPreview.style.display = 'none'; return; }
    var parts = tiers.map(function(t){ return t.min + '+: ' + t.price.toFixed(2) + ' ' + cur + '/unit'; });
    tierPreview.innerHTML = '<i class="fas fa-layer-group"></i> ' + parts.join(' &nbsp;·&nbsp; ');
    tierPreview.style.display = '';
  }

  // ── Named options builder ──
  var optionRows = document.getElementById('option-rows');
  var optionAdd = document.getElementById('option-add');
  function wireOptionRow(row) {
    var rm = row.querySelector('.option-remove');
    if (rm) rm.addEventListener('click', function() {
      if (optionRows.querySelectorAll('.option-row').length > 1) row.remove();
      else { row.querySelectorAll('input').forEach(function(i){ i.value = ''; }); }
    });
  }
  if (optionRows) {
    optionRows.querySelectorAll('.option-row').forEach(wireOptionRow);
  }
  if (optionAdd && optionRows) {
    optionAdd.addEventListener('click', function() {
      var first = optionRows.querySelector('.option-row');
      if (!first) return;
      var clone = first.cloneNode(true);
      clone.querySelectorAll('input').forEach(function(i){ i.value = ''; });
      optionRows.appendChild(clone);
      wireOptionRow(clone);
    });
  }

  function wireTierRow(row) {
    var rm = row.querySelector('.tier-remove');
    if (rm) rm.addEventListener('click', function() {
      if (tierRows.querySelectorAll('.tier-row').length > 1) row.remove();
      else { row.querySelectorAll('input').forEach(function(i){ i.value = ''; }); }
      updateTierPreview();
    });
    row.querySelectorAll('input').forEach(function(i){ i.addEventListener('input', updateTierPreview); });
  }

  if (tierRows) {
    tierRows.querySelectorAll('.tier-row').forEach(wireTierRow);
  }
  if (tierAdd && tierRows) {
    tierAdd.addEventListener('click', function() {
      var first = tierRows.querySelector('.tier-row');
      var clone = first.cloneNode(true);
      clone.querySelectorAll('input').forEach(function(i){ i.value = ''; });
      tierRows.appendChild(clone);
      wireTierRow(clone);
    });
  }

  if (pricingType) {
    pricingType.addEventListener('change', syncBlocks);
    [monthlyInput, yearlyInput, discountInput, currencySel].forEach(function(el) {
      if (el) el.addEventListener('input', updateSavings);
    });
    if (currencySel) currencySel.addEventListener('input', updateTierPreview);
    syncBlocks();
  }
})();

// ── Live icon preview next to the Icon Class input ──────────
(function() {
  var input = document.getElementById('icon_class');
  var box = document.getElementById('icon-class-preview');
  if (!input || !box) return;
  input.addEventListener('input', function() {
    box.innerHTML = '';
    var i = document.createElement('i');
    i.className = input.value.trim() || 'fas fa-box';
    box.appendChild(i);
  });
})();

// ── BCEL OnePay price-point rows (add/remove + QR previews) ──
(function() {
  var rowsEl = document.getElementById('bcel-rows');
  var addBtn = document.getElementById('bcel-add');
  if (!rowsEl || !addBtn) return;

  // Parse and rebuild the URL so only a validated http(s) address ever
  // reaches the src attribute (never the raw field text).
  function safeHttpUrl(raw) {
    try {
      var u = new URL(raw);
      if (u.protocol === 'https:' || u.protocol === 'http:') return u.href;
    } catch (e) { /* not a URL */ }
    return null;
  }

  function wireRow(row) {
    var qrInput = row.querySelector('[name="bcel_qr"]');
    var img = row.querySelector('.bcel-qr-preview');
    if (qrInput && img) {
      qrInput.addEventListener('input', function() {
        var url = safeHttpUrl(qrInput.value.trim());
        if (url) {
          img.src = url;
          img.style.visibility = '';
        } else {
          img.removeAttribute('src');
          img.style.visibility = 'hidden';
        }
      });
      img.addEventListener('error', function() { img.style.visibility = 'hidden'; });
    }
    var rm = row.querySelector('.bcel-remove');
    if (rm) rm.addEventListener('click', function() {
      if (rowsEl.querySelectorAll('.bcel-row').length > 1) {
        row.remove();
      } else {
        row.querySelectorAll('input').forEach(function(i) { i.value = ''; });
        if (img) { img.removeAttribute('src'); img.style.visibility = 'hidden'; }
      }
    });
  }

  rowsEl.querySelectorAll('.bcel-row').forEach(wireRow);
  addBtn.addEventListener('click', function() {
    var first = rowsEl.querySelector('.bcel-row');
    var clone = first.cloneNode(true);
    clone.querySelectorAll('input').forEach(function(i) { i.value = ''; });
    var img = clone.querySelector('.bcel-qr-preview');
    if (img) { img.removeAttribute('src'); img.style.visibility = 'hidden'; }
    rowsEl.appendChild(clone);
    wireRow(clone);
  });
})();

// ── Sidebar Preview Logic ───────────────────────────────────
(function() {
  const btnOpen    = document.getElementById('btn-preview-sidebar');
  const btnClose   = document.getElementById('preview-close');
  const overlay    = document.getElementById('preview-overlay');
  const panel      = document.getElementById('preview-panel');
  const titleEl    = document.getElementById('preview-title');
  const bodyEl     = document.getElementById('preview-body');

  function val(id) { return (document.getElementById(id) || {}).value || ''; }

  function open() {
    // Read current form values
    const name        = val('name');
    const description = val('description');
    const price       = val('price');
    const currency    = val('currency');
    const iconClass   = val('icon_class') || 'fas fa-box';
    const features    = val('features').split('\n').filter(function(l){ return l.trim(); });
    const siTitle     = val('slide_in_title') || name;
    const siSubtitle  = val('slide_in_subtitle');
    const siContent   = val('slide_in_content');
    const siImage     = val('slide_in_image');
    const siVideo     = val('slide_in_video');

    titleEl.textContent = siTitle || 'Product Preview';

    // Build preview HTML — matches frontend product-loader rendering
    let html = '';

    // Icon — the frontend service card leads with the product icon in a
    // circle, so the preview does too (previously read but never rendered).
    html += '<div style="text-align:center;margin-bottom:1.5rem;">' +
      '<span style="width:72px;height:72px;display:inline-flex;align-items:center;justify-content:center;border-radius:50%;background:linear-gradient(135deg,#d62b83,#8b5cf6);color:#fff;font-size:1.8rem;"><i class="' + esc(iconClass) + '"></i></span>' +
      '</div>';

    // Image
    if (siImage) {
      html += '<img src="' + esc(siImage) + '" alt="' + esc(siTitle) + '" style="width:100%;height:auto;border-radius:12px;margin-bottom:1.5rem;background:#f1f5f9;">';
    }

    // Subtitle
    if (siSubtitle) {
      html += '<p style="font-size:1.1rem;color:#64748b;margin-bottom:1.5rem;">' + esc(siSubtitle) + '</p>';
    }

    // Video
    if (siVideo) {
      html += '<div style="margin-bottom:1.5rem;"><iframe width="100%" height="360" src="' + esc(siVideo) + '" frameborder="0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen style="border-radius:12px;"></iframe></div>';
    }

    // HTML Content — rendered raw (this is the HTML textbox output)
    if (siContent) {
      var safeContent = (window.DOMPurify && window.DOMPurify.sanitize) ? window.DOMPurify.sanitize(siContent) : siContent;
      html += '<div class="preview-html-content" style="margin-bottom:1.5rem;line-height:1.7;color:#334155;">' + safeContent + '</div>';
    }

    // Features list
    if (features.length) {
      html += '<div style="margin-bottom:1.5rem;"><h3 style="font-size:1.1rem;font-weight:600;color:#1a1a2e;margin-bottom:0.75rem;">Features</h3><ul style="padding-left:1.2rem;color:#475569;">';
      features.forEach(function(f) { html += '<li style="margin-bottom:0.4rem;">' + esc(f) + '</li>'; });
      html += '</ul></div>';
    }

    // Price + Add to My Services button
    html += '<div style="text-align:center;margin-top:2rem;padding-top:1.5rem;border-top:1px solid #e2e8f0;">';
    var pType = val('pricing_type');
    if (pType === 'subscription') {
      var m = parseFloat(val('monthly_price'));
      var y = parseFloat(val('yearly_price'));
      if (m > 0) {
        html += '<p style="font-size:1.3rem;font-weight:700;color:#d62b83;margin-bottom:0.25rem;">' + m.toFixed(2) + ' ' + esc(currency || 'USD') + '<span style="font-size:0.9rem;color:#64748b;font-weight:500;">/month</span></p>';
      }
      if (y > 0) {
        html += '<p style="font-size:1.1rem;font-weight:600;color:#1a1a2e;margin-bottom:0.5rem;">' + y.toFixed(2) + ' ' + esc(currency || 'USD') + '<span style="font-size:0.9rem;color:#64748b;font-weight:500;">/year</span></p>';
      }
      if (m > 0 && y > 0 && (m * 12 - y) > 0) {
        var manualPct = parseInt(val('annual_discount_pct'), 10);
        var savePct = !isNaN(manualPct) ? manualPct : Math.round(((m * 12 - y) / (m * 12)) * 100);
        html += '<p style="font-size:0.9rem;color:#166534;margin-bottom:1rem;"><i class="fas fa-piggy-bank"></i> Save ' + savePct + '% with annual billing</p>';
      }
    } else if (price) {
      html += '<p style="font-size:1.3rem;font-weight:700;color:#d62b83;margin-bottom:1rem;">' + parseFloat(price).toFixed(2) + ' ' + esc(currency || 'USD') + '</p>';
    }
    html += '<button type="button" style="background:#d62b83;color:#fff;border:none;padding:0.8rem 2rem;border-radius:8px;font-size:1.05rem;cursor:pointer;font-weight:600;"><i class="fas fa-plus"></i> Add to My Services</button>';
    html += '</div>';

    bodyEl.innerHTML = html;

    // Show panel
    panel.style.transform = 'translateX(0)';
    overlay.style.opacity = '1';
    overlay.style.visibility = 'visible';
  }

  function close() {
    panel.style.transform = 'translateX(100%)';
    overlay.style.opacity = '0';
    overlay.style.visibility = 'hidden';
  }

  function esc(s) {
    if (!s) return '';
    const d = document.createElement('div');
    d.textContent = String(s);
    return d.innerHTML;
  }

  btnOpen.addEventListener('click', open);
  btnClose.addEventListener('click', close);
  overlay.addEventListener('click', close);

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') close();
  });
})();

// ── Readiness checklist ─────────────────────────────────────
(function() {
  var list = document.getElementById('readiness-list');
  var statusEl = document.getElementById('readiness-status');
  if (!list || !statusEl) return;

  function val(id) {
    var el = document.getElementById(id);
    return el ? (el.value || '') : '';
  }

  function sellOnlineOn() {
    var cb = document.getElementById('purchase_mode');
    return !!(cb && cb.checked);
  }

  // state: 'ok' | 'fail' | 'warn' | 'neutral'
  function setItem(key, state, text) {
    var li = list.querySelector('[data-check="' + key + '"]');
    if (!li) return;
    var iconSpan = li.querySelector('.readiness-icon');
    var textSpan = li.querySelector('.readiness-text');
    var cls, color;
    if (state === 'ok') { cls = 'fas fa-circle-check'; color = '#16a34a'; }
    else if (state === 'warn') { cls = 'fas fa-circle-exclamation'; color = '#d97706'; }
    else if (state === 'neutral') { cls = 'fas fa-minus'; color = '#94a3b8'; }
    else { cls = 'fas fa-circle-xmark'; color = '#b91c1c'; }
    iconSpan.innerHTML = '';
    var i = document.createElement('i');
    i.className = cls;
    i.style.color = color;
    iconSpan.appendChild(i);
    if (text) textSpan.textContent = text;
  }

  // Does the chosen pricing type have a real (> 0) price somewhere?
  function hasRealPrice() {
    var pType = val('pricing_type');
    if (pType === 'subscription') {
      return parseFloat(val('monthly_price')) > 0 || parseFloat(val('yearly_price')) > 0;
    }
    if (pType === 'tiered') {
      var inputs = document.querySelectorAll('#tier-rows [name="tier_unit_price"]');
      for (var k = 0; k < inputs.length; k++) {
        if (parseFloat(inputs[k].value) > 0) return true;
      }
      return false;
    }
    return parseFloat(val('price')) > 0;
  }

  function recompute() {
    var sellOn = sellOnlineOn();
    var real = hasRealPrice();

    var nameLen = val('name').trim().length;
    var nameOk = nameLen >= 3 && nameLen <= 80;

    var descOk = val('description').trim().length >= 20;

    var classOk = val('service_page') !== '' && val('subcategory') !== '';

    // One-time products may leave the price blank ("Custom Quote") — but
    // only while Sell online is off; buyable products need a real price.
    var priceOk = real;
    if (!priceOk && val('pricing_type') === 'one_time' && !sellOn && val('price').trim() === '') {
      priceOk = true;
    }

    setItem('name', nameOk ? 'ok' : 'fail');
    setItem('description', descOk ? 'ok' : 'fail');
    setItem('classification', classOk ? 'ok' : 'fail');
    setItem('price', priceOk ? 'ok' : 'fail');

    var sellCounts = false;
    var sellOk = true;
    if (sellOn) {
      sellCounts = true;
      sellOk = real;
      setItem('sell', sellOk ? 'ok' : 'fail', 'Ready to sell online');
    } else {
      setItem('sell', 'neutral', 'Sell online is off — quote requests only');
    }

    setItem('icon', val('icon_class').trim() !== '' ? 'ok' : 'warn');

    var missing = 0;
    if (!nameOk) missing++;
    if (!descOk) missing++;
    if (!classOk) missing++;
    if (!priceOk) missing++;
    if (sellCounts && !sellOk) missing++;

    if (missing === 0) {
      statusEl.textContent = 'Ready to publish ✓';
      statusEl.style.color = '#16a34a';
    } else {
      statusEl.textContent = missing + ' item(s) to finish before publishing';
      statusEl.style.color = '#d97706';
    }
  }

  var ids = ['name', 'description', 'service_page', 'subcategory', 'pricing_type',
             'price', 'monthly_price', 'yearly_price', 'purchase_mode'];
  ids.forEach(function(id) {
    var el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('input', recompute);
    el.addEventListener('change', recompute);
  });

  // Tier rows are added/removed dynamically — delegate on the container.
  var tierRows = document.getElementById('tier-rows');
  if (tierRows) {
    tierRows.addEventListener('input', recompute);
    tierRows.addEventListener('change', recompute);
    tierRows.addEventListener('click', recompute); // row removal
  }
  var tierAdd = document.getElementById('tier-add');
  if (tierAdd) tierAdd.addEventListener('click', recompute);

  recompute();
})();
</script>

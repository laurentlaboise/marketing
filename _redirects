# Root → browser language (Netlify parses the Accept-Language header for
# the Language condition), else English. 302 — a visitor's language is not
# permanent. On GitHub Pages (the live host) the same sequence runs
# client-side in /index.html: wts_lang cookie → navigator.languages → /en/.
/    /th/    302    Language=th
/    /la/    302    Language=lo
/    /fr/    302    Language=fr
/    /en/    302

# Clean article SPA rewrite (if hosted on Netlify)
/en/articles/*  /en/articles/index.html  200

# --- Localized sub-directories (/th /la /fr) -------------------------------
# Enable these single-hop SPA rewrites once the localized article apps are
# generated (a 200 rewrite to a missing file would 404, so they stay off
# until /xx/articles/index.html exists):
# /th/articles/*  /th/articles/index.html  200
# /la/articles/*  /la/articles/index.html  200
# /fr/articles/*  /fr/articles/index.html  200

# Fallback: localized paths without a generated file serve the English
# page (temporary 302, never a 404). Non-forced rules only fire when no
# physical file exists, so dropping real files into /th /la /fr takes
# precedence automatically — including localized article URLs, which hop
# via /en/articles/* to the article app until their own rewrite is enabled.
/th/*  /en/:splat  302
/la/*  /en/:splat  302
/fr/*  /en/:splat  302


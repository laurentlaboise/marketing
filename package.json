{
  "name": "marketing-website",
  "version": "1.0.0",
  "description": "Marketing website build process",
  "scripts": {
    "bundle:css": "node scripts/bundle-css.js",
    "normalize:css": "node scripts/bundle-css.js && node scripts/normalize-site-css.js",
    "build": "node scripts/bundle-css.js && node scripts/normalize-site-css.js && webpack --mode=production && node scripts/inject-footers.js",
    "build:webpack": "webpack --mode=production",
    "inject-footers": "node scripts/inject-footers.js",
    "localize": "node scripts/generate-localized-pages.js",
    "sitemap": "node scripts/generate-sitemap.js",
    "legacy-redirects": "node scripts/generate-legacy-redirects.js",
    "audit:hreflang": "node scripts/check-hreflang.js",
    "analyze-schema": "node analyze-schema.js",
    "start": "echo 'No local server - blog-backend has been migrated to wts-admin'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.1",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "tailwindcss": "^3.4.1",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "striptags": "^3.2.0"
}
}
